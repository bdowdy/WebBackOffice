Attribute VB_Name = "Select_What"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Private Display              As Integer
Private ExitForm             As Boolean
Private Sub Arrow_dwn_Click()
On Error Resume Next
Sel_Server.TopIndex = Sel_Server.TopIndex + 5
End Sub
Private Sub arrow_up_Click()
On Error Resume Next
If Sel_Server.TopIndex - 5 < 0 Then
 Sel_Server.TopIndex = 0
Else
 Sel_Server.TopIndex = Sel_Server.TopIndex - 5
End If
End Sub
Private Sub Form_Activate()
If Sel_Server.ListCount < 1 Then
  See_Msg "No Names Found", 5, ""
End If
End Sub
Private Sub Form_Load()
On Error GoTo ErrorHandler
ResizeScreen1024 Me
CenterForm Me
Get_What.Caption = Find_What
Dim Db              As ADODB.Connection
Dim RS              As ADODB.Recordset
Dim sDb             As ADODB.Connection
Dim SRS             As ADODB.Recordset
Dim Lb              As Integer
Dim FS              As Integer
Dim SA              As Integer
Dim Cl              As Integer
Dim Adb             As ADODB.Connection
Dim ARs             As ADODB.Recordset
Dim ASdb            As ADODB.Connection
Dim ASrs            As ADODB.Recordset
Dim MYName          As String
Dim Area            As String
Dim ff              As Integer
Dim Crd             As Integer
Dim TXTFileInfo()   As Variant
Dim PreFixName      As String
If OrderIs = "Go Order" Or OrderIs = "Pick Up" Or OrderIs = "Delivery" Then
 PreFixName = "Bag  #"
Else
 PreFixName = "Seat #"
End If
GetSelected = ""
If Load_What = "List Seats" Then
  For FS = 0 To Number_In_Party - 1
     Sel_Server.AddItem PreFixName & FS + 1
  Next FS
End If


If Load_What = "Item Availability" Then
  Sel_Server.AddItem "86 Menu Item"
  Sel_Server.AddItem "Set Quantity Available"
  Exit Sub
End If

If Load_What = "CloseTab" Then
  Sel_Server.AddItem "Close with card on file"
  Sel_Server.AddItem "Other Payment"
  Sel_Server.AddItem "Cancel"
  Exit Sub
End If
If Load_What = "LoadConcepts" Then
 ConnectADODB "MSaleData", Db
   Sql = "Select * from [Concept] "
   Sql = Sql & " Order by [Name] asc"
 ConnectADORS Sql, Db, RS
  If RS.EOF Then
   See_Msg "No Concepts Found", 5, ""
  End If
  Sel_Server.Clear
  Do While Not RS.EOF
   Sel_Server.AddItem RS.fields("Name").Value & ""
   RS.MoveNext
  Loop
  DbClose Db, RS
  Exit Sub
End If
If Load_What = "Survey" Then
 'Get_What = "Is this your first time eating Krispy Krunchy"
 Get_What = GetConfigInfo("Survey", "Survey Discription", "", "FUNCTIONS.INI")
 ConnectADODB "MSaleData", Db
   Sql = "Select * from [Special Requests] Where [Remote 1] = 'Survey'"
   Sql = Sql & " Order by [Request Name] asc"
 ConnectADORS Sql, Db, RS
  If RS.EOF Then
   See_Msg "No Names Found", 5, ""
  End If
  Sel_Server.Clear
  Do While Not RS.EOF
   Sel_Server.AddItem RS.fields("Request Name").Value & ""
   RS.MoveNext
  Loop
  DbClose Db, RS
  Exit Sub
End If

If Load_What = "Reprint Audits" Then
 ConnectADODB SvrPath.TerminalPath & "MSaleData", Db
   Sql = "Select * from [AuditReports] "
   Sql = Sql & " Where TRY_CAST([Date] AS date) = '" & CDate(SearchDates.Item(1).StartDate) & "'"
   Sql = Sql & " Order by [Name] asc"
 ConnectADORS Sql, Db, RS
  If RS.EOF Then
   See_Msg "No Audits Found for this date " & SearchDates.Item(1).StartDate, 5, ""
  End If
  Sel_Server.Clear
  Sel_Server.AddItem "Print All"
  Do While Not RS.EOF
   Sel_Server.AddItem RS.fields("Name").Value & ""
   RS.MoveNext
  Loop
  DbClose Db, RS
  Exit Sub
End If
If Load_What = "GroupAudits" Then
   ConnectADODB "MSaleData", Db
   Sql = "Select * from [Check Numbers] Where [Audit Status] = 0 and [Register Group] = '" & SvrPath.TerminalGroupName & "'"
   ConnectADORS Sql, Db, RS
   Sel_Server.Clear
   Do While Not RS.EOF
     Sel_Server.AddItem RS.fields("Work Area").Value & ""
     RS.MoveNext
   Loop
  DbClose Db, RS
  Exit Sub
End If
If Load_What = "Servers" Then
        ConnectADODB "MSaleData", ASdb
        'ConnectADODB SvrPath.LocalTerminalPath & "EMPLOYEE.MDB", Db
