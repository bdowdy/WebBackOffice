@{
    var navPath = (Context.Request.Path.Value ?? "/").TrimEnd('/');
    if (navPath.Length == 0) { navPath = "/"; }

    bool NavIsCurrent(string href)
    {
        if (href == "/")
        {
            return navPath == "/" || navPath.Equals("/MSaleAdmin", StringComparison.OrdinalIgnoreCase) || navPath.Equals("/MSaleAdmin/Index", StringComparison.OrdinalIgnoreCase);
        }
        return navPath.Equals(href, StringComparison.OrdinalIgnoreCase);
    }
}
<a href="/" class="block px-6 pb-4 pt-6">
    <img src="/img/Microsale-White-Color-Horizontal-RGB-Logo.svg" alt="MicroSale" class="h-7 w-auto" />
    <span class="mt-2 block text-[10px] font-semibold uppercase tracking-[0.25em] text-gold-400">Back Office</span>
</a>
<nav class="flex-1 space-y-6 px-4 pb-8 pt-2">
    <a href="/" class="flex items-center gap-2.5 rounded-md px-2 py-2 text-sm font-medium @(NavIsCurrent("/") ? "bg-white/10 text-gold-300" : "text-neutral-400 hover:bg-white/5 hover:text-white")">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" />
        </svg>
        Dashboard
    </a>
    @foreach (var s in AdminNav.Sections)
    {
        <div>
            <div class="flex items-center gap-2.5 px-2 py-1.5 font-display text-xs font-medium uppercase tracking-wider text-neutral-500">
                <span class="h-1.5 w-1.5 rounded-full bg-gold-500"></span>
                @s.Name
            </div>
            <div class="mt-1 space-y-0.5">
                @foreach (var l in s.Links)
                {
                    <a href="@l.Href" title="@l.Title"
                       class="block truncate rounded-md px-4 py-2 text-sm @(NavIsCurrent(l.Href) ? "bg-white/10 font-medium text-gold-300" : "text-neutral-400 hover:bg-white/5 hover:text-white")">@l.Title</a>
                }
            </div>
        </div>
    }
</nav>
