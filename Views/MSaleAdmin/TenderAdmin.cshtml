@{
    ViewData["Title"] = "Tender Setup";
    ViewData["Subtitle"] = "Program cash, credit, EMV, house account, fees, and tender options.";
}

<div class="grid gap-6 lg:grid-cols-[320px_1fr]">

    <div class="self-start rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Existing Tenders</h2>
        <p class="mt-1 text-sm text-slate-500">Click a tender to edit it.</p>

        <button type="button"
                onclick="clearForm()"
                class="mt-4 inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
            Add New Tender
        </button>

        <div id="tenderList" class="mt-3 max-h-[640px] divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h2 class="text-base font-semibold text-slate-900">Tender Details</h2>

        <input type="hidden" id="originalTenderName" />

        <div class="mt-4 grid gap-4 sm:grid-cols-2">

            <div>
                <label class="block text-sm font-medium text-slate-700">Tender Name</label>
                <input id="tenderName"
                       placeholder="Enter tender name"
                       class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Fee Type</label>
                <select id="feeType"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option>Cash Discount %</option>
                    <option>Convenience Fee %</option>
                    <option>Convenience Fee Amount</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Fee Amount</label>
                <input id="feeAmount"
                       type="number"
                       step="0.01"
                       value="0.00"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Alternate Name</label>
                <input id="altName"
                       value="None"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-4">
            <button type="button"
                    onclick="saveAltName()"
                    class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
                Save Alternate Name
            </button>
        </div>

        <h2 class="mt-6 text-base font-semibold text-slate-900">Tender Options</h2>

        <div class="mt-3 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="usesEMV" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                EMV Pin Pad Tender
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isGiftEPay" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Gift E-Pay Tender
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isHouseAccount" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                House Account
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isKiosk" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Available on Kiosk
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isInterCard" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                InterCard Game Card Tender
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isPropertyManagement" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Property Management Tender
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="isCash" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Cash Tender - Gives Change
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="opensDrawer" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Opens Cash Drawer
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input type="checkbox" id="managerAccess" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Manager Access Required
            </label>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-6">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearForm()">Clear</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteTender()">Delete</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTender()">Save Tender</button>
        </div>

    </div>

</div>

<script>
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadTenders();
    });

    function loadTenders() {
        fetch('/MSaleAdmin/GetTenders')
            .then(r => r.json())
            .then(data => {

                let list = document.getElementById('tenderList');
                list.innerHTML = "";

                data.forEach(function (t) {

                    let name = t.tenderName || t.TenderName || "";

                    if (name === "")
                        return;

                    let div = document.createElement("div");
                    div.className = "tender-item cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50";
                    div.innerText = name;

                    div.onclick = function () {

                        document.querySelectorAll(".tender-item")
                            .forEach(x => x.classList.remove("active", ...SEL));

                        div.classList.add("active", ...SEL);

                        loadTenderByName(name);
                    };

                    list.appendChild(div);
                });
            })
            .catch(err => alert("GetTenders error: " + err));
    }

    function loadTenderByName(name) {

        if (!name) return;

        fetch('/MSaleAdmin/GetTender?name=' + encodeURIComponent(name))
            .then(r => {
                if (!r.ok) throw new Error("Tender not found");
                return r.json();
            })
            .then(t => {

                document.getElementById('originalTenderName').value =
                    t.tenderName || t.TenderName || "";

                document.getElementById('tenderName').value =
                    t.tenderName || t.TenderName || "";

                setChecked('usesEMV', t.usesEMV || t.UsesEMV);
                setChecked('isGiftEPay', t.isGiftEPay || t.IsGiftEPay);
                setChecked('isHouseAccount', t.isHouseAccount || t.IsHouseAccount);
                setChecked('isKiosk', t.isKiosk || t.IsKiosk);
                setChecked('isInterCard', t.isInterCard || t.IsInterCard);
                setChecked('isPropertyManagement', t.isPropertyManagement || t.IsPropertyManagement);
                setChecked('isCash', t.isCash || t.IsCash);
                setChecked('opensDrawer', t.opensDrawer || t.OpensDrawer);
                setChecked('managerAccess', t.managerAccess || t.ManagerAccess);

                document.getElementById('feeAmount').value =
                    Number(t.convenienceFeeAmt || t.ConvenienceFeeAmt || 0).toFixed(2);

                document.getElementById('feeType').value =
                    t.feeType || t.FeeType || "Cash Discount %";

                document.getElementById('altName').value =
                    t.altName || t.AltName || "None";
            })
            .catch(err => alert("GetTender error: " + err));
    }

    function setChecked(id, value) {
        document.getElementById(id).checked =
            value === true || value === 1 || value === "1" || value === "true";
    }

    function checked(id) {
        return document.getElementById(id).checked;
    }

    function saveTender() {

        let tender = {
            originalTenderName: document.getElementById('originalTenderName').value,
            tenderName: document.getElementById('tenderName').value,

            usesEMV: checked('usesEMV'),
            isGiftEPay: checked('isGiftEPay'),
            isHouseAccount: checked('isHouseAccount'),
            isKiosk: checked('isKiosk'),
            isInterCard: checked('isInterCard'),
            isPropertyManagement: checked('isPropertyManagement'),
            isCash: checked('isCash'),
            opensDrawer: checked('opensDrawer'),
            managerAccess: checked('managerAccess'),

            convenienceFeeAmt:
                parseFloat(document.getElementById('feeAmount').value || 0),

            feeType:
                document.getElementById('feeType').value,

            altName:
                document.getElementById('altName').value
        };

        if (!tender.tenderName.trim()) {
            alert("Enter a tender name.");
            return;
        }

        fetch('/MSaleAdmin/SaveTender', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tender)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadTenders();
        });
    }

    function deleteTender() {

        let name =
            document.getElementById('tenderName').value;

        if (!name.trim()) {
            alert("Select a tender first.");
            return;
        }

        if (!confirm("Delete tender " + name + "?"))
            return;

        fetch('/MSaleAdmin/DeleteTender?name=' + encodeURIComponent(name), {
            method: 'DELETE'
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            clearForm();
            loadTenders();
        });
    }

    function saveAltName() {

        let data = {
            feeType: document.getElementById('feeType').value,
            altName: document.getElementById('altName').value
        };

        fetch('/MSaleAdmin/SaveAltName', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(result => alert(result.message || "Saved"));
    }

    function clearForm() {

        document.getElementById('originalTenderName').value = "";
        document.getElementById('tenderName').value = "";

        document.querySelectorAll('input[type=checkbox]')
            .forEach(x => x.checked = false);

        document.getElementById('feeAmount').value = "0.00";
        document.getElementById('feeType').value = "Cash Discount %";
        document.getElementById('altName').value = "None";

        document.querySelectorAll(".tender-item")
            .forEach(x => x.classList.remove("active", ...SEL));

        document.getElementById('tenderName').focus();
    }
</script>
