@{
    ViewData["Title"] = "Tender Setup";
}

<style>
    body {
        background: #f4f6f9;
    }

    .page {
        max-width: 1250px;
        margin: 35px auto;
        background: white;
        padding: 28px;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(0,0,0,.12);
    }

    .header {
        background: #2c3e50;
        color: white;
        padding: 24px;
        border-radius: 14px;
        margin-bottom: 24px;
    }

        .header h2 {
            margin: 0;
            font-size: 32px;
        }

    .layout {
        display: grid;
        grid-template-columns: 330px 1fr;
        gap: 22px;
    }

    .panel {
        border: 1px solid #e1e5ea;
        background: #fafafa;
        border-radius: 12px;
        padding: 18px;
    }

    .panel-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 12px;
    }

    .tender-list {
        background: white;
        border: 1px solid #dce1e6;
        border-radius: 10px;
        max-height: 640px;
        overflow-y: auto;
    }

    .tender-item {
        padding: 12px 14px;
        border-bottom: 1px solid #eee;
        cursor: pointer;
        font-weight: 600;
        color: #2c3e50;
    }

        .tender-item:hover {
            background: #eef6ff;
        }

        .tender-item.active {
            background: #3498db;
            color: white;
        }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 16px;
    }

    label {
        font-weight: 700;
        color: #34495e;
        margin-bottom: 6px;
        display: block;
    }

    input, select {
        width: 100%;
        height: 42px;
        border: 1px solid #cfd6dd;
        border-radius: 8px;
        padding: 0 12px;
        box-sizing: border-box;
        font-size: 15px;
    }

        input:focus, select:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 5px rgba(52,152,219,.35);
        }

    .required {
        background: #fff8cc;
    }

    .option-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 12px;
        margin-top: 8px;
    }

    .option-card {
        background: white;
        border: 1px solid #dce1e6;
        border-radius: 10px;
        padding: 13px;
        cursor: pointer;
        font-weight: 600;
    }

        .option-card:hover {
            background: #eef6ff;
            border-color: #3498db;
        }

        .option-card input {
            width: auto;
            height: auto;
            margin-right: 8px;
        }

    .button-bar {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 22px;
    }

    button {
        border: none;
        border-radius: 8px;
        padding: 11px 22px;
        font-weight: 700;
        color: white;
        cursor: pointer;
    }

    .btn-new {
        background: #3498db;
    }

    .btn-save {
        background: #27ae60;
    }

    .btn-delete {
        background: #e74c3c;
    }

    .btn-clear {
        background: #7f8c8d;
    }

    .btn-alt {
        background: #8e44ad;
    }

    .hint {
        color: #7f8c8d;
        font-size: 14px;
        margin-bottom: 12px;
    }
</style>

<div class="page">

    <div class="header">
        <h2>Tender Setup</h2>
        <div>Program cash, credit, EMV, house account, fees, and tender options.</div>
    </div>

    <div class="layout">

        <div class="panel">
            <div class="panel-title">Existing Tenders</div>
            <div class="hint">Click a tender to edit it.</div>

            <button type="button"
                    class="btn-new"
                    onclick="clearForm()"
                    style="width:100%; margin-bottom:12px;">
                Add New Tender
            </button>

            <div id="tenderList" class="tender-list"></div>
        </div>

        <div class="panel">

            <div class="panel-title">Tender Details</div>

            <input type="hidden" id="originalTenderName" />

            <div class="grid">

                <div>
                    <label>Tender Name</label>
                    <input id="tenderName"
                           class="required"
                           placeholder="Enter tender name" />
                </div>

                <div>
                    <label>Fee Type</label>
                    <select id="feeType">
                        <option>Cash Discount %</option>
                        <option>Convenience Fee %</option>
                        <option>Convenience Fee Amount</option>
                    </select>
                </div>

                <div>
                    <label>Fee Amount</label>
                    <input id="feeAmount"
                           type="number"
                           step="0.01"
                           value="0.00" />
                </div>

                <div>
                    <label>Alternate Name</label>
                    <input id="altName" value="None" />
                </div>

            </div>

            <div class="button-bar">
                <button type="button"
                        class="btn-alt"
                        onclick="saveAltName()">
                    Save Alternate Name
                </button>
            </div>

            <br />

            <div class="panel-title">Tender Options</div>

            <div class="option-grid">

                <label class="option-card">
                    <input type="checkbox" id="usesEMV" />
                    EMV Pin Pad Tender
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isGiftEPay" />
                    Gift E-Pay Tender
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isHouseAccount" />
                    House Account
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isKiosk" />
                    Available on Kiosk
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isInterCard" />
                    InterCard Game Card Tender
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isPropertyManagement" />
                    Property Management Tender
                </label>

                <label class="option-card">
                    <input type="checkbox" id="isCash" />
                    Cash Tender - Gives Change
                </label>

                <label class="option-card">
                    <input type="checkbox" id="opensDrawer" />
                    Opens Cash Drawer
                </label>

                <label class="option-card">
                    <input type="checkbox" id="managerAccess" />
                    Manager Access Required
                </label>

            </div>

            <div class="button-bar">
                <button type="button" class="btn-clear" onclick="clearForm()">Clear</button>
                <button type="button" class="btn-delete" onclick="deleteTender()">Delete</button>
                <button type="button" class="btn-save" onclick="saveTender()">Save Tender</button>
            </div>

        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadTenders();
    });

    function loadTenders() {
        fetch('/MSaleAdmin/GetTenders')
            .then(r => r.json())
            .then(data => {

                let list = document.getElementById('tenderList');
                list.innerHTML = "";

                data.forEach(function (t) {

                    let name = t.tenderName || t.TenderName || "";

                    if (name === "")
                        return;

                    let div = document.createElement("div");
                    div.className = "tender-item";
                    div.innerText = name;

                    div.onclick = function () {

                        document.querySelectorAll(".tender-item")
                            .forEach(x => x.classList.remove("active"));

                        div.classList.add("active");

                        loadTenderByName(name);
                    };

                    list.appendChild(div);
                });
            })
            .catch(err => alert("GetTenders error: " + err));
    }

    function loadTenderByName(name) {

        if (!name) return;

        fetch('/MSaleAdmin/GetTender?name=' + encodeURIComponent(name))
            .then(r => {
                if (!r.ok) throw new Error("Tender not found");
                return r.json();
            })
            .then(t => {

                document.getElementById('originalTenderName').value =
                    t.tenderName || t.TenderName || "";

                document.getElementById('tenderName').value =
                    t.tenderName || t.TenderName || "";

                setChecked('usesEMV', t.usesEMV || t.UsesEMV);
                setChecked('isGiftEPay', t.isGiftEPay || t.IsGiftEPay);
                setChecked('isHouseAccount', t.isHouseAccount || t.IsHouseAccount);
                setChecked('isKiosk', t.isKiosk || t.IsKiosk);
                setChecked('isInterCard', t.isInterCard || t.IsInterCard);
                setChecked('isPropertyManagement', t.isPropertyManagement || t.IsPropertyManagement);
                setChecked('isCash', t.isCash || t.IsCash);
                setChecked('opensDrawer', t.opensDrawer || t.OpensDrawer);
                setChecked('managerAccess', t.managerAccess || t.ManagerAccess);

                document.getElementById('feeAmount').value =
                    Number(t.convenienceFeeAmt || t.ConvenienceFeeAmt || 0).toFixed(2);

                document.getElementById('feeType').value =
                    t.feeType || t.FeeType || "Cash Discount %";

                document.getElementById('altName').value =
                    t.altName || t.AltName || "None";
            })
            .catch(err => alert("GetTender error: " + err));
    }

    function setChecked(id, value) {
        document.getElementById(id).checked =
            value === true || value === 1 || value === "1" || value === "true";
    }

    function checked(id) {
        return document.getElementById(id).checked;
    }

    function saveTender() {

        let tender = {
            originalTenderName: document.getElementById('originalTenderName').value,
            tenderName: document.getElementById('tenderName').value,

            usesEMV: checked('usesEMV'),
            isGiftEPay: checked('isGiftEPay'),
            isHouseAccount: checked('isHouseAccount'),
            isKiosk: checked('isKiosk'),
            isInterCard: checked('isInterCard'),
            isPropertyManagement: checked('isPropertyManagement'),
            isCash: checked('isCash'),
            opensDrawer: checked('opensDrawer'),
            managerAccess: checked('managerAccess'),

            convenienceFeeAmt:
                parseFloat(document.getElementById('feeAmount').value || 0),

            feeType:
                document.getElementById('feeType').value,

            altName:
                document.getElementById('altName').value
        };

        if (!tender.tenderName.trim()) {
            alert("Enter a tender name.");
            return;
        }

        fetch('/MSaleAdmin/SaveTender', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tender)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadTenders();
        });
    }

    function deleteTender() {

        let name =
            document.getElementById('tenderName').value;

        if (!name.trim()) {
            alert("Select a tender first.");
            return;
        }

        if (!confirm("Delete tender " + name + "?"))
            return;

        fetch('/MSaleAdmin/DeleteTender?name=' + encodeURIComponent(name), {
            method: 'DELETE'
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            clearForm();
            loadTenders();
        });
    }

    function saveAltName() {

        let data = {
            feeType: document.getElementById('feeType').value,
            altName: document.getElementById('altName').value
        };

        fetch('/MSaleAdmin/SaveAltName', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(result => alert(result.message || "Saved"));
    }

    function clearForm() {

        document.getElementById('originalTenderName').value = "";
        document.getElementById('tenderName').value = "";

        document.querySelectorAll('input[type=checkbox]')
            .forEach(x => x.checked = false);

        document.getElementById('feeAmount').value = "0.00";
        document.getElementById('feeType').value = "Cash Discount %";
        document.getElementById('altName').value = "None";

        document.querySelectorAll(".tender-item")
            .forEach(x => x.classList.remove("active"));

        document.getElementById('tenderName').focus();
    }
</script>