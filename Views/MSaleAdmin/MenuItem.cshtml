@{
    ViewData["Title"] = "Menu Item Maintenance";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-3 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
        <label for="menuItemSelect" class="text-sm font-medium text-slate-700">Existing Menu Item</label>
        <select id="menuItemSelect" onchange="loadMenuItem()" class="block w-full max-w-md rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

        <button type="button" onclick="newItem()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">New</button>
        <button type="button" onclick="saveItem()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save</button>
        <button type="button" onclick="loadMenuItems()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Reload</button>

        <div class="flex-1"></div>

        <button type="button" onclick="location.href='/MSaleAdmin'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Dashboard</button>
        <button type="button" onclick="location.href='/'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Item Information</h3>

            <input type="hidden" id="originalMenuItemName" />

            <label for="menuItemName" class="mt-4 block text-sm font-medium text-slate-700">Menu Item Name</label>
            <input id="menuItemName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />

            <label for="departmentName" class="mt-4 block text-sm font-medium text-slate-700">Department</label>
            <select id="departmentName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            <label for="reportCategory" class="mt-4 block text-sm font-medium text-slate-700">Report Category</label>
            <select id="reportCategory" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            <div class="mt-4 grid grid-cols-2 gap-4">
                <div>
                    <label for="regularPrice" class="block text-sm font-medium text-slate-700">Regular Price</label>
                    <input id="regularPrice" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="inventoryAmount" class="block text-sm font-medium text-slate-700">Inventory Amount</label>
                    <input id="inventoryAmount" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="productCost" class="block text-sm font-medium text-slate-700">Product Cost</label>
                    <input id="productCost" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="upCharge" class="block text-sm font-medium text-slate-700">Up Charge</label>
                    <input id="upCharge" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <label for="itemInfo" class="mt-4 block text-sm font-medium text-slate-700">Item Information</label>
            <textarea id="itemInfo" class="mt-1 block min-h-[150px] w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></textarea>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Item Codes / Options</h3>

            <label for="barCode" class="mt-4 block text-sm font-medium text-slate-700">Barcode</label>
            <input id="barCode" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />

            <div class="mt-4 grid grid-cols-3 gap-4">
                <div>
                    <label for="salesTaxTable" class="block text-sm font-medium text-slate-700">Sales Tax Table</label>
                    <select id="salesTaxTable" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label for="specialTaxTable" class="block text-sm font-medium text-slate-700">Special Tax Table</label>
                    <select id="specialTaxTable" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label for="liquorTaxAmount" class="block text-sm font-medium text-slate-700">Surcharge</label>
                    <select id="liquorTaxAmount" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
            </div>

            <hr class="my-5 border-slate-200" />

            <div class="grid grid-cols-2 gap-4">
                <div><label for="remote1" class="block text-sm font-medium text-slate-700">Remote Printer 1</label><select id="remote1" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
                <div><label for="remote4" class="block text-sm font-medium text-slate-700">Remote Printer 4</label><select id="remote4" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
                <div><label for="remote2" class="block text-sm font-medium text-slate-700">Remote Printer 2</label><select id="remote2" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
                <div><label for="remote5" class="block text-sm font-medium text-slate-700">Remote Printer 5</label><select id="remote5" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
                <div><label for="remote3" class="block text-sm font-medium text-slate-700">Remote Printer 3</label><select id="remote3" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
                <div><label for="remote6" class="block text-sm font-medium text-slate-700">Remote Printer 6</label><select id="remote6" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select></div>
            </div>

            <hr class="my-5 border-slate-200" />

            <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="avalibility" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Available</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="taxable" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Taxable</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="useModifiers" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Use Modifiers</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="modifiersAreOptional" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Modifiers Optional</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="openPrice" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Open Price</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="quickPick" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Quick Pick</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="quickButton" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Quick Button</label>
                <label class="flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2.5 text-sm text-slate-700 ring-1 ring-inset ring-slate-200"><input type="checkbox" id="onLine" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> On Line</label>
            </div>

            <div id="status" class="mt-4 text-sm font-medium text-slate-600"></div>
        </div>
    </div>
</div>

<script>
    let isNewItem = false;
    let lookupsReady = false;

    document.addEventListener("DOMContentLoaded", function () {
        startup();
    });

    async function startup() {
        loadTaxOptions();

        await loadDepartments();
        await loadReportCategories();
        await loadSystemPrinters();
        await loadMenuItems();

        lookupsReady = true;
        newItem();
    }

    function loadTaxOptions() {
        ["salesTaxTable", "specialTaxTable", "liquorTaxAmount"].forEach(id => {
            const ddl = document.getElementById(id);
            ddl.innerHTML = "";

            for (let i = 0; i <= 5; i++) {
                ddl.add(new Option(i.toString(), i.toString()));
            }
        });
    }

    function loadDepartments() {
        return fetch('/MenuItem/GetDepartments')
            .then(r => r.json())
            .then(data => {
                const ddl = document.getElementById("departmentName");
                ddl.innerHTML = "";
                ddl.add(new Option("-- Select Department --", ""));
                data.forEach(x => ddl.add(new Option(x, x)));
            });
    }

    function loadReportCategories() {
        return fetch('/MenuItem/GetReportCategories')
            .then(r => r.json())
            .then(data => {
                const ddl = document.getElementById("reportCategory");
                ddl.innerHTML = "";
                ddl.add(new Option("-- Select Report Category --", ""));
                data.forEach(x => ddl.add(new Option(x, x)));
            });
    }

    function loadSystemPrinters() {
        return fetch('/MenuItem/GetSystemPrinters')
            .then(r => r.json())
            .then(data => {
                ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"].forEach(id => {
                    const ddl = document.getElementById(id);
                    ddl.innerHTML = "";
                    ddl.add(new Option("-- None --", ""));
                    data.forEach(x => ddl.add(new Option(x, x)));
                });
            });
    }

    function loadMenuItems() {
        return fetch('/MenuItem/GetMenuItemNames')
            .then(r => r.json())
            .then(data => {
                const ddl = document.getElementById("menuItemSelect");
                ddl.innerHTML = "";
                ddl.add(new Option("-- Select Menu Item --", ""));
                data.forEach(x => ddl.add(new Option(x, x)));
            });
    }

    function loadMenuItem() {
        const name = document.getElementById("menuItemSelect").value;

        if (!name) {
            newItem();
            return;
        }

        fetch('/MenuItem/GetMenuItem?menuItemName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message || "Item not found.");
                    return;
                }

                const x = result.data;
                isNewItem = false;

                document.getElementById("originalMenuItemName").value = x.menuItemName || "";
                document.getElementById("menuItemName").value = x.menuItemName || "";
                document.getElementById("departmentName").value = x.departmentName || "";
                document.getElementById("reportCategory").value = x.reportCategory || "";

                document.getElementById("regularPrice").value = x.regularPrice ?? 0;
                document.getElementById("inventoryAmount").value = x.inventoryAmount ?? 0;
                document.getElementById("productCost").value = x.productCost ?? 0;
                document.getElementById("upCharge").value = x.upCharge ?? 0;

                document.getElementById("barCode").value = x.barCode || "";
                document.getElementById("itemInfo").value = x.itemInfo || "";

                document.getElementById("salesTaxTable").value = String(x.salesTaxTable ?? 0);
                document.getElementById("specialTaxTable").value = String(x.specialTaxTable ?? 0);
                document.getElementById("liquorTaxAmount").value = String(x.liquorTaxAmount ?? 0);

                setPrinterValue("remote1", x.remote1);
                setPrinterValue("remote2", x.remote2);
                setPrinterValue("remote3", x.remote3);
                setPrinterValue("remote4", x.remote4);
                setPrinterValue("remote5", x.remote5);
                setPrinterValue("remote6", x.remote6);

                document.getElementById("avalibility").checked = x.avalibility === true;
                document.getElementById("taxable").checked = x.taxable === true;
                document.getElementById("useModifiers").checked = x.useModifiers === true;
                document.getElementById("modifiersAreOptional").checked = x.modifiersAreOptional === true;
                document.getElementById("openPrice").checked = x.openPrice === true;
                document.getElementById("quickPick").checked = x.quickPick === true;
                document.getElementById("quickButton").checked = x.quickButton === true;
                document.getElementById("onLine").checked = x.onLine === true;

                document.getElementById("status").innerText = "Editing existing item";
            });
    }

    function setPrinterValue(id, value) {
        const ddl = document.getElementById(id);
        const val = value || "";

        if (val && !Array.from(ddl.options).some(o => o.value === val)) {
            ddl.add(new Option(val, val));
        }

        ddl.value = val;
    }

    function newItem() {
        isNewItem = true;

        document.getElementById("menuItemSelect").value = "";
        document.getElementById("originalMenuItemName").value = "";
        document.getElementById("menuItemName").value = "";
        document.getElementById("departmentName").value = "";
        document.getElementById("reportCategory").value = "";

        document.getElementById("regularPrice").value = "0.00";
        document.getElementById("inventoryAmount").value = "0";
        document.getElementById("productCost").value = "0.00";
        document.getElementById("upCharge").value = "0.00";

        document.getElementById("barCode").value = "";
        document.getElementById("itemInfo").value = "";

        document.getElementById("salesTaxTable").value = "0";
        document.getElementById("specialTaxTable").value = "0";
        document.getElementById("liquorTaxAmount").value = "0";

        ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"].forEach(id => {
            document.getElementById(id).value = "";
        });

        document.getElementById("avalibility").checked = true;
        document.getElementById("taxable").checked = true;
        document.getElementById("useModifiers").checked = false;
        document.getElementById("modifiersAreOptional").checked = false;
        document.getElementById("openPrice").checked = false;
        document.getElementById("quickPick").checked = false;
        document.getElementById("quickButton").checked = false;
        document.getElementById("onLine").checked = false;

        document.getElementById("status").innerText = "Adding new menu item";
    }

    function saveItem() {
        const name = document.getElementById("menuItemName").value.trim();

        if (!name) {
            alert("Enter a menu item name.");
            return;
        }

        const model = {
            isNewItem: isNewItem,
            menuItemName: name,
            originalMenuItemName: document.getElementById("originalMenuItemName").value,

            departmentName: document.getElementById("departmentName").value,
            reportCategory: document.getElementById("reportCategory").value,

            regularPrice: parseFloat(document.getElementById("regularPrice").value || 0),
            inventoryAmount: parseFloat(document.getElementById("inventoryAmount").value || 0),
            productCost: parseFloat(document.getElementById("productCost").value || 0),
            upCharge: parseFloat(document.getElementById("upCharge").value || 0),

            barCode: document.getElementById("barCode").value,
            itemInfo: document.getElementById("itemInfo").value,

            salesTaxTable: parseInt(document.getElementById("salesTaxTable").value || 0),
            specialTaxTable: parseInt(document.getElementById("specialTaxTable").value || 0),
            liquorTaxAmount: parseInt(document.getElementById("liquorTaxAmount").value || 0),

            remote1: document.getElementById("remote1").value,
            remote2: document.getElementById("remote2").value,
            remote3: document.getElementById("remote3").value,
            remote4: document.getElementById("remote4").value,
            remote5: document.getElementById("remote5").value,
            remote6: document.getElementById("remote6").value,

            avalibility: document.getElementById("avalibility").checked,
            taxable: document.getElementById("taxable").checked,
            useModifiers: document.getElementById("useModifiers").checked,
            modifiersAreOptional: document.getElementById("modifiersAreOptional").checked,
            openPrice: document.getElementById("openPrice").checked,
            quickPick: document.getElementById("quickPick").checked,
            quickButton: document.getElementById("quickButton").checked,
            onLine: document.getElementById("onLine").checked
        };

        fetch('/MenuItem/SaveMenuItem', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(model)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");

            if (x.success === true) {
                isNewItem = false;
                document.getElementById("originalMenuItemName").value = name;
                document.getElementById("status").innerText = "Saved";
                loadMenuItems();
            }
        })
        .catch(err => alert("Save failed: " + err.message));
    }
</script>
