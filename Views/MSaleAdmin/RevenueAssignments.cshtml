@{
    ViewData["Title"] = "Revenue Assignments";
    ViewData["Subtitle"] = "Link master departments and non-sale revenue items to a revenue item.";
}

<div class="max-w-2xl space-y-6">

    <div class="space-y-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <select id="revenueCombo" class="block w-full max-w-xs rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
            <option value="">Select Revenue Item</option>
        </select>

        <div class="flex flex-wrap items-center gap-2">

            <button type="button" onclick="loadMasterDepartments()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Load Master Departments
            </button>

            <button type="button" onclick="loadNonSaleRevenue()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Load Non Sale Revenue
            </button>

            <button type="button" onclick="selectAllItems()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Select All
            </button>

            <button type="button" onclick="saveAssignments()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
                Save
            </button>

        </div>

        <div id="dlist" class="h-[500px] max-w-md divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>

    </div>

    <div class="space-y-3 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div class="flex flex-wrap items-center gap-2">

            <input type="text"
                   id="newRevenueName"
                   placeholder="New Revenue Name"
                   class="block w-64 rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />

            <button type="button" onclick="addRevenueItem()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Add Revenue Item
            </button>

        </div>

        <div class="flex flex-wrap items-center gap-2">

            <input type="text"
                   id="newMasterDepartment"
                   placeholder="New Master Department"
                   class="block w-64 rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />

            <button type="button" onclick="addMasterDepartment()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Add Master Department
            </button>

        </div>
    </div>

</div>


<script>
document.addEventListener("DOMContentLoaded", function () {

loadRevenueNames();

document.getElementById("revenueCombo")
.addEventListener("change", function () {

loadExisting();

});
});
function loadRevenueNames() {

fetch('/MSaleAdmin/GetNonSaleRevenue')
.then(r => r.json())
.then(data => {

let combo =
document.getElementById("revenueCombo");

combo.innerHTML =
'<option value="">Select Revenue Item</option>';

data.forEach(function (item) {

let opt = document.createElement("option");

opt.value = item;
opt.text = item;

combo.appendChild(opt);

});
});
}
function addCheckItem(text) {

let div = document.createElement("div");

div.className = "flex items-center gap-2 px-4 py-2.5 text-sm text-slate-700";

let chk = document.createElement("input");

chk.type = "checkbox";
chk.value = text;
chk.className = "h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500";

let lbl = document.createElement("span");

lbl.innerText = " " + text;

div.appendChild(chk);
div.appendChild(lbl);

document.getElementById("dlist")
.appendChild(div);
}
function clearList() {

document.getElementById("dlist").innerHTML = "";

}
function loadMasterDepartments() {

clearList();

    fetch('/MSaleAdmin/GetMasterDepartments')
.then(r => r.json())
.then(data => {

data.forEach(function (item) {

addCheckItem(item);

});

loadExisting();

});
}
function loadNonSaleRevenue() {

clearList();

    fetch('/MSaleAdmin/GetNonSaleRevenue')
.then(r => r.json())
.then(data => {

data.forEach(function (item) {

addCheckItem(item);

});

loadExisting();

});
}
function loadExisting() {

let revenueName =
document.getElementById("revenueCombo").value;

if (!revenueName)
return;

    fetch('/MSaleAdmin/GetRevenueAssignments?revenueName='
+ encodeURIComponent(revenueName))

.then(r => r.json())

.then(saved => {

document
.querySelectorAll('#dlist input')

.forEach(function (box) {

if (saved.includes(box.value)) {

box.checked = true;

}
});
});
}
function selectAllItems() {

document
.querySelectorAll('#dlist input')

.forEach(function (box) {

box.checked = true;

});
}
    function saveAssignments() {

        let revenueName =
            document.getElementById("revenueCombo").value;

        if (!revenueName) {

            alert("Select Revenue Item");
            return;
        }

        let selected = [];

        document
            .querySelectorAll('#dlist input:checked')

            .forEach(function (box) {

                selected.push(box.value);

            });

            fetch('/MSaleAdmin/SaveRevenueAssignments', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({

                revenueName: revenueName,
                linkType: 'Revenue',
                linkToNames: selected

            })
        })
        .then(r => r.json())
        .then(x => {

            alert("Saved");

        });
    }
</script>

<script>
    function addRevenueItem() {

        let name =
            document.getElementById("newRevenueName").value;

        if (!name) {

            alert("Enter Name");
            return;
        }

        fetch('/MSaleAdmin/AddRevenueItem', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                name: name
            })

        })
        .then(r => r.json())

        .then(x => {

            alert("Added");

            document.getElementById("newRevenueName").value = "";

            loadRevenueNames();

        });
    }
</script>
<script>
    function addMasterDepartment() {

        let name =
            document.getElementById("newMasterDepartment").value;

        if (!name) {
            alert("Enter Master Department");
            return;
        }

        fetch('/MSaleAdmin/AddMasterDepartment', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                name: name
            })
        })
        .then(r => r.json())
        .then(x => {

            alert("Master Department Added");

            document.getElementById("newMasterDepartment").value = "";

            loadMasterDepartments();
        });
    }
</script>
