@{
    ViewData["Title"] = "Special Requests";
    ViewData["Subtitle"] = "Add, edit, delete, and set amounts for special requests.";
}

<div class="max-w-3xl space-y-6">

    <input type="hidden" id="originalName" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div class="grid gap-4 sm:grid-cols-3">

            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-slate-700">Request Name</label>
                <input id="requestName"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                       placeholder="Example: Extra Sauce, Birthday Plate" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Amount</label>
                <input id="requestAmount"
                       type="number"
                       step="0.01"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                       value="0.00" />
            </div>

        </div>

        <div class="flex flex-wrap items-center gap-2 pt-4">
            <button type="button"
                    class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                    onclick="saveRequest()">
                Save
            </button>

            <button type="button"
                    class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50"
                    onclick="deleteRequest()">
                Delete
            </button>

            <button type="button"
                    class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50"
                    onclick="clearRequest()">
                Clear
            </button>
        </div>

    </div>

    <div>
        <h5 class="text-base font-semibold text-slate-900">Existing Special Requests</h5>

        <div class="mt-3 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200">

            <div class="grid grid-cols-[1fr_120px] gap-3 border-b border-slate-200 bg-slate-50 px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-slate-500">
                <div>Request Name</div>
                <div class="text-right">Amount</div>
            </div>

            <div id="requestList" class="max-h-80 divide-y divide-slate-100 overflow-y-auto"></div>

        </div>
    </div>

</div>

<script>

    let selectedRequestRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadRequests();
    });

    function loadRequests() {

        fetch('/MSaleAdmin/GetSpecialRequests')
            .then(r => r.json())
            .then(data => {

                let list =
                    document.getElementById('requestList');

                list.innerHTML = '';

                data.forEach(function (x) {

                    let div = document.createElement('div');
                    div.className = 'grid cursor-pointer grid-cols-[1fr_120px] gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50';

                    let nameDiv =
                        document.createElement('div');

                    nameDiv.textContent = x.name;

                    let amountDiv =
                        document.createElement('div');

                    amountDiv.className = 'text-right';

                    amountDiv.textContent =
                        Number(x.amount || 0).toFixed(2);

                    div.appendChild(nameDiv);
                    div.appendChild(amountDiv);

                    div.onclick = function () {

                        if (selectedRequestRow)
                            selectedRequestRow.classList.remove('selected', ...SEL);

                        selectedRequestRow = div;

                        selectedRequestRow.classList.add('selected', ...SEL);

                        document.getElementById('requestName').value =
                            x.name;

                        document.getElementById('originalName').value =
                            x.name;

                        document.getElementById('requestAmount').value =
                            Number(x.amount || 0).toFixed(2);
                    };

                    list.appendChild(div);
                });
            });
    }

    function saveRequest() {

        let item = {

            name:
                document.getElementById('requestName').value,

            originalName:
                document.getElementById('originalName').value,

            amount:
                parseFloat(
                    document.getElementById('requestAmount').value || 0
                )
        };

        if (!item.name.trim()) {

            alert("Enter a request name.");
            return;
        }

        fetch('/MSaleAdmin/SaveSpecialRequest', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify(item)

        })
        .then(r => r.json())
        .then(result => {

            alert(result.message || "Saved");

            loadRequests();

            clearRequest();
        });
    }

    function deleteRequest() {

        let item = {

            name:
                document.getElementById('originalName').value ||
                document.getElementById('requestName').value
        };

        if (!item.name.trim()) {

            alert("Select a request to delete.");
            return;
        }

        if (!confirm("Delete request " + item.name + "?"))
            return;

        fetch('/MSaleAdmin/DeleteSpecialRequest', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify(item)

        })
        .then(r => r.json())
        .then(result => {

            alert(result.message || "Deleted");

            loadRequests();

            clearRequest();
        });
    }

    function clearRequest() {

        document.getElementById('requestName').value = '';

        document.getElementById('originalName').value = '';

        document.getElementById('requestAmount').value = '0.00';

        if (selectedRequestRow) {

            selectedRequestRow.classList.remove('selected', ...SEL);

            selectedRequestRow = null;
        }
    }

</script>
