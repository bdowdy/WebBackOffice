@{
    ViewData["Title"] = "Report Categories";
    ViewData["Subtitle"] = "Manage report departments, remote printers, and timed events.";
}

<div class="grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)]">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h3 class="text-base font-semibold text-slate-900">Departments</h3>

        <select id="departmentList"
                size="25"
                onchange="loadDepartment()"
                class="mt-3 block w-full rounded-lg border-0 bg-white p-1 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
        </select>

        <div class="pt-4">
            <button type="button"
                    onclick="newDepartment()"
                    class="inline-flex w-full items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                New Department
            </button>
        </div>

    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h3 class="text-base font-semibold text-slate-900">Department Setup</h3>

        <div class="mt-4 grid gap-4 sm:grid-cols-2">

            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-slate-700">Report Name</label>
                <input id="reportName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Department No</label>
                <input id="departmentNo" type="number" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Record Number</label>
                <input id="recordNumber" type="number" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div class="flex items-center gap-2 sm:col-span-2">
                <input id="ebtEligible" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                <label for="ebtEligible" class="text-sm font-medium text-slate-700">EBT Eligible</label>
            </div>

            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-slate-700">Master Department</label>
                <select id="masterName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
            </div>

        </div>

        <div class="mt-6 border-t border-slate-200 pt-4">

            <div class="text-sm font-semibold text-slate-900">
                Remote Printers
            </div>

            <div class="mt-3 grid gap-3 sm:grid-cols-2">

                <select id="remote1" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="remote2" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="remote3" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="remote4" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="remote5" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="remote6" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            </div>

        </div>

        <div class="mt-6 border-t border-slate-200 pt-4">

            <div class="text-sm font-semibold text-slate-900">
                Timed Events
            </div>

            <div class="mt-3 grid gap-3 sm:grid-cols-2">

                <select id="timedEvent1" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="timedEvent2" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="timedEvent3" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="timedEvent4" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <select id="timedEvent5" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            </div>

        </div>

        <div class="flex flex-wrap items-center gap-2 pt-6">

            <button type="button"
                    onclick="saveDepartment()"
                    class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
                Save
            </button>

            <button type="button"
                    onclick="location.href='/'"
                    class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">
                Exit
            </button>

        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadSetupLists();
    });

    function loadSetupLists() {
        fetch('/MSaleAdmin/GetReportCategoryLists')
            .then(r => r.json())
            .then(data => {
                console.log(data);

                if (!data.ok) {
                    alert(data.error || "Could not load lists.");
                    return;
                }

                fillList("departmentList", data.departments || [], false);
                fillList("masterName", data.masterDepartments || [], true);

                for (let i = 1; i <= 5; i++) {
                    fillList("timedEvent" + i, data.timedEvents || [], true);
                }

                for (let i = 1; i <= 6; i++) {
                    fillList("remote" + i, data.printers || [], true);
                }
            })
            .catch(err => alert("Load error: " + err.message));
    }

    function fillList(id, items, includeNone) {
        let el = document.getElementById(id);
        el.innerHTML = "";

        if (includeNone) {
            el.add(new Option("None", "None"));
        }

        items.forEach(x => {
            el.add(new Option(x, x));
        });
    }

    function loadDepartment() {
        let name = document.getElementById("departmentList").value;
        if (!name) return;

        fetch('/MSaleAdmin/GetReportCategory?reportName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(d => {
                if (d.error) {
                    alert(d.error);
                    return;
                }

                document.getElementById("reportName").value = d.reportName || "";
                document.getElementById("departmentNo").value = d.departmentNo || 0;
                document.getElementById("recordNumber").value = d.recordNumber || 0;
                document.getElementById("ebtEligible").checked = Number(d.flag || 0) === 1;

                setSelect("masterName", d.masterName || "None");

                setSelect("remote1", d.remote1 || "None");
                setSelect("remote2", d.remote2 || "None");
                setSelect("remote3", d.remote3 || "None");
                setSelect("remote4", d.remote4 || "None");
                setSelect("remote5", d.remote5 || "None");
                setSelect("remote6", d.remote6 || "None");

                setSelect("timedEvent1", d.timedEvent1 || "None");
                setSelect("timedEvent2", d.timedEvent2 || "None");
                setSelect("timedEvent3", d.timedEvent3 || "None");
                setSelect("timedEvent4", d.timedEvent4 || "None");
                setSelect("timedEvent5", d.timedEvent5 || "None");
            });
    }

    function setSelect(id, value) {
        let el = document.getElementById(id);

        if (![...el.options].some(o => o.value === value)) {
            el.add(new Option(value, value));
        }

        el.value = value;
    }

    function newDepartment() {
        document.getElementById("reportName").value = "";
        document.getElementById("departmentNo").value = "0";
        document.getElementById("recordNumber").value = "0";
        document.getElementById("ebtEligible").checked = false;

        setSelect("masterName", "None");

        for (let i = 1; i <= 6; i++) {
            setSelect("remote" + i, "None");
        }

        for (let i = 1; i <= 5; i++) {
            setSelect("timedEvent" + i, "None");
        }
    }

    function saveDepartment() {
        let data = {
            reportName: document.getElementById("reportName").value,
            departmentNo: parseInt(document.getElementById("departmentNo").value || 0),
            recordNumber: parseInt(document.getElementById("recordNumber").value || 0),
            flag: document.getElementById("ebtEligible").checked ? 1 : 0,

            remote1: document.getElementById("remote1").value,
            remote2: document.getElementById("remote2").value,
            remote3: document.getElementById("remote3").value,
            remote4: document.getElementById("remote4").value,
            remote5: document.getElementById("remote5").value,
            remote6: document.getElementById("remote6").value,

            masterName: document.getElementById("masterName").value,

            timedEvent1: document.getElementById("timedEvent1").value,
            timedEvent2: document.getElementById("timedEvent2").value,
            timedEvent3: document.getElementById("timedEvent3").value,
            timedEvent4: document.getElementById("timedEvent4").value,
            timedEvent5: document.getElementById("timedEvent5").value
        };

        fetch('/MSaleAdmin/SaveReportCategory', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadSetupLists();
        });
    }
</script>
