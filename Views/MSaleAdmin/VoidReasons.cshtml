@{
    ViewData["Title"] = "Void Reasons";
}

<style>
    body {
        background: #f4f6f9;
    }

    .msale-page {
        max-width: 1050px;
        margin: 30px auto;
        padding: 0 15px;
    }

    .msale-card {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.10);
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }

    .msale-header {
        background: linear-gradient(135deg, #12395c, #2563eb);
        color: white;
        padding: 24px 30px;
    }

        .msale-header h2 {
            margin: 0;
            font-weight: 700;
        }

        .msale-header p {
            margin: 5px 0 0;
            opacity: .9;
        }

    .msale-content {
        padding: 28px;
    }

    .edit-panel {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .button-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .list-header,
    .void-row {
        display: grid;
        grid-template-columns: 1fr 180px;
        align-items: center;
    }

    .list-header {
        background: #eaf1fb;
        color: #1f2937;
        font-weight: 700;
        padding: 12px 16px;
        border-radius: 12px 12px 0 0;
        border: 1px solid #dbe3ef;
    }

    .void-list {
        max-height: 420px;
        overflow-y: auto;
        border: 1px solid #dbe3ef;
        border-top: none;
        border-radius: 0 0 12px 12px;
        background: white;
    }

    .void-row {
        padding: 13px 16px;
        border-bottom: 1px solid #edf2f7;
        cursor: pointer;
        transition: .15s ease;
    }

        .void-row:hover {
            background: #f1f7ff;
        }

        .void-row.selected {
            background: #dbeafe;
            font-weight: 700;
            border-left: 5px solid #2563eb;
        }

    .inventory-value {
        text-align: center;
    }

    .pill {
        display: inline-block;
        min-width: 58px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .pill-yes {
        background: #dcfce7;
        color: #166534;
    }

    .pill-no {
        background: #fee2e2;
        color: #991b1b;
    }

    .empty-message {
        padding: 20px;
        color: #6b7280;
        text-align: center;
    }
</style>

<div class="msale-page">
    <div class="msale-card">

        <div class="msale-header">
            <h2>Void Reasons</h2>
            <p>Add, edit, delete, and control whether a void removes inventory.</p>
        </div>

        <div class="msale-content">

            <input type="hidden" id="originalVoidName" />

            <div class="edit-panel">
                <div class="row">
                    <div class="col-md-8 mb-3">
                        <label class="form-label fw-bold">Void Reason</label>
                        <input id="voidName"
                               class="form-control form-control-lg"
                               placeholder="Example: Customer changed mind" />
                    </div>

                    <div class="col-md-4 mb-3 d-flex align-items-end">
                        <div class="form-check form-switch fs-5">
                            <input id="inventory"
                                   type="checkbox"
                                   class="form-check-input" />
                            <label class="form-check-label" for="inventory">
                                Remove Inventory
                            </label>
                        </div>
                    </div>
                </div>

                <div class="button-row">
                    <button type="button" class="btn btn-primary px-4" onclick="saveVoidReason()">
                        Save
                    </button>

                    <button type="button" class="btn btn-outline-danger px-4" onclick="deleteVoidReason()">
                        Delete
                    </button>

                    <button type="button" class="btn btn-outline-secondary px-4" onclick="clearVoidReason()">
                        Clear
                    </button>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">Existing Void Reasons</h5>
                <span id="recordCount" class="text-muted"></span>
            </div>

            <div class="list-header">
                <div>Void Reason</div>
                <div class="inventory-value">Remove Inventory</div>
            </div>

            <div id="voidList" class="void-list"></div>

        </div>
    </div>
</div>

<script>
    let selectedVoidRow = null;

    document.addEventListener("DOMContentLoaded", function () {
        loadVoidReasons();
    });

    function loadVoidReasons() {
        fetch('/MSaleAdmin/GetVoidReasons')
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById('voidList');
                const count = document.getElementById('recordCount');

                list.innerHTML = '';
                count.textContent = `${data.length} record${data.length === 1 ? '' : 's'}`;

                if (!data || data.length === 0) {
                    list.innerHTML = `<div class="empty-message">No void reasons found.</div>`;
                    return;
                }

                data.forEach(function (x) {
                    const div = document.createElement('div');
                    div.className = 'void-row';

                    const nameDiv = document.createElement('div');
                    nameDiv.textContent = x.voidName;

                    const invDiv = document.createElement('div');
                    invDiv.className = 'inventory-value';
                    invDiv.innerHTML = x.inventory
                        ? '<span class="pill pill-yes">Yes</span>'
                        : '<span class="pill pill-no">No</span>';

                    div.appendChild(nameDiv);
                    div.appendChild(invDiv);

                    div.onclick = function () {
                        if (selectedVoidRow)
                            selectedVoidRow.classList.remove('selected');

                        selectedVoidRow = div;
                        selectedVoidRow.classList.add('selected');

                        document.getElementById('voidName').value = x.voidName;
                        document.getElementById('originalVoidName').value = x.voidName;
                        document.getElementById('inventory').checked = x.inventory === true;
                    };

                    list.appendChild(div);
                });
            });
    }

    function saveVoidReason() {
        const item = {
            voidName: document.getElementById('voidName').value,
            originalVoidName: document.getElementById('originalVoidName').value,
            inventory: document.getElementById('inventory').checked
        };

        if (!item.voidName.trim()) {
            alert("Enter a void reason.");
            return;
        }

        fetch('/MSaleAdmin/SaveVoidReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadVoidReasons();
            clearVoidReason();
        });
    }

    function deleteVoidReason() {
        const item = {
            voidName:
                document.getElementById('originalVoidName').value ||
                document.getElementById('voidName').value
        };

        if (!item.voidName.trim()) {
            alert("Select a void reason to delete.");
            return;
        }

        if (!confirm("Delete void reason " + item.voidName + "?"))
            return;

        fetch('/MSaleAdmin/DeleteVoidReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadVoidReasons();
            clearVoidReason();
        });
    }

    function clearVoidReason() {
        document.getElementById('voidName').value = '';
        document.getElementById('originalVoidName').value = '';
        document.getElementById('inventory').checked = false;

        if (selectedVoidRow) {
            selectedVoidRow.classList.remove('selected');
            selectedVoidRow = null;
        }
    }
</script>