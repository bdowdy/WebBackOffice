@{
    ViewData["Title"] = "Void Reasons";
    ViewData["Subtitle"] = "Add, edit, delete, and control whether a void removes inventory.";
}

<div class="max-w-3xl space-y-6">

    <input type="hidden" id="originalVoidName" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div class="grid gap-4 sm:grid-cols-3">

            <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-slate-700">Void Reason</label>
                <input id="voidName"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                       placeholder="Example: Customer changed mind" />
            </div>

            <div class="flex items-end">
                <div class="flex items-center gap-2 pb-2">
                    <input id="inventory"
                           type="checkbox"
                           class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                    <label class="text-sm font-medium text-slate-700" for="inventory">
                        Remove Inventory
                    </label>
                </div>
            </div>

        </div>

        <div class="flex flex-wrap items-center gap-2 pt-4">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveVoidReason()">
                Save
            </button>

            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteVoidReason()">
                Delete
            </button>

            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearVoidReason()">
                Clear
            </button>
        </div>

    </div>

    <div>
        <div class="flex items-center justify-between">
            <h5 class="text-base font-semibold text-slate-900">Existing Void Reasons</h5>
            <span id="recordCount" class="text-sm text-slate-500"></span>
        </div>

        <div class="mt-3 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200">

            <div class="grid grid-cols-[1fr_180px] items-center border-b border-slate-200 bg-slate-50 px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-slate-500">
                <div>Void Reason</div>
                <div class="text-center">Remove Inventory</div>
            </div>

            <div id="voidList" class="max-h-[420px] divide-y divide-slate-100 overflow-y-auto"></div>

        </div>
    </div>

</div>

<script>
    let selectedVoidRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadVoidReasons();
    });

    function loadVoidReasons() {
        fetch('/MSaleAdmin/GetVoidReasons')
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById('voidList');
                const count = document.getElementById('recordCount');

                list.innerHTML = '';
                count.textContent = `${data.length} record${data.length === 1 ? '' : 's'}`;

                if (!data || data.length === 0) {
                    list.innerHTML = `<div class="px-4 py-6 text-center text-sm text-slate-500">No void reasons found.</div>`;
                    return;
                }

                data.forEach(function (x) {
                    const div = document.createElement('div');
                    div.className = 'grid cursor-pointer grid-cols-[1fr_180px] items-center px-4 py-3 text-sm text-slate-700 hover:bg-slate-50';

                    const nameDiv = document.createElement('div');
                    nameDiv.textContent = x.voidName;

                    const invDiv = document.createElement('div');
                    invDiv.className = 'text-center';
                    invDiv.innerHTML = x.inventory
                        ? '<span class="inline-block min-w-[58px] rounded-full bg-emerald-100 px-2.5 py-1 text-center text-xs font-semibold text-emerald-700">Yes</span>'
                        : '<span class="inline-block min-w-[58px] rounded-full bg-rose-100 px-2.5 py-1 text-center text-xs font-semibold text-rose-700">No</span>';

                    div.appendChild(nameDiv);
                    div.appendChild(invDiv);

                    div.onclick = function () {
                        if (selectedVoidRow)
                            selectedVoidRow.classList.remove('selected', ...SEL);

                        selectedVoidRow = div;
                        selectedVoidRow.classList.add('selected', ...SEL);

                        document.getElementById('voidName').value = x.voidName;
                        document.getElementById('originalVoidName').value = x.voidName;
                        document.getElementById('inventory').checked = x.inventory === true;
                    };

                    list.appendChild(div);
                });
            });
    }

    function saveVoidReason() {
        const item = {
            voidName: document.getElementById('voidName').value,
            originalVoidName: document.getElementById('originalVoidName').value,
            inventory: document.getElementById('inventory').checked
        };

        if (!item.voidName.trim()) {
            alert("Enter a void reason.");
            return;
        }

        fetch('/MSaleAdmin/SaveVoidReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadVoidReasons();
            clearVoidReason();
        });
    }

    function deleteVoidReason() {
        const item = {
            voidName:
                document.getElementById('originalVoidName').value ||
                document.getElementById('voidName').value
        };

        if (!item.voidName.trim()) {
            alert("Select a void reason to delete.");
            return;
        }

        if (!confirm("Delete void reason " + item.voidName + "?"))
            return;

        fetch('/MSaleAdmin/DeleteVoidReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadVoidReasons();
            clearVoidReason();
        });
    }

    function clearVoidReason() {
        document.getElementById('voidName').value = '';
        document.getElementById('originalVoidName').value = '';
        document.getElementById('inventory').checked = false;

        if (selectedVoidRow) {
            selectedVoidRow.classList.remove('selected', ...SEL);
            selectedVoidRow = null;
        }
    }
</script>
