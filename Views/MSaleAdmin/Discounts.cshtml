@{
    ViewData["Title"] = "Discounts";
    ViewData["Subtitle"] = "Add, edit, delete, assignments, active days, and combo matches.";
}

@section HeaderActions {
    <div class="flex flex-wrap items-center gap-2">
        <button type="button" onclick="clearForm()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Clear</button>
        <button type="button" onclick="deleteDiscount()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50">Delete</button>
        <button type="button" onclick="saveDiscount()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save</button>
    </div>
}

<div class="space-y-6">
    <div id="msg" class="hidden rounded-lg px-4 py-3 text-sm font-semibold"></div>

    <div class="grid gap-6 lg:grid-cols-3">
        <section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Discount</h2>
            <label class="mt-4 block text-sm font-medium text-slate-700">Discount Name</label>
            <select id="discountCombo" onchange="discountChanged()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                <option value="">-- Select Discount --</option>
            </select>
            <label class="mt-4 block text-sm font-medium text-slate-700">New / Edit Name</label>
            <input id="discountName" maxlength="20" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Discount Type</label>
            <select id="discountType" onchange="typeChanged()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                <option value=""></option>
                <option>Amount</option>
                <option>Percentage</option>
                <option>Discount Amount</option>
                <option>Discount Percentage</option>
                <option>Open Amount</option>
                <option>Open Percentage</option>
                <option>Minimum Amount</option>
                <option>Minimum Percentage</option>
                <option>Combo Amount</option>
                <option>Combo Percentage</option>
                <option>Combo Set Amount</option>
                <option>Set Price</option>
                <option>Charge Amount</option>
                <option>Charge Percentage</option>
            </select>
            <label class="mt-4 block text-sm font-medium text-slate-700">Amount</label>
            <input id="discountAmount" type="number" step="0.01" value="0.00" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Access Level</label>
            <select id="accessLevel" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
            <label class="mt-4 block text-sm font-medium text-slate-700">Discount ID</label>
            <input id="discountId" type="number" value="0" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Category</label>
            <select id="discountClass" onchange="typeChanged()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                <option>Discount</option>
                <option>Gratuity</option>
                <option>Service Charge</option>
                <option>Processing Fee</option>
            </select>
        </section>
        <section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Rules</h2>
            <div class="mt-4 space-y-2.5">
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="allowOnlyOne" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Allow only 1 discount per seat</label>
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="afterPrint" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Exclude modifier prices</label>
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="autoMatch" type="checkbox" onchange="typeChanged()" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Auto match / auto deduct percentage</label>
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="autoDeduct" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Auto fire discount</label>
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="tracking" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Coupon number tracking</label>
                <label class="flex items-center gap-2 text-sm text-slate-700"><input id="eventOnly" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Event only</label>
            </div>
            <label id="maxLabel" class="mt-4 block text-sm font-medium text-slate-700">Maximum Amount Allowed Per Transaction</label>
            <input id="maxDiscountAmount" type="number" step="0.01" value="0.00" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Match With Number</label>
            <input id="matchValue" type="number" step="0.01" value="0" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Discount Department</label>
            <select id="discDepartment" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
        </section>
        <section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Tax / Time / Days</h2>
            <label class="mt-4 block text-sm font-medium text-slate-700">Sales Tax</label>
            <input id="tax1" type="number" value="1" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Special Tax</label>
            <input id="tax2" type="number" value="0" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Tax 3</label>
            <input id="taxable" type="number" value="0" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Start Time</label>
            <input id="startTime" value="12:00 AM" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">End Time</label>
            <input id="endTime" value="12:00 AM" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <label class="mt-4 block text-sm font-medium text-slate-700">Expires</label>
            <input id="expires" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <h3 class="mt-5 text-sm font-semibold text-slate-700">Days Not Available</h3>
            <div id="days" class="mt-2 grid grid-cols-2 gap-2"></div>
        </section>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Assignments</h2>
            <div class="mt-4 flex flex-wrap items-center gap-2">
                <button type="button" onclick="loadAssign('menu')" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Menu Items</button>
                <button type="button" onclick="loadAssign('category')" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Categories</button>
                <button type="button" onclick="loadAssign('department')" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Departments</button>
                <button type="button" onclick="assignAll()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Assign All</button>
                <button type="button" onclick="clearAssign()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Clear</button>
            </div>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <div>
                    <h3 class="text-sm font-semibold text-slate-700">Available</h3>
                    <input id="filterAvailable" placeholder="Search..." oninput="renderAvailable()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                    <div id="availableList" class="mt-2 min-h-[240px] max-h-80 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-slate-700">Assigned</h3>
                    <div id="assignedList" class="mt-2 min-h-[240px] max-h-80 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
                </div>
            </div>
        </section>
        <section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-base font-semibold text-slate-900">Combo Match</h2>
            <div class="mt-4 flex flex-wrap items-center gap-2">
                <button type="button" onclick="loadComboItems()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Load Combo Items</button>
                <button type="button" onclick="clearCombos()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Clear Combos</button>
            </div>
            <input id="comboFilter" placeholder="Search combo items..." oninput="renderComboSource()" class="mt-4 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            <div id="comboSource" class="mt-2 min-h-[140px] max-h-80 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
                @for (int i = 0; i <= 6; i++)
                {
                    var title = i == 0 ? "Combo Item" : $"Match #{i}";
                    <div>
                        <h3 class="text-sm font-semibold text-slate-700">@title</h3>
                        <div id="combo@i" class="mt-1 min-h-[90px] max-h-40 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200" ondrop="dropCombo(event,@i)" ondragover="event.preventDefault()"></div>
                    </div>
                }
            </div>
        </section>
    </div>
</div>
<script>
    let availableItems = [];
    let assignedItems  = [];
    let comboItems     = [];
    let comboLists     = [[], [], [], [], [], [], []];

    const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

    document.addEventListener('DOMContentLoaded', async function () {
        buildDays();
        await loadSetupLists();
        clearForm(false);
    });

    // ── Utilities ─────────────────────────────────────────────────────────────

    async function api(url, opt) {
        const r    = await fetch(url, opt);
        const text = await r.text();
        if (!r.ok) throw new Error(text || r.statusText);
        if (!text) return null;
        try   { return JSON.parse(text); }
        catch { return text; }
    }

    function showMsg(text, bad) {
        const m = document.getElementById('msg');
        m.textContent    = text;
        m.style.display  = 'block';
        m.style.background = bad ? '#ffe2e2' : '#e5f5e9';
        m.style.color      = bad ? '#8b1d1d' : '#205c33';
    }

    function el(id)  { return document.getElementById(id); }
    function val(id) { const x = el(id); return x ? (x.value || '') : ''; }

    function num(id, fallback) {
        const n = Number(val(id));
        return Number.isFinite(n) ? n : fallback;
    }

    function checked(id) {
        const x = el(id);
        return x && x.checked ? 1 : 0;
    }

    function setVal(id, value, fallback = '') {
        const x = el(id);
        if (x) x.value = (value !== null && value !== undefined) ? value : fallback;
    }

    function setChecked(id, value) {
        const x = el(id);
        if (x) x.checked = Number(value || 0) !== 0;
    }

    function asArray(value) {
        if (Array.isArray(value)) return value.filter(x => x !== null && x !== undefined && String(x).trim() !== '');
        if (value === null || value === undefined || value === '') return [];
        return [value];
    }

    function esc(s) {
        return String(s ?? '')
            .replaceAll('&', '&amp;').replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;').replaceAll('"', '&quot;');
    }

    function escJs(s) {
        return String(s ?? '').replaceAll('\\', '\\\\').replaceAll("'", "\\'");
    }

    // Case-insensitive property reader — handles PascalCase C# serialization
    // and camelCase equally.  prop(obj, 'discountName') finds 'DiscountName' too.
    function prop(obj, key) {
        if (!obj || typeof obj !== 'object') return undefined;
        if (key in obj) return obj[key];
        const lower = key.toLowerCase();
        const match = Object.keys(obj).find(k => k.toLowerCase() === lower);
        return match ? obj[match] : undefined;
    }

    // Coerce an item that might be an object or a plain string into a display string.
    // Tries the most common property names your API might use (case-insensitive).
    function extractName(x) {
        if (x === null || x === undefined) return '';
        if (typeof x !== 'object') return String(x);
        return prop(x, 'discountName')   ??
               prop(x, 'accessName')     ??
               prop(x, 'accessLevel')    ??
               prop(x, 'departmentName') ??
               prop(x, 'reportName')     ??
               prop(x, 'name')           ??
               prop(x, 'value')          ??
               prop(x, 'text')           ??
               String(x);
    }

    // ── Days ──────────────────────────────────────────────────────────────────

    function buildDays() {
        el('days').innerHTML = days.map((d, i) =>
            `<label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="day${i}" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> ${d}</label>`
        ).join('');
    }

    // ── Setup lists (discounts, access levels, departments) ───────────────────

    async function loadSetupLists() {
        try {
            const d = await api('/MSaleAdmin/GetDiscountSetupLists') || {};

            // Normalise every array: items may be plain strings OR objects,
            // and the envelope keys may be PascalCase or camelCase.
            const discounts    = asArray(prop(d, 'discounts')   ).map(extractName).filter(Boolean);
            const accessLevels = asArray(prop(d, 'accessLevels')).map(extractName).filter(Boolean);
            const departments  = asArray(prop(d, 'departments') ).map(extractName).filter(Boolean);

            fillSelect('discountCombo', discounts,               true,  '-- Select Discount --');
            fillSelect('accessLevel',  accessLevels,             true,  '');
            fillSelect('discDepartment', ['None', ...departments], false, '');
        } catch (e) {
            showMsg('Could not load setup lists: ' + e.message, true);
        }
    }

    function fillSelect(id, arr, addBlank, blankText) {
        const node = el(id);
        if (!node) return;
        let html = addBlank ? `<option value="">${esc(blankText || '')}</option>` : '';
        html += asArray(arr).map(x => `<option value="${esc(x)}">${esc(x)}</option>`).join('');
        node.innerHTML = html;
    }

    // ── Load a specific discount ───────────────────────────────────────────────

    async function discountChanged() {
        const name = val('discountCombo');
        setVal('discountName', name);
        if (name) await loadDiscount(name);
    }

    async function loadDiscount(nameFromCombo) {
        try {
            const name = nameFromCombo || val('discountName') || val('discountCombo');
            if (!name) { showMsg('Choose a discount first.', true); return; }

            const raw = await api('/MSaleAdmin/GetDiscount?discountName=' + encodeURIComponent(name)) || {};

            // Detect response shape — works regardless of PascalCase vs camelCase.
            // Shape A: { discount: {...}, activeDays: [...], ... }
            // Shape B: { discountName/DiscountName: "...", activeDays: [...], ... }
            const discObj = prop(raw, 'discount');
            const x = (discObj && typeof discObj === 'object')
                        ? discObj   // Shape A — unwrap the nested discount
                        : raw;      // Shape B — the root IS the discount

            // Verify we actually have a discount (check for a name property, any casing)
            const loadedName = prop(x, 'discountName');
            if (!loadedName) {
                showMsg('Discount not found. You can save it as new.', true);
                return;
            }

            setVal('discountName',      loadedName,                            name);
            setVal('discountCombo',     loadedName,                            name);
            setVal('discountType',      prop(x, 'discountType'),               '');
            setVal('discountAmount',    prop(x, 'discountAmount'),             0);
            setVal('accessLevel',       prop(x, 'accessLevel'),                '');
            setVal('discountId',        prop(x, 'discountId'),                 0);
            setVal('discountClass',     prop(x, 'type'),                       'Discount');
            setVal('maxDiscountAmount', prop(x, 'maxDiscountAmount'),          0);
            setVal('matchValue',        prop(x, 'matchValue'),                 0);
            setVal('discDepartment',    prop(x, 'discDepartment'),             'None');
            setVal('tax1',              prop(x, 'tax1'),                       1);
            setVal('tax2',              prop(x, 'tax2'),                       0);
            setVal('taxable',           prop(x, 'taxable'),                    0);
            setVal('startTime',         prop(x, 'startTime'),                  '12:00 AM');
            setVal('endTime',           prop(x, 'endTime'),                    '12:00 AM');
            setVal('expires',           String(prop(x, 'expires') || '').substring(0, 10));

            setChecked('allowOnlyOne', prop(x, 'allowOnlyOne'));
            setChecked('afterPrint',   prop(x, 'afterPrint'));
            setChecked('autoMatch',    prop(x, 'autoMatch'));
            setChecked('autoDeduct',   prop(x, 'autoDeduct'));
            setChecked('tracking',     prop(x, 'tracking'));
            setChecked('eventOnly',    String(prop(x, 'searchNumber') || '') === '1' ? 1 : 0);

            // Active days — all field name variants handled via prop()
            days.forEach((_, i) => setChecked('day' + i, 0));
            asArray(prop(raw, 'activeDays')).forEach(a => {
                if (!a) return;
                const pos    = prop(a, 'pos') ?? prop(a, 'position');
                const dayVal = prop(a, 'dayValue') ?? prop(a, 'day') ?? prop(a, 'value') ?? 0;
                if (pos !== null && pos !== undefined) setChecked('day' + pos, dayVal);
            });

            assignedItems = asArray(prop(raw, 'assignments'));
            renderAssigned();

            comboLists = [[], [], [], [], [], [], []];
            comboLists[0] = asArray(prop(raw, 'comboItem'));
            asArray(prop(raw, 'comboMatches')).forEach(m => {
                if (!m) return;
                const no        = Number(prop(m, 'matchNo'));
                const matchName = prop(m, 'matchName') || '';
                if (no >= 1 && no <= 6 && matchName) comboLists[no].push(matchName);
            });
            renderCombos();

            typeChanged();
            showMsg('Discount loaded.', false);
        } catch (e) {
            showMsg('Error loading discount: ' + e.message, true);
        }
    }

    // ── Type / category label ─────────────────────────────────────────────────

    function typeChanged() {
        const t = val('discountType');
        const c = val('discountClass');
        let label = 'Maximum Amount Allowed Per Transaction';
        if (t === 'Minimum Amount' || t === 'Minimum Percentage') label = 'Minimum Check Amount for Discount';
        if (c === 'Service Charge') label = 'Minimum Check Amount for Delivery';
        const maxLabel = el('maxLabel');
        if (maxLabel) maxLabel.textContent = label;

        if (checked('autoMatch') && !['Discount Percentage', 'Open Percentage'].includes(t)) {
            showMsg('Auto Match works with Discount Percentage or Open Percentage only.', true);
            setChecked('autoMatch', 0);
        }
    }

    // ── Assignments ───────────────────────────────────────────────────────────

    async function loadAssign(mode) {
        try {
            availableItems = asArray(await api('/MSaleAdmin/GetDiscountAssignableItems?mode=' + encodeURIComponent(mode)));
            renderAvailable();
            renderAssigned();
        } catch (e) {
            showMsg(e.message, true);
        }
    }

    function renderAvailable() {
        const node = el('availableList');
        if (!node) return;
        const f = val('filterAvailable').toLowerCase();
        node.innerHTML = availableItems
            .filter(x => String(x).toLowerCase().includes(f))
            .map(x => `<div class="cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50" onclick="addAssigned('${escJs(x)}')">${esc(x)}</div>`)
            .join('');
    }

    function addAssigned(x) {
        if (!assignedItems.includes(x)) { assignedItems.push(x); assignedItems.sort(); }
        renderAssigned();
    }

    function renderAssigned() {
        const node = el('assignedList');
        if (!node) return;
        node.innerHTML = assignedItems
            .map(x => `<div class="cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50" onclick="removeAssigned('${escJs(x)}')">${esc(x)}</div>`)
            .join('');
    }

    function removeAssigned(x) {
        assignedItems = assignedItems.filter(a => a !== x);
        renderAssigned();
    }

    function assignAll() {
        availableItems.forEach(x => { if (!assignedItems.includes(x)) assignedItems.push(x); });
        assignedItems.sort();
        renderAssigned();
    }

    function clearAssign() {
        availableItems = [];
        assignedItems  = [];
        renderAvailable();
        renderAssigned();
    }

    // ── Combo match ───────────────────────────────────────────────────────────

    async function loadComboItems() {
        try {
            comboItems = asArray(await api('/MSaleAdmin/GetDiscountAssignableItems?mode=combo'));
            renderComboSource();
        } catch (e) {
            showMsg(e.message, true);
        }
    }

    function renderComboSource() {
        const node = el('comboSource');
        if (!node) return;
        const f = val('comboFilter').toLowerCase();
        node.innerHTML = comboItems
            .filter(x => String(x).toLowerCase().includes(f))
            .map(x => `<div class="cursor-grab px-4 py-2.5 text-sm hover:bg-slate-50" draggable="true" ondragstart="dragCombo(event,'${escJs(x)}')">${esc(x)}</div>`)
            .join('');
    }

    function dragCombo(e, x)  { e.dataTransfer.setData('text/plain', x); }
    function dropCombo(e, n)  { e.preventDefault(); addCombo(n, e.dataTransfer.getData('text/plain')); }

    function addCombo(n, x) {
        if (x && !comboLists[n].includes(x)) comboLists[n].push(x);
        renderCombos();
    }

    function removeCombo(n, x) {
        comboLists[n] = comboLists[n].filter(a => a !== x);
        renderCombos();
    }

    function renderCombos() {
        for (let i = 0; i < 7; i++) {
            const node = el('combo' + i);
            if (!node) continue;
            node.innerHTML = comboLists[i]
                .map(x => `<div class="cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50" onclick="removeCombo(${i},'${escJs(x)}')">${esc(x)}</div>`)
                .join('');
        }
    }

    function clearCombos() {
        comboLists = [[], [], [], [], [], [], []];
        renderCombos();
    }

    // ── Clear form ────────────────────────────────────────────────────────────

    function clearForm(message = true) {
        setVal('discountCombo', '');
        setVal('discountName', '');
        setVal('discountType', '');
        setVal('discountAmount', '0.00');
        setVal('accessLevel', '');
        setVal('discountId', '0');
        setVal('discountClass', 'Discount');
        setVal('maxDiscountAmount', '0.00');
        setVal('matchValue', '0');
        setVal('discDepartment', 'None');
        setVal('tax1', '1');
        setVal('tax2', '0');
        setVal('taxable', '0');
        setVal('startTime', '12:00 AM');
        setVal('endTime', '12:00 AM');
        setVal('expires', '');
        ['allowOnlyOne', 'afterPrint', 'autoMatch', 'autoDeduct', 'tracking', 'eventOnly']
            .forEach(id => setChecked(id, 0));
        days.forEach((_, i) => setChecked('day' + i, 0));
        clearAssign();
        clearCombos();
        typeChanged();
        if (message) showMsg('Ready for new discount.', false);
    }

    // ── Build save payload ────────────────────────────────────────────────────

    function payload() {
        const activeDays = [];
        days.forEach((_, i) => { if (checked('day' + i)) activeDays.push(i); });

        const comboMatches = [];
        for (let i = 1; i <= 6; i++) {
            comboLists[i].forEach(x => comboMatches.push({ matchNo: i, matchName: x }));
        }

        return {
            discountName:      val('discountName'),
            discountType:      val('discountType'),
            discountAmount:    num('discountAmount', 0),
            accessLevel:       val('accessLevel'),
            menuItemLink:      0,
            categoryLink:      0,
            departmentLink:    0,
            maxDiscountAmount: num('maxDiscountAmount', 0),
            matchValue:        num('matchValue', 0),
            taxable:           num('taxable', 0),
            tax1:              num('tax1', 1),
            tax2:              num('tax2', 0),
            allowOnlyOne:      checked('allowOnlyOne'),
            afterPrint:        checked('afterPrint'),
            autoMatch:         checked('autoMatch'),
            discDepartment:    val('discDepartment') || 'None',
            type:              val('discountClass')  || 'Discount',
            searchNumber:      checked('eventOnly') ? '1' : 'None',
            startTime:         val('startTime') || '12:00 AM',
            endTime:           val('endTime')   || '12:00 AM',
            autoDeduct:        checked('autoDeduct'),
            expires:           val('expires'),
            discountId:        num('discountId', 0),
            tracking:          checked('tracking'),
            activeDays,
            assignments:       assignedItems,
            comboItem:         comboLists[0],
            comboMatches
        };
    }

    // ── Save ──────────────────────────────────────────────────────────────────

    async function saveDiscount() {
        try {
            const p = payload();
            if (!p.discountName) { showMsg('Discount name is required.', true); return; }
            await api('/MSaleAdmin/SaveDiscount', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(p)
            });
            await loadSetupLists();
            setVal('discountCombo', p.discountName);
            showMsg('Discount saved.', false);
        } catch (e) {
            showMsg(e.message, true);
        }
    }

    // ── Delete ────────────────────────────────────────────────────────────────

    async function deleteDiscount() {
        try {
            const discountName = val('discountName') || val('discountCombo');
            if (!discountName) { showMsg('Choose a discount to delete.', true); return; }
            if (!confirm('Delete ' + discountName + ' and all related discount rows?')) return;
            await api('/MSaleAdmin/DeleteDiscount', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ discountName })
            });
            await loadSetupLists();
            clearForm(false);
            showMsg('Discount deleted.', false);
        } catch (e) {
            showMsg(e.message, true);
        }
    }
</script>
