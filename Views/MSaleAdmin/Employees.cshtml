@{
    ViewData["Title"] = "Employee Setup";
    ViewData["Subtitle"] = "Yellow fields are required.";
}

<div class="space-y-6">

    <input type="hidden" id="originalFirstName" />
    <input type="hidden" id="originalLastName" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">General Data</h2>

        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

            <div>
                <label class="block text-sm font-medium text-slate-700">First Name</label>
                <input id="firstName" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Middle Name</label>
                <input id="middleName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Last Name</label>
                <input id="lastName" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Nick Name</label>
                <input id="nickName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Employee ID</label>
                <input id="employeeId" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Company ID</label>
                <input id="companyId" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Contact Information</h2>

        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

            <div>
                <label class="block text-sm font-medium text-slate-700">Address</label>
                <input id="address" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">City</label>
                <input id="city" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">State</label>
                <input id="state" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Zip</label>
                <input id="zip" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Cell Phone</label>
                <input id="homePhone" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Email</label>
                <input id="phone2" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Security / Access</h2>

        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

            <div>
                <label class="block text-sm font-medium text-slate-700">Base Access Level</label>
                <input id="accessLevel" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Primary Access Number</label>
                <input id="accessNumber" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Secondary Access Number</label>
                <input id="secondaryAccess" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Language Preference</label>
                <input id="language" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Dates / Status</h2>

        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

            <div>
                <label class="block text-sm font-medium text-slate-700">Hire Date</label>
                <input id="hireDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Date of Birth</label>
                <input id="dob" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div class="flex items-center gap-2 pt-7">
                <input id="terminated" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                <span class="text-sm font-medium text-slate-700">Terminated</span>
            </div>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-4">
            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveEmployee()">Save</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearForm()">Clear</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteEmployee()">Remove</button>
        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Current Employees</h2>

        <div class="mt-4 flex flex-wrap items-center gap-2">
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadEmployees(0)">Filter Active Employees</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadEmployees(1)">Filter Terminated Employees</button>
        </div>

        <div class="mt-4 max-h-[430px] overflow-x-auto overflow-y-auto rounded-lg ring-1 ring-slate-200">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="sticky top-0 bg-slate-50">
                    <tr>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Last Name</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">First Name</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Nick Name</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Access Level</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Primary Access</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Employee ID</th>
                    </tr>
                </thead>
                <tbody id="employeeList" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadEmployees(0);
    });

    function loadEmployees(status) {
        fetch('/MSaleAdmin/GetEmployees?terminated=' + status)
            .then(r => r.json())
            .then(data => {
                let tbody = document.getElementById("employeeList");
                tbody.innerHTML = "";

                data.forEach(e => {
                    let tr = document.createElement("tr");
                    tr.className = "cursor-pointer hover:bg-slate-50";

                    tr.onclick = function () {
                        editEmployee(e);
                    };

                    tr.innerHTML = `
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.lastName)}</td>
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.firstName)}</td>
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.nickName)}</td>
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.accessLevel)}</td>
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.accessNumber)}</td>
                        <td class="px-4 py-2.5 text-slate-700">${safe(e.employeeId)}</td>
                    `;

                    tbody.appendChild(tr);
                });
            });
    }

    function safe(v) {
        return v ?? "";
    }

    function editEmployee(e) {
        document.getElementById("originalFirstName").value = e.firstName ?? "";
        document.getElementById("originalLastName").value = e.lastName ?? "";

        document.getElementById("firstName").value = e.firstName ?? "";
        document.getElementById("middleName").value = e.middleName ?? "";
        document.getElementById("lastName").value = e.lastName ?? "";
        document.getElementById("nickName").value = e.nickName ?? "";

        document.getElementById("employeeId").value = e.employeeId ?? "";
        document.getElementById("companyId").value = e.companyId ?? "";

        document.getElementById("address").value = e.address ?? "";
        document.getElementById("city").value = e.city ?? "";
        document.getElementById("state").value = e.state ?? "";
        document.getElementById("zip").value = e.zip ?? "";

        document.getElementById("homePhone").value = e.homePhone ?? "";
        document.getElementById("phone2").value = e.phone2 ?? "";

        document.getElementById("accessLevel").value = e.accessLevel ?? "";
        document.getElementById("accessNumber").value = e.accessNumber ?? "";
        document.getElementById("secondaryAccess").value = e.employeeId ?? "";
        document.getElementById("language").value = e.language ?? "";

        document.getElementById("hireDate").value = e.hireDate ?? "";
        document.getElementById("dob").value = e.dob ?? "";

        document.getElementById("terminated").checked = e.terminated === true;
    }

    function clearForm() {
        document.querySelectorAll("input").forEach(x => {
            if (x.type === "checkbox") {
                x.checked = false;
            } else {
                x.value = "";
            }
        });

        document.getElementById("firstName").focus();
    }

    function saveEmployee() {
        let firstName = document.getElementById("firstName").value.trim();
        let lastName = document.getElementById("lastName").value.trim();
        let accessLevel = document.getElementById("accessLevel").value.trim();
        let accessNumber = document.getElementById("accessNumber").value.trim();

        if (firstName === "" || lastName === "") {
            alert("First Name and Last Name are required.");
            return;
        }

        if (accessLevel === "" || accessNumber === "") {
            alert("Access Level and Primary Access Number are required.");
            return;
        }

        fetch('/MSaleAdmin/SaveEmployee', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                originalFirstName: document.getElementById("originalFirstName").value,
                originalLastName: document.getElementById("originalLastName").value,

                firstName: firstName,
                middleName: document.getElementById("middleName").value,
                lastName: lastName,
                nickName: document.getElementById("nickName").value,

                address: document.getElementById("address").value,
                city: document.getElementById("city").value,
                state: document.getElementById("state").value,
                zip: document.getElementById("zip").value,

                accessLevel: accessLevel,
                accessNumber: accessNumber,

                homePhone: document.getElementById("homePhone").value,
                phone2: document.getElementById("phone2").value,

                language: document.getElementById("language").value,
                employeeId: document.getElementById("employeeId").value,
                companyId: document.getElementById("companyId").value,

                hireDate: document.getElementById("hireDate").value,
                dob: document.getElementById("dob").value,

                terminated: document.getElementById("terminated").checked
            })
        })
        .then(r => r.text())
        .then(msg => {
            alert(msg);
            clearForm();
            loadEmployees(0);
        });
    }

    function deleteEmployee() {
        let firstName = document.getElementById("originalFirstName").value;
        let lastName = document.getElementById("originalLastName").value;

        if (!firstName || !lastName) {
            alert("Select an employee first.");
            return;
        }

        if (!confirm("Remove this employee?")) return;

        fetch('/MSaleAdmin/DeleteEmployee', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                originalFirstName: firstName,
                originalLastName: lastName
            })
        })
        .then(r => r.text())
        .then(msg => {
            alert(msg);
            clearForm();
            loadEmployees(0);
        });
    }
</script>
