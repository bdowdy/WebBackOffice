@{
    ViewData["Title"] = "Time Keeping Reports";
    ViewData["Subtitle"] = "Labor, payroll, and scheduling reports.";
}

<style>
    .tr-layout { display: flex; gap: 1.25rem; align-items: flex-start; }
    .tr-sidebar {
        width: 220px; flex-shrink: 0;
        background: #fff; border-radius: 12px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08); border: 1px solid #e2e8f0;
        padding: 8px 0; position: sticky; top: 80px;
    }
    .tr-sidebar-title {
        font-size: 10px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .06em; color: #94a3b8;
        padding: 6px 14px 4px;
    }
    .tr-nav-btn {
        display: block; width: 100%; text-align: left;
        padding: 8px 14px; font-size: 13px; color: #475569;
        background: none; border: none; cursor: pointer;
        border-left: 3px solid transparent; transition: all .15s;
    }
    .tr-nav-btn:hover  { background: #f8fafc; color: #1e293b; }
    .tr-nav-btn.active { background: #f0fdf4; color: #16a34a; border-left-color: #16a34a; font-weight: 600; }
    .tr-main { flex: 1; min-width: 0; }
    .tr-panel { display: none; }
    .tr-panel.active { display: block; }
    /* shared form bar */
    .ctrl-bar {
        background: #fff; border-radius: 12px; padding: 16px 20px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08); border: 1px solid #e2e8f0;
        display: flex; flex-wrap: wrap; align-items: flex-end; gap: 12px;
        margin-bottom: 16px;
    }
    .ctrl-bar label { font-size: 12px; font-weight: 500; color: #64748b; display: block; margin-bottom: 3px; }
    .ctrl-bar input[type=date], .ctrl-bar select {
        border: none; border-radius: 8px; padding: 7px 10px; font-size: 13px;
        box-shadow: 0 0 0 1px #cbd5e1 inset; background: #fff; color: #1e293b;
    }
    .ctrl-bar input[type=date]:focus, .ctrl-bar select:focus {
        outline: none; box-shadow: 0 0 0 2px #16a34a inset;
    }
    .btn-run {
        background: #16a34a; color: #fff; border: none; border-radius: 8px;
        padding: 8px 16px; font-size: 13px; font-weight: 600; cursor: pointer;
        transition: background .15s;
    }
    .btn-run:hover { background: #15803d; }
    .btn-print {
        background: #475569; color: #fff; border: none; border-radius: 8px;
        padding: 8px 16px; font-size: 13px; font-weight: 600; cursor: pointer;
        display: none; transition: background .15s;
    }
    .btn-print:hover { background: #334155; }
    /* result area */
    .result-wrap {
        background: #fff; border-radius: 12px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08); border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .result-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
    .result-tbl th {
        background: #f8fafc; padding: 7px 10px; text-align: left;
        border-bottom: 2px solid #e2e8f0; color: #64748b;
        font-size: 11px; font-weight: 600; text-transform: uppercase;
        letter-spacing: .04em; white-space: nowrap;
    }
    .result-tbl td { padding: 7px 10px; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .result-tbl tr:hover td { background: #f8fafc; }
    .result-tbl tr.total-row td { background: #f1f5f9; font-weight: 600; color: #1e293b; }
    .result-tbl tr.grand-row td { background: #1e293b; color: #fff; font-weight: 700; }
    .badge-ot  { color: #dc2626; font-weight: 700; }
    .badge-warn { color: #d97706; font-weight: 600; }
    .badge-ok   { color: #16a34a; font-weight: 600; }
    .badge-below { background: #fef2f2; color: #dc2626; border-radius: 4px; padding: 1px 5px; font-size: 11px; }
    .summary-strip {
        display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 14px;
    }
    .sc {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 8px;
        padding: 10px 14px; min-width: 100px;
    }
    .sc .lbl { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: #94a3b8; }
    .sc .val { font-size: 18px; font-weight: 700; color: #1e293b; margin-top: 1px; }
    .dept-hd {
        background: #1e293b; color: #fff; padding: 7px 14px;
        font-size: 13px; font-weight: 600; display: flex; justify-content: space-between;
    }
    .dept-hd span { font-size: 12px; font-weight: 400; color: #94a3b8; }
    .on-clock-card {
        background: #fff; border-radius: 10px; border: 1px solid #e2e8f0;
        padding: 14px 18px; display: flex; align-items: center; gap: 14px;
    }
    .oc-dot { width: 10px; height: 10px; border-radius: 50%; background: #16a34a;
              box-shadow: 0 0 0 3px #dcfce7; flex-shrink: 0; }
    .oc-name { font-size: 14px; font-weight: 600; color: #1e293b; }
    .oc-sub  { font-size: 12px; color: #64748b; }
    .oc-hrs  { margin-left: auto; font-size: 15px; font-weight: 700; color: #16a34a; }
    .msg-empty { padding: 32px; text-align: center; color: #94a3b8; font-size: 13px; }
    @@media print {
        nav, header, .no-print, .tr-sidebar { display: none !important; }
        .tr-layout { display: block; }
        .tr-panel { display: block !important; }
        .tr-panel:not(.active) { display: none !important; }
    }
</style>

<div class="tr-layout">

<!-- SIDEBAR -->
<nav class="tr-sidebar no-print">
    <div class="tr-sidebar-title">Reports</div>
    <button class="tr-nav-btn active" onclick="showPanel('payperiod',this)">Pay Period Labor</button>
    <button class="tr-nav-btn" onclick="showPanel('otwatch',this)">Overtime Watch</button>
    <button class="tr-nav-btn" onclick="showPanel('hourlylabor',this)">Hourly Labor</button>
    <button class="tr-nav-btn" onclick="showPanel('punch',this)">Punch Report</button>
    <button class="tr-nav-btn" onclick="showPanel('onclock',this)">Who's On the Clock</button>
    <button class="tr-nav-btn" onclick="showPanel('breaks',this)">Break Report</button>
    <button class="tr-nav-btn" onclick="showPanel('bydept',this)">Hours By Department</button>
    <button class="tr-nav-btn" onclick="showPanel('avgrate',this)">Avg Rate Exception</button>
    <button class="tr-nav-btn" onclick="showPanel('indiv',this)">Individual Daily</button>
    <div class="tr-sidebar-title" style="margin-top:4px">Employee Info</div>
    <button class="tr-nav-btn" onclick="showPanel('phonelist',this)">Phone List</button>
    <button class="tr-nav-btn" onclick="showPanel('accesscodes',this)">Access Codes</button>
</nav>

<!-- MAIN CONTENT AREA -->
<div class="tr-main">

<!-- ═══ 1. PAY PERIOD LABOR ═══ -->
<div id="panel-payperiod" class="tr-panel active">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="pp-begin"></div>
        <div><label>End Date</label><input type="date" id="pp-end"></div>
        <button class="btn-run" onclick="runPayPeriod()">Run Report</button>
        <button class="btn-print" id="pp-print" onclick="window.print()">Print</button>
    </div>
    <div id="pp-out"></div>
</div>

<!-- ═══ 2. OVERTIME WATCH ═══ -->
<div id="panel-otwatch" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="ot-begin"></div>
        <div><label>End Date</label><input type="date" id="ot-end"></div>
        <button class="btn-run" onclick="runOTWatch()">Run Report</button>
        <button class="btn-print" id="ot-print" onclick="window.print()">Print</button>
    </div>
    <div id="ot-out"></div>
</div>

<!-- ═══ 3. HOURLY LABOR ═══ -->
<div id="panel-hourlylabor" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Date</label><input type="date" id="hl-date"></div>
        <button class="btn-run" onclick="runHourlyLabor()">Run Report</button>
        <button class="btn-print" id="hl-print" onclick="window.print()">Print</button>
    </div>
    <div id="hl-out"></div>
</div>

<!-- ═══ 4. PUNCH REPORT ═══ -->
<div id="panel-punch" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="pr-begin"></div>
        <div><label>End Date</label><input type="date" id="pr-end"></div>
        <button class="btn-run" onclick="runPunch()">Run Report</button>
        <button class="btn-print" id="pr-print" onclick="window.print()">Print</button>
    </div>
    <div id="pr-out"></div>
</div>

<!-- ═══ 5. WHO'S ON THE CLOCK ═══ -->
<div id="panel-onclock" class="tr-panel">
    <div class="ctrl-bar">
        <button class="btn-run" onclick="runOnClock()">Refresh</button>
    </div>
    <div id="oc-out"></div>
</div>

<!-- ═══ 6. BREAK REPORT ═══ -->
<div id="panel-breaks" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="br-begin"></div>
        <div><label>End Date</label><input type="date" id="br-end"></div>
        <button class="btn-run" onclick="runBreaks()">Run Report</button>
        <button class="btn-print" id="br-print" onclick="window.print()">Print</button>
    </div>
    <div id="br-out"></div>
</div>

<!-- ═══ 7. HOURS BY DEPARTMENT ═══ -->
<div id="panel-bydept" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="bd-begin"></div>
        <div><label>End Date</label><input type="date" id="bd-end"></div>
        <button class="btn-run" onclick="runByDept()">Run Report</button>
        <button class="btn-print" id="bd-print" onclick="window.print()">Print</button>
    </div>
    <div id="bd-out"></div>
</div>

<!-- ═══ 8. AVG RATE EXCEPTION ═══ -->
<div id="panel-avgrate" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="ar-begin"></div>
        <div><label>End Date</label><input type="date" id="ar-end"></div>
        <button class="btn-run" onclick="runAvgRate()">Run Report</button>
        <button class="btn-print" id="ar-print" onclick="window.print()">Print</button>
    </div>
    <div id="ar-out"></div>
</div>

<!-- ═══ 9. INDIVIDUAL DAILY ═══ -->
<div id="panel-indiv" class="tr-panel">
    <div class="ctrl-bar">
        <div><label>Begin Date</label><input type="date" id="id-begin"></div>
        <div><label>End Date</label><input type="date" id="id-end"></div>
        <div>
            <label>Employee (optional)</label>
            <select id="id-emp">
                <option value="">— All Employees —</option>
            </select>
        </div>
        <button class="btn-run" onclick="runIndiv()">Run Report</button>
        <button class="btn-print" id="id-print" onclick="window.print()">Print</button>
    </div>
    <div id="id-out"></div>
</div>

<!-- ═══ 10. PHONE LIST ═══ -->
<div id="panel-phonelist" class="tr-panel">
    <div class="ctrl-bar">
        <button class="btn-run" onclick="runPhoneList()">Load List</button>
        <button class="btn-print" id="pl-print" onclick="window.print()">Print</button>
    </div>
    <div id="pl-out"></div>
</div>

<!-- ═══ 11. ACCESS CODES ═══ -->
<div id="panel-accesscodes" class="tr-panel">
    <div class="ctrl-bar">
        <button class="btn-run" onclick="runAccessCodes()">Load List</button>
        <button class="btn-print" id="ac-print" onclick="window.print()">Print</button>
    </div>
    <div id="ac-out"></div>
</div>

</div><!-- .tr-main -->
</div><!-- .tr-layout -->

<script>
// ── Helpers ──────────────────────────────────────────────────────────────
const fmt  = (n, d=2) => Number(n||0).toFixed(d);
const money = n => '$' + fmt(n);
const hh    = n => fmt(n) + ' h';
const today = () => new Date().toISOString().slice(0,10);
function weekRange() {
    const d = new Date(), day = d.getDay();
    const mon = new Date(d); mon.setDate(d.getDate() - (day===0?6:day-1));
    const sun = new Date(mon); sun.setDate(mon.getDate()+6);
    return [mon.toISOString().slice(0,10), sun.toISOString().slice(0,10)];
}
function setWeek(...ids) {
    const [m,s] = weekRange();
    ids.forEach((id,i) => { const el=document.getElementById(id); if(el) el.value = i===0?m:s; });
}
function showPanel(name, btn) {
    document.querySelectorAll('.tr-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tr-nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('panel-'+name).classList.add('active');
    btn.classList.add('active');
}
function tableWrap(html) {
    return `<div class="result-wrap"><div style="overflow-x:auto">${html}</div></div>`;
}
function empty(msg) {
    return `<div class="result-wrap"><div class="msg-empty">${msg||'No records found.'}</div></div>`;
}
function summaryStrip(items) {
    return `<div class="summary-strip">${items.map(i=>`<div class="sc"><div class="lbl">${i.l}</div><div class="val">${i.v}</div></div>`).join('')}</div>`;
}

// ── 1. Pay Period Labor ───────────────────────────────────────────────────
function runPayPeriod() {
    const b=document.getElementById('pp-begin').value, e=document.getElementById('pp-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetPayPeriodLabor?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out = document.getElementById('pp-out');
        if(!data.length){out.innerHTML=empty();return;}
        // Group by employee
        const empMap={};
        data.forEach(r=>{(empMap[r.employeeName]||(empMap[r.employeeName]=[])).push(r);});
        let gReg=0,gOT=0,gWages=0,html='';
        Object.keys(empMap).sort().forEach(emp=>{
            const rows=empMap[emp]; let eReg=0,eOT=0,eWages=0;
            rows.forEach(r=>{eReg+=+r.regHours;eOT+=+r.otHours;eWages+=+r.wages;});
            gReg+=eReg;gOT+=eOT;gWages+=eWages;
            html+=`<div class="dept-hd">${emp}<span>${rows.length} shift${rows.length!==1?'s':''} &nbsp;|&nbsp; Reg ${fmt(eReg)} h &nbsp;|&nbsp; OT ${fmt(eOT)} h &nbsp;|&nbsp; Wages ${money(eWages)}</span></div>`;
            html+=`<table class="result-tbl"><thead><tr><th>Date</th><th>Dept</th><th>Reg Hrs</th><th>OT Hrs</th><th>Total</th><th>Rate</th><th>Wages</th></tr></thead><tbody>`;
            rows.forEach(r=>{html+=`<tr><td>${r.shiftDate}</td><td>${r.departmentName}</td><td>${fmt(r.regHours)}</td><td class="${+r.otHours>0?'badge-ot':''}">${+r.otHours>0?fmt(r.otHours):''}</td><td>${fmt(r.totalHours)}</td><td>${money(r.rateOfPay)}</td><td>${money(r.wages)}</td></tr>`;});
            html+=`</tbody></table>`;
        });
        html+=`<table class="result-tbl"><tfoot><tr class="grand-row"><td colspan="2" style="padding:10px">Grand Total</td><td>${fmt(gReg)}</td><td>${fmt(gOT)}</td><td>${fmt(gReg+gOT)}</td><td></td><td>${money(gWages)}</td></tr></tfoot></table>`;
        out.innerHTML=summaryStrip([{l:'Reg Hrs',v:fmt(gReg)},{l:'OT Hrs',v:fmt(gOT)},{l:'Total Wages',v:money(gWages)}])+`<div class="result-wrap"><div style="overflow-x:auto">${html}</div></div>`;
        document.getElementById('pp-print').style.display='';
    }).catch(e=>document.getElementById('pp-out').innerHTML=empty('Error: '+e.message));
}

// ── 2. Overtime Watch ─────────────────────────────────────────────────────
function runOTWatch() {
    const b=document.getElementById('ot-begin').value, e=document.getElementById('ot-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetOvertimeWatch?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('ot-out');
        if(!data.length){out.innerHTML=empty();return;}
        let html=`<table class="result-tbl"><thead><tr><th>Employee</th><th>Dept</th><th>Total Hrs</th><th>OT Hrs</th><th>Rate</th><th>OT Wages</th><th>Status</th></tr></thead><tbody>`;
        data.forEach(r=>{
            const cls=r.status==='OT'?'badge-ot':r.status==='Warning'?'badge-warn':'badge-ok';
            html+=`<tr><td>${r.employeeName}</td><td>${r.departmentName}</td><td>${fmt(r.totalHours)}</td><td class="${r.otHours>0?'badge-ot':''}">${r.otHours>0?fmt(r.otHours):''}</td><td>${money(r.rateOfPay)}</td><td>${r.otHours>0?money(r.otWages):''}</td><td><span class="${cls}">${r.status}</span></td></tr>`;
        });
        html+=`</tbody></table>`;
        const otCount=data.filter(r=>r.status==='OT').length;
        out.innerHTML=summaryStrip([{l:'Employees',v:data.length},{l:'In OT',v:otCount},{l:'OT Wages',v:money(data.reduce((a,r)=>a+r.otWages,0))}])+tableWrap(html);
        document.getElementById('ot-print').style.display='';
    }).catch(e=>document.getElementById('ot-out').innerHTML=empty('Error: '+e.message));
}

// ── 3. Hourly Labor ───────────────────────────────────────────────────────
function runHourlyLabor() {
    const d=document.getElementById('hl-date').value;
    if(!d){alert('Select a date.');return;}
    fetch(`/TimeReports/GetHourlyLabor?date=${d}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('hl-out');
        const hours=data.hours||[];
        let html=`<table class="result-tbl"><thead><tr><th>Hour</th><th>Head Count</th><th>Employees</th><th>Est. Labor Cost</th></tr></thead><tbody>`;
        hours.forEach(h=>{
            if(h.headCount>0)
                html+=`<tr><td>${h.label}</td><td>${h.headCount}</td><td style="font-size:11px">${(h.employees||[]).join(', ')}</td><td>${money(h.laborCost)}</td></tr>`;
        });
        html+=`</tbody></table>`;
        const peak=hours.reduce((a,h)=>h.headCount>a.headCount?h:a,{headCount:0,label:''});
        out.innerHTML=summaryStrip([{l:'Date',v:d},{l:'Peak Hour',v:peak.label},{l:'Peak Count',v:peak.headCount}])+tableWrap(html);
        document.getElementById('hl-print').style.display='';
    }).catch(e=>document.getElementById('hl-out').innerHTML=empty('Error: '+e.message));
}

// ── 4. Punch Report ───────────────────────────────────────────────────────
function runPunch() {
    const b=document.getElementById('pr-begin').value, e=document.getElementById('pr-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetPunchReport?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('pr-out');
        if(!data.length){out.innerHTML=empty();return;}
        let html=`<table class="result-tbl"><thead><tr><th>Employee</th><th>Dept</th><th>Shift Date</th><th>Time In</th><th>Time Out</th><th>Brk Out</th><th>Brk In</th><th>Edited By</th></tr></thead><tbody>`;
        data.forEach(r=>{
            const alt=r.alteredBy||(r.alteredIn||r.alteredOut)?'style="color:#b45309"':'';
            html+=`<tr ${alt}><td>${r.employeeName}</td><td>${r.departmentName}</td><td>${r.shiftDate}</td><td>${r.timeIn}</td><td>${r.timeOut}</td><td>${r.breakOut}</td><td>${r.breakIn}</td><td style="font-size:11px">${r.alteredBy||''}</td></tr>`;
        });
        html+=`</tbody></table>`;
        out.innerHTML=summaryStrip([{l:'Records',v:data.length},{l:'Employees',v:new Set(data.map(r=>r.employeeName)).size}])+tableWrap(html);
        document.getElementById('pr-print').style.display='';
    }).catch(e=>document.getElementById('pr-out').innerHTML=empty('Error: '+e.message));
}

// ── 5. Who's On the Clock ─────────────────────────────────────────────────
function runOnClock() {
    fetch('/TimeReports/GetWhoIsOnClock')
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('oc-out');
        if(!data.length){out.innerHTML=`<div class="result-wrap"><div class="msg-empty">Nobody is currently clocked in.</div></div>`;return;}
        let html=`<div style="display:flex;flex-wrap:wrap;gap:10px;padding:14px">`;
        data.forEach(r=>{
            html+=`<div class="on-clock-card"><div class="oc-dot"></div><div><div class="oc-name">${r.employeeName}</div><div class="oc-sub">${r.departmentName} &bull; In ${r.timeIn}</div></div><div class="oc-hrs">${fmt(r.hoursOn)} h</div></div>`;
        });
        html+=`</div>`;
        out.innerHTML=summaryStrip([{l:'On Clock',v:data.length}])+`<div class="result-wrap">${html}</div>`;
    }).catch(e=>document.getElementById('oc-out').innerHTML=empty('Error: '+e.message));
}

// ── 6. Break Report ───────────────────────────────────────────────────────
function runBreaks() {
    const b=document.getElementById('br-begin').value, e=document.getElementById('br-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetBreakReport?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('br-out');
        if(!data.length){out.innerHTML=empty();return;}
        let html=`<table class="result-tbl"><thead><tr><th>Date</th><th>Employee</th><th>Dept</th><th>Time In</th><th>Time Out</th><th>Break Out</th><th>Break In</th><th>Break Mins</th></tr></thead><tbody>`;
        data.forEach(r=>{html+=`<tr><td>${r.shiftDate}</td><td>${r.employeeName}</td><td>${r.departmentName}</td><td>${r.timeIn}</td><td>${r.timeOut}</td><td>${r.breakOut}</td><td>${r.breakIn}</td><td>${r.breakMinutes}</td></tr>`;});
        html+=`</tbody></table>`;
        const avg=data.length?fmt(data.reduce((a,r)=>a+(+r.breakMinutes),0)/data.length):0;
        out.innerHTML=summaryStrip([{l:'Breaks',v:data.length},{l:'Avg Break',v:avg+' min'}])+tableWrap(html);
        document.getElementById('br-print').style.display='';
    }).catch(e=>document.getElementById('br-out').innerHTML=empty('Error: '+e.message));
}

// ── 7. Hours By Department ────────────────────────────────────────────────
function runByDept() {
    const b=document.getElementById('bd-begin').value, e=document.getElementById('bd-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetHoursByDepartment?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('bd-out');
        if(!data.length){out.innerHTML=empty();return;}
        let html='',gHrs=0,gWages=0;
        data.forEach(d=>{
            gHrs+=+d.totalHours;gWages+=+d.totalWages;
            html+=`<div class="dept-hd">${d.departmentName}<span>${fmt(d.totalHours)} h &nbsp;|&nbsp; ${money(d.totalWages)}</span></div>`;
            html+=`<table class="result-tbl"><thead><tr><th>Employee</th><th>Shifts</th><th>Total Hrs</th><th>Wages</th></tr></thead><tbody>`;
            d.employees.forEach(emp=>{html+=`<tr><td>${emp.employeeName}</td><td>${emp.shifts}</td><td>${fmt(emp.totalHours)}</td><td>${money(emp.totalWages)}</td></tr>`;});
            html+=`</tbody></table>`;
        });
        html+=`<table class="result-tbl"><tfoot><tr class="grand-row"><td colspan="2" style="padding:10px">Grand Total</td><td>${fmt(gHrs)}</td><td>${money(gWages)}</td></tr></tfoot></table>`;
        out.innerHTML=summaryStrip([{l:'Depts',v:data.length},{l:'Total Hrs',v:fmt(gHrs)},{l:'Total Wages',v:money(gWages)}])+`<div class="result-wrap"><div style="overflow-x:auto">${html}</div></div>`;
        document.getElementById('bd-print').style.display='';
    }).catch(e=>document.getElementById('bd-out').innerHTML=empty('Error: '+e.message));
}

// ── 8. Avg Rate Exception ─────────────────────────────────────────────────
function runAvgRate() {
    const b=document.getElementById('ar-begin').value, e=document.getElementById('ar-end').value;
    if(!b||!e){alert('Select dates.');return;}
    fetch(`/TimeReports/GetAvgRateException?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(data=>{
        const out=document.getElementById('ar-out');
        if(!data.length){out.innerHTML=empty('No tipped employee records found.');return;}
        let html=`<table class="result-tbl"><thead><tr><th>Employee</th><th>Shifts</th><th>Total Hrs</th><th>Base Rate</th><th>Total Tips</th><th>Avg Hrly Rate</th><th>Status</th></tr></thead><tbody>`;
        data.forEach(r=>{html+=`<tr><td>${r.employeeName}</td><td>${r.shifts}</td><td>${fmt(r.totalHours)}</td><td>${money(r.baseRate)}</td><td>${money(r.totalTips)}</td><td>${money(r.avgHourlyRate)}</td><td>${r.belowMinWage?'<span class="badge-below">Below Min Wage</span>':'<span class="badge-ok">OK</span>'}</td></tr>`;});
        html+=`</tbody></table>`;
        const below=data.filter(r=>r.belowMinWage).length;
        out.innerHTML=summaryStrip([{l:'Tipped Emps',v:data.length},{l:'Below Min Wage',v:below}])+tableWrap(html);
        document.getElementById('ar-print').style.display='';
    }).catch(e=>document.getElementById('ar-out').innerHTML=empty('Error: '+e.message));
}

// ── 9. Individual Daily ───────────────────────────────────────────────────
function loadIndivEmployees() {
    const b=document.getElementById('id-begin').value, e=document.getElementById('id-end').value;
    if(!b||!e) return;
    fetch(`/TimeReports/GetEmployeeList?beginDate=${b}&endDate=${e}`)
    .then(r=>r.json()).then(names=>{
        const sel=document.getElementById('id-emp');
        sel.innerHTML='<option value="">— All Employees —</option>';
        names.forEach(n=>{const o=document.createElement('option');o.value=n;o.textContent=n;sel.appendChild(o);});
    });
}
document.getElementById('id-begin').addEventListener('change', loadIndivEmployees);
document.getElementById('id-end').addEventListener('change',   loadIndivEmployees);

function runIndiv() {
    const b=document.getElementById('id-begin').value, e=document.getElementById('id-end').value;
    const emp=document.getElementById('id-emp').value;
    if(!b||!e){alert('Select dates.');return;}
    const url=`/TimeReports/GetIndividualDailyReport?beginDate=${b}&endDate=${e}`+(emp?`&employeeName=${encodeURIComponent(emp)}`:'');
    fetch(url).then(r=>r.json()).then(data=>{
        const out=document.getElementById('id-out');
        if(!data.length){out.innerHTML=empty();return;}
        const empMap={};
        data.forEach(r=>{(empMap[r.employeeName]||(empMap[r.employeeName]=[])).push(r);});
        let html='',gReg=0,gOT=0,gWages=0,gSales=0;
        Object.keys(empMap).sort().forEach(name=>{
            const rows=empMap[name]; let eReg=0,eOT=0,eWages=0,eSales=0;
            rows.forEach(r=>{eReg+=+r.regHours;eOT+=+r.otHours;eWages+=+r.wages;eSales+=+r.sales;});
            gReg+=eReg;gOT+=eOT;gWages+=eWages;gSales+=eSales;
            html+=`<div class="dept-hd">${name}<span>Reg ${fmt(eReg)} h &nbsp;|&nbsp; OT ${fmt(eOT)} h &nbsp;|&nbsp; Wages ${money(eWages)} &nbsp;|&nbsp; Sales ${money(eSales)}</span></div>`;
            html+=`<table class="result-tbl"><thead><tr><th>Date</th><th>Dept</th><th>In</th><th>Out</th><th>Reg</th><th>OT</th><th>Wages</th><th>Decl Tips</th><th>CC Tips</th><th>Sales</th></tr></thead><tbody>`;
            rows.forEach(r=>{html+=`<tr class="${r.alteredBy?'altered':''}"><td>${r.shiftDate}</td><td>${r.departmentName}</td><td>${r.timeIn}</td><td>${r.timeOut}</td><td>${fmt(r.regHours)}</td><td class="${+r.otHours>0?'badge-ot':''}">${+r.otHours>0?fmt(r.otHours):''}</td><td>${money(r.wages)}</td><td>${+r.declaredTips?money(r.declaredTips):''}</td><td>${+r.creditCardTips?money(r.creditCardTips):''}</td><td>${+r.sales?money(r.sales):''}</td></tr>`;});
            html+=`</tbody></table>`;
        });
        html+=`<table class="result-tbl"><tfoot><tr class="grand-row"><td colspan="4" style="padding:10px">Grand Total</td><td>${fmt(gReg)}</td><td>${fmt(gOT)}</td><td>${money(gWages)}</td><td></td><td></td><td>${money(gSales)}</td></tr></tfoot></table>`;
        out.innerHTML=summaryStrip([{l:'Employees',v:Object.keys(empMap).length},{l:'Reg Hrs',v:fmt(gReg)},{l:'OT Hrs',v:fmt(gOT)},{l:'Wages',v:money(gWages)},{l:'Sales',v:money(gSales)}])+`<div class="result-wrap"><div style="overflow-x:auto">${html}</div></div>`;
        document.getElementById('id-print').style.display='';
    }).catch(e=>document.getElementById('id-out').innerHTML=empty('Error: '+e.message));
}

