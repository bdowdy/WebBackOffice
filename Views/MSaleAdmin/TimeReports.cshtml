// ── Init default dates ────────────────────────────────────────────────────
(function init() {
    const [m,s] = weekRange();
    [['pp-begin','pp-end'],['ot-begin','ot-end'],['pr-begin','pr-end'],
     ['br-begin','br-end'],['bd-begin','bd-end'],['ar-begin','ar-end'],
     ['id-begin','id-end']].forEach(([b,e])=>{
        document.getElementById(b).value=m;
        document.getElementById(e).value=s;
    });
    document.getElementById('hl-date').value=today();
    // Auto-load who's on clock
    runOnClock();
})();
</script>
