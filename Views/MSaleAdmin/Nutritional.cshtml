@{
    ViewData["Title"] = "Nutritional Setup";
}

<div class="max-w-2xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div>
            <label class="block text-sm font-medium text-slate-700">Menu Name</label>
            <select id="menuName" onchange="loadNutritional()"
                    class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                <option value="">Select Menu Item</option>
            </select>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
                <label class="block text-sm font-medium text-slate-700">Calories</label>
                <input id="calories" type="number" step="1"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Fat</label>
                <input id="fat" type="number" step="0.01"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Carbs</label>
                <input id="carb" type="number" step="0.01"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Protein</label>
                <input id="protein" type="number" step="0.01"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Sodium</label>
                <input id="sodium" type="number" step="0.01"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-2 pt-2">
            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveNutritional()">Save</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteNutritional()">Remove</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearForm()">Clear</button>
        </div>

        <div id="msg" class="mt-4 text-sm font-semibold text-emerald-700"></div>

    </div>

</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadMenuNames();
    });

    function loadMenuNames() {
        fetch('/MSaleAdmin/GetNutritionalMenuNames')
            .then(r => r.json())
            .then(data => {
                let combo = document.getElementById("menuName");
                combo.innerHTML = '<option value="">Select Menu Item</option>';

                data.forEach(name => {
                    let opt = document.createElement("option");
                    opt.value = name;
                    opt.textContent = name;
                    combo.appendChild(opt);
                });
            });
    }

    function loadNutritional() {
        let menuName = document.getElementById("menuName").value;
        clearNumbers();

        if (!menuName) return;

        fetch('/MSaleAdmin/GetNutritional?menuName=' + encodeURIComponent(menuName))
            .then(r => r.json())
            .then(data => {
                if (!data) return;

                document.getElementById("sodium").value = data.sodium ?? "";
                document.getElementById("carb").value = data.carb ?? "";
                document.getElementById("fat").value = data.fat ?? "";
                document.getElementById("protein").value = data.protein ?? "";
                document.getElementById("calories").value = data.calories ?? "";
            });
    }

    function saveNutritional() {
        let menuName = document.getElementById("menuName").value;

        if (!menuName) {
            showMsg("Select a Menu Name first.");
            return;
        }

        let data = {
            menuName: menuName,
            sodium: val("sodium"),
            carb: val("carb"),
            fat: val("fat"),
            protein: val("protein"),
            calories: val("calories")
        };

        fetch('/MSaleAdmin/SaveNutritional', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(result => {
            showMsg(result.message);
        });
    }

    function deleteNutritional() {
        let menuName = document.getElementById("menuName").value;

        if (!menuName) {
            showMsg("Select a Menu Name first.");
            return;
        }

        fetch('/MSaleAdmin/DeleteNutritional', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ menuName: menuName })
        })
        .then(r => r.json())
        .then(result => {
            clearNumbers();
            showMsg(result.message);
        });
    }

    function clearForm() {
        document.getElementById("menuName").value = "";
        clearNumbers();
        showMsg("");
    }

    function clearNumbers() {
        document.getElementById("sodium").value = "";
        document.getElementById("carb").value = "";
        document.getElementById("fat").value = "";
        document.getElementById("protein").value = "";
        document.getElementById("calories").value = "";
    }

    function val(id) {
        let v = document.getElementById(id).value;
        return v === "" ? 0 : parseFloat(v);
    }

    function showMsg(text) {
        document.getElementById("msg").innerText = text;
    }
</script>
