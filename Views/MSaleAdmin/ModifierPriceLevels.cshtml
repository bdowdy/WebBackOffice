@{
    ViewData["Title"] = "Modifier Price Levels";
    ViewData["Subtitle"] = "Edit modifier titles, prefixes, prices, levels, and categories.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
        <button onclick="addRow()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Add Row</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveRows()">Save</button>
        <button onclick="loadRows()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Reload</button>
        <div class="flex-1"></div>
        <button onclick="location.href='/MSaleAdmin'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Dashboard</button>
        <button onclick="location.href='/'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Exit</button>
    </div>

    <div class="overflow-x-auto rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid grid-cols-[1fr_140px_120px_120px_1fr_90px] items-center gap-2 border-b border-slate-200 pb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">
            <div>Modifier Title</div>
            <div>Prefix</div>
            <div>Price</div>
            <div>Level</div>
            <div>Modifier Category</div>
            <div>Remove</div>
        </div>

        <div id="rows"></div>
    </div>

</div>

<script>
    let rows = [];

    document.addEventListener("DOMContentLoaded", loadRows);

    function loadRows() {
        fetch('/ModifierPriceLevels/GetModifierPriceLevels')
            .then(r => r.json())
            .then(data => {
                rows = data || [];
                drawRows();
            })
            .catch(err => alert("Could not load price levels: " + err.message));
    }

    function drawRows() {
        const div = document.getElementById("rows");
        div.innerHTML = "";

        const INPUT = "w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500";

        rows.forEach((r, i) => {
            const row = document.createElement("div");
            row.className = "mt-2 grid grid-cols-[1fr_140px_120px_120px_1fr_90px] items-center gap-2";

            row.innerHTML = `
                <input class="${INPUT}" value="${safe(r.modifierTitle)}" onchange="rows[${i}].modifierTitle=this.value" />
                <input class="${INPUT}" value="${safe(r.prefix)}" onchange="rows[${i}].prefix=this.value" />
                <input class="${INPUT}" type="number" step="0.01" value="${r.price || 0}" onchange="rows[${i}].price=parseFloat(this.value||0)" />
                <input class="${INPUT}" type="number" value="${r.level || 0}" onchange="rows[${i}].level=parseInt(this.value||0)" />
                <input class="${INPUT}" value="${safe(r.modifierCategory)}" onchange="rows[${i}].modifierCategory=this.value" />
                <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="removeRow(${i})">X</button>
            `;

            div.appendChild(row);
        });
    }

    function addRow() {
        rows.push({
            modifierTitle: "",
            prefix: "",
            price: 0,
            level: 0,
            modifierCategory: ""
        });

        drawRows();
    }

    function removeRow(i) {
        rows.splice(i, 1);
        drawRows();
    }

    function saveRows() {
        fetch('/ModifierPriceLevels/SaveModifierPriceLevels', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(rows)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"))
        .catch(err => alert("Save failed: " + err.message));
    }

    function safe(v) {
        return (v || "").replaceAll('"', '&quot;');
    }
</script>
