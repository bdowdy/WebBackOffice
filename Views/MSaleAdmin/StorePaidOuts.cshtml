@{
    ViewData["Title"] = "Store Paid Outs";
    ViewData["Subtitle"] = "Add or edit paid out reasons.";
}

<div class="max-w-xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <label for="paidOutName" class="block text-sm font-medium text-slate-700">Paid Out Name</label>
        <input id="paidOutName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="Enter paid out name" />

        <div class="flex flex-wrap items-center gap-2 pt-4">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="savePaidOut()">Save</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearPaidOut()">Clear</button>
        </div>

    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Existing Paid Outs</h2>
        <div id="paidOutList" class="mt-3 max-h-80 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadPaidOuts();
    });

    function loadPaidOuts() {
        fetch('/MSaleAdmin/GetStorePaidOuts')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById('paidOutList');
                list.innerHTML = '';

                data.forEach(function (x) {
                    let div = document.createElement('div');
                    div.className = 'cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50';
                    div.textContent = x.paidOutName;

                    div.onclick = function () {
                        document.getElementById('paidOutName').value = x.paidOutName;
                    };

                    list.appendChild(div);
                });
            });
    }

    function savePaidOut() {
        let item = {
            paidOutName: document.getElementById('paidOutName').value
        };

        if (!item.paidOutName.trim()) {
            alert("Enter a paid out name.");
            return;
        }

        fetch('/MSaleAdmin/SaveStorePaidOut', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadPaidOuts();
            clearPaidOut();
        });
    }

    function clearPaidOut() {
        document.getElementById('paidOutName').value = '';
    }
</script>
