@{
    ViewData["Title"] = "Store Paid In";
    ViewData["Subtitle"] = "Add, edit, and delete store paid in records.";
}

<div class="max-w-2xl space-y-6">

    <input type="hidden" id="paidInId" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <label class="block text-sm font-medium text-slate-700">
            Paid In Name
        </label>

        <input type="text"
               id="paidInName"
               class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
               placeholder="Enter Paid In Name" />

        <div class="flex flex-wrap items-center gap-2 pt-4">

            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                    onclick="savePaidIn()">
                Save
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50"
                    onclick="clearForm()">
                Clear
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50"
                    onclick="deletePaidIn()">
                Delete
            </button>

        </div>

    </div>

    <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200">

        <div class="max-h-[500px] overflow-y-auto">

            <table class="min-w-full divide-y divide-slate-200 text-sm">

                <thead class="sticky top-0 bg-slate-50">
                    <tr>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Paid In Name</th>
                    </tr>
                </thead>

                <tbody id="paidInList" class="divide-y divide-slate-100">
                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {
        loadPaidIns();
    });

    function loadPaidIns() {

        fetch('/MSaleAdmin/GetStorePaidIns')
            .then(r => r.json())
            .then(data => {

                let tbody =
                    document.getElementById("paidInList");

                tbody.innerHTML = "";

                if (data.length === 0) {

                    tbody.innerHTML =
                        `<tr>
                            <td class="px-4 py-6 text-center text-sm italic text-slate-400">
                                No Store Paid In Records Found
                            </td>
                         </tr>`;

                    return;
                }

                data.forEach(function(item) {

                    let tr = document.createElement("tr");
                    tr.className = "cursor-pointer hover:bg-slate-50";

                    tr.innerHTML =
                        `<td class="px-4 py-2.5 text-slate-700" onclick="editPaidIn(${item.id},
                            '${item.paidInName}')">

                            ${item.paidInName}

                         </td>`;

                    tbody.appendChild(tr);

                });

            });

    }

    function editPaidIn(id, name) {

        document.getElementById("paidInId").value = id;
        document.getElementById("paidInName").value = name;

    }

    function clearForm() {

        document.getElementById("paidInId").value = "";
        document.getElementById("paidInName").value = "";

        document.getElementById("paidInName").focus();

    }

    function savePaidIn() {

        let id =
            document.getElementById("paidInId").value;

        let paidInName =
            document.getElementById("paidInName").value;

        if (paidInName.trim() === "") {

            alert("Please enter a Paid In Name.");
            return;

        }

        fetch('/MSaleAdmin/SaveStorePaidIn', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({

                id: id || 0,
                paidInName: paidInName

            })

        })
        .then(r => r.text())
        .then(msg => {

            alert(msg);

            clearForm();
            loadPaidIns();

        });

    }

    function deletePaidIn() {

        let id =
            document.getElementById("paidInId").value;

        if (!id) {

            alert("Select a Paid In record first.");
            return;

        }

        if (!confirm("Delete this Paid In record?"))
            return;

        fetch('/MSaleAdmin/DeleteStorePaidIn', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                id: id
            })

        })
        .then(r => r.text())
        .then(msg => {

            alert(msg);

            clearForm();
            loadPaidIns();

        });

    }

</script>
