@{
    ViewData["Title"] = "Discount Item Assignment";
}

<div class="max-w-2xl space-y-6">

    <div class="space-y-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div>
            <label for="eventCombo" class="block text-sm font-medium text-slate-700">Discount List</label>
            <select id="eventCombo" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                <option value="">Select Discount List</option>
            </select>
        </div>

        <div class="flex flex-wrap items-center gap-2 pt-2">
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadMenuAndModifiers()">
                Menu / Modifiers
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadDepartments()">
                Departments
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="selectAllItems()">
                Select All
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearList()">
                Clear List
            </button>
        </div>

        <div id="dlist" class="max-h-96 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200">
            <div class="px-4 py-10 text-center text-sm italic text-slate-400">Select a discount and load Menu / Modifiers or Departments to begin</div>
        </div>

        <button class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveCouponAssignments()">
            Save Assignments
        </button>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadDiscountEventNames();
    });

    function clearList() {
        document.getElementById("dlist").innerHTML =
            '<div class="px-4 py-10 text-center text-sm italic text-slate-400">List cleared. Load Menu / Modifiers or Departments to continue.</div>';
    }

    function addCheckItem(text, value, checked) {
        let div = document.createElement("label");
        div.className = "flex cursor-pointer select-none items-center gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50";

        let chk = document.createElement("input");
        chk.type = "checkbox";
        chk.value = value;
        chk.checked = checked === true;
        chk.className = "h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500";

        div.appendChild(chk);
        div.appendChild(document.createTextNode(text));

        document.getElementById("dlist").appendChild(div);
    }

    function getSelectedDiscount() {
        return document.getElementById("eventCombo").value.trim();
    }

    function clean(x) {
        if (x == null) return "";

        if (typeof x === "string") {
            return x.trim();
        }

        return (
            x.name ||
            x.Name ||
            x.menuItemName ||
            x.MenuItemName ||
            x["Menu Item Name"] ||
            x.modifierName ||
            x.ModifierName ||
            x["Modifier Name"] ||
            x.departmentName ||
            x.DepartmentName ||
            x["Department Name"] ||
            x.linkToName ||
            x.LinkToName ||
            ""
        ).toString().trim();
    }

    function loadDiscountEventNames() {
        let combo = document.getElementById("eventCombo");
        combo.innerHTML = '<option value="">Select Discount</option>';

        fetch('/MSaleAdmin/GetDiscountEventNames')
            .then(r => r.json())
            .then(data => {
                data.forEach(function (row) {
                    let name = clean(row);

                    if (name !== "") {
                        let opt = document.createElement("option");
                        opt.value = name;
                        opt.text = name;
                        combo.appendChild(opt);
                    }
                });
            });
    }

    function loadMenuAndModifiers() {
        loadAssignmentList('/MSaleAdmin/GetMenuAndModifiers');
    }

    function loadDepartments() {
        loadAssignmentList('/MSaleAdmin/GetDepartments');
    }

    function loadAssignmentList(loadUrl) {
        let dlist = document.getElementById("dlist");
        dlist.innerHTML = '<div class="px-4 py-10 text-center text-sm italic text-slate-400">Loading...</div>';

        let couponName = getSelectedDiscount();

        if (!couponName) {
            alert("Select a discount first.");
            dlist.innerHTML = '<div class="px-4 py-10 text-center text-sm italic text-slate-400">Select a discount and load Menu / Modifiers or Departments to begin</div>';
            return;
        }

        // Fetch the items AND the saved assignments at the same time
        Promise.all([
            fetch(loadUrl).then(r => r.json()),
            fetch('/MSaleAdmin/GetCouponAssignments?couponName=' + encodeURIComponent(couponName))
                .then(r => r.json())
                .catch(() => [])   // if saved-fetch fails, treat as empty
        ])
        .then(function (results) {
            let items = results[0] || [];
            let saved = results[1] || [];

            dlist.innerHTML = "";

            // Normalize saved list once
            let savedList = saved
                .map(x => clean(x).toLowerCase())
                .filter(x => x !== "");

            items.forEach(function (row) {
                let name = clean(row);

                if (name !== "") {
                    let isChecked = savedList.indexOf(name.toLowerCase()) !== -1;
                    addCheckItem(name, name, isChecked);
                }
            });

            if (items.length === 0) {
                dlist.innerHTML = '<div class="px-4 py-10 text-center text-sm italic text-slate-400">No items returned.</div>';
                alert("No items returned from: " + loadUrl);
            }
        })
        .catch(function (err) {
            dlist.innerHTML = '<div class="px-4 py-10 text-center text-sm italic text-slate-400">Failed to load items.</div>';
            alert("Could not load items from: " + loadUrl);
        });
    }

    function selectAllItems() {
        document.querySelectorAll('#dlist input[type="checkbox"]').forEach(function (box) {
            box.checked = true;
        });
    }

    function saveCouponAssignments() {
        let couponName = getSelectedDiscount();

        if (!couponName) {
            alert("Select a discount first.");
            return;
        }

        let selected = [];

        document.querySelectorAll('#dlist input[type="checkbox"]:checked').forEach(function (box) {
            selected.push(box.value);
        });

        fetch('/MSaleAdmin/SaveCouponAssignments', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                couponName: couponName,
                linkToNames: selected
            })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                alert("Saved.");
            } else {
                alert(data.error || "Save failed.");
            }
        });
    }
</script>
