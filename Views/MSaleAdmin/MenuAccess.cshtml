@{
    ViewData["Title"] = "Menu Access Setup";
    ViewData["Subtitle"] = "Access Levels (Permissions)";
}

<div class="grid gap-6 lg:grid-cols-[2fr_3fr]">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <select id="buttonList" size="24" onclick="selectFunction()"
                class="block w-full rounded-lg border-0 bg-white p-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

        <div class="mt-3 text-center text-sm font-medium text-slate-700">
            Access Level Required
        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="rounded-lg bg-amber-50 px-3 py-2 text-center text-sm font-medium text-amber-800 ring-1 ring-inset ring-amber-200">Select access - 10 locks button</div>

        <div class="mt-4 flex flex-wrap items-end gap-3">
            <div class="min-w-0 flex-1">
                <div class="block text-sm font-medium text-slate-700">Selected Item</div>
                <div id="selectedName" class="mt-1 truncate py-2 text-sm font-semibold text-slate-900">Select Item</div>
            </div>

            <div>
                <div class="block text-sm font-medium text-slate-700">Level</div>
                <select id="accessLevel"
                        class="mt-1 block w-20 rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    @for (int i = 0; i <= 10; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <button type="button" onclick="saveAccess()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save</button>
        </div>

        <div class="mt-6 block text-sm font-medium text-slate-700">Active Access Levels</div>
        <select id="displayAccess" size="20" onclick="selectActiveAccess()"
                class="mt-1 block w-full rounded-lg border-0 bg-white p-2 text-sm font-semibold shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
    </div>

</div>

<script>
    const menuItems = [
        "Restrict Tenders",
        "Manager Access",
        "Minimum Access",
        "Discount After Check Is Printed",
        "View All Checks",
        "Set Access",
        "Access Phone Order",
        "Phone Order",
        "Message To Manager",
        "Item Refund",
        "Refund",
        "Member Reward",
        "Check Id",
        "New Phone Order",
        "Open Drinks",
        "Attach Coupon",
        "Review Order",
        "Attach Credit Card",
        "Guest Services",
        "Frequent Diner",
        "Show Recipe",
        "Catering Proposal",
        "Server Drinks",
        "Release Holds",
        "Keyboard",
        "Customer Name",
        "Attach Discount",
        "Table Tent",
        "Change Destination",
        "Tray Review",
        "Time Clock",
        "Paid Outs",
        "Fire Order",
        "Gift Card Balance",
        "Resend to Kitchen",
        "Item To Go",
        "Discount Card",
        "Show Menu List",
        "Hide Sent Items",
        "Show Sent Items",
        "PLU Look Up",
        "Verify Account",
        "Edit Account No",
        "Meal Periods",
        "Print By Seat",
        "Open Drawer",
        "Intercard",
        "Reprint Receipt",
        "Hold Item",
        "Hold Check",
        "Managers Menu",
        "Apply Tip",
        "Blind Audit",
        "Gratuity",
        "Waste",
        "Redeem Loyalty",
        "Loyalty Status",
        "EBT Total",
        "Verify Balance",
        "Reprint Last Receipt",
        "Taxable",
        "Start Tab",
        "Tip Edit",
        "Scan Check",
        "Price Adjust",
        "Alternate Remote",
        "Select Receipt",
        "Item Transfer",
        "Delete Item",
        "Print/Start Tab",
        "Service Charge",
        "Send/Stay",
        "Skim Drawer",
        "Tip List",
        "Print CC Slip",
        "Pay Up Front",
        "Recall Suspended",
        "Text Order Ready",
        "Stop PhoneOrder Message",
        "EBT Sale",
        "Qty Available",
        "Change Menu",
        "Single Labels",
        "Multi Labels",
        "Grab N Go",
        "Table View",
        "Kiosk Is On",
        "Edit Seats"
    ];

    document.addEventListener("DOMContentLoaded", function () {
        loadButtonList();
        loadAccessLevels();
    });

    function loadButtonList() {
        let list = document.getElementById("buttonList");
        list.innerHTML = "";

        menuItems.forEach(x => {
            let opt = document.createElement("option");
            opt.value = x;
            opt.text = x;
            list.appendChild(opt);
        });
    }

    function mapMenuName(name) {
        if (name === "Restrict Tenders") return "Amount Tended";
        if (name === "Manager Access") return "Managers Menu";
        if (name === "Discount After Check Is Printed") return "Allow Discount";
        return name;
    }

    function selectFunction() {
        let list = document.getElementById("buttonList");
        let name = list.value;

        if (name === "Set Access") {
            let custom = prompt("Enter Button Name");
            if (!custom) return;
            name = custom;
        }

        setAccess(mapMenuName(name));
    }

    function selectActiveAccess() {
        let list = document.getElementById("displayAccess");
        if (!list.value) return;

        let parts = list.value.split("--");
        let name = parts[0].trim();

        setAccess(name);
    }

    function setAccess(menuName) {
        fetch('/MSaleAdmin/GetMenuAccessItem?menuName=' + encodeURIComponent(menuName))
            .then(r => r.json())
            .then(data => {
                document.getElementById("selectedName").innerText = data.menuName || menuName;
                document.getElementById("accessLevel").value = data.accessRequired ?? 0;
            })
            .catch(err => alert("Could not load item: " + err.message));
    }

    function loadAccessLevels() {
        fetch('/MSaleAdmin/GetMenuAccess')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("displayAccess");
                list.innerHTML = "";

                data.forEach(x => {
                    let opt = document.createElement("option");
                    opt.value = x.menuName + " -- " + x.accessRequired;
                    opt.text = x.menuName + " -- " + x.accessRequired;
                    list.appendChild(opt);
                });
            })
            .catch(err => alert("Could not load access levels: " + err.message));
    }

    function saveAccess() {
        let menuName = document.getElementById("selectedName").innerText;

        if (!menuName || menuName === "Select Item") return;

        let data = {
            menuName: menuName,
            accessRequired: parseInt(document.getElementById("accessLevel").value || 0)
        };

        fetch('/MSaleAdmin/SaveMenuAccess', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Updated");
            document.getElementById("selectedName").innerText = "Select Item";
            document.getElementById("accessLevel").value = 0;
            loadAccessLevels();
        })
        .catch(err => alert("Save failed: " + err.message));
    }
</script>
