@{
    ViewData["Title"] = "Time Records Report";
    ViewData["Subtitle"] = "Pre-print closed time records by employee for a date range.";
}

<div class="space-y-6">

    <!-- Date range + controls -->
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="flex flex-wrap items-end gap-4">
            <div>
                <label for="beginDate" class="block text-sm font-medium text-slate-700">Begin Date</label>
                <input type="date" id="beginDate"
                       class="mt-1 block rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>
            <div>
                <label for="endDate" class="block text-sm font-medium text-slate-700">End Date</label>
                <input type="date" id="endDate"
                       class="mt-1 block rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>
            <button onclick="loadReport()"
                    class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Run Report
            </button>
            <button onclick="printReport()" id="btnPrint" style="display:none"
                    class="inline-flex items-center gap-1.5 rounded-lg bg-slate-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-600">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659" />
                </svg>
                Print
            </button>
        </div>
        <p id="reportStatus" class="mt-3 text-sm text-slate-500 hidden"></p>
    </div>

    <!-- Report output -->
    <div id="reportWrap" class="hidden">

        <!-- Summary cards -->
        <div class="mb-4 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-6" id="summaryCards"></div>

        <!-- Detail table (one section per employee) -->
        <div id="reportBody"></div>

    </div>

</div>

<style>
    @@media print {
        nav, header, .no-print { display: none !important; }
        #reportWrap { display: block !important; }
        .page-break { page-break-before: always; }
        body { font-size: 11px; }
    }
    .emp-section { margin-bottom: 1.5rem; }
    .emp-hd {
        display: flex; align-items: center; justify-content: space-between;
        background: #1e293b; color: #fff;
        padding: 7px 14px; border-radius: 8px 8px 0 0;
        font-size: 13px; font-weight: 600;
    }
    .emp-hd span { font-size: 12px; font-weight: 400; color: #94a3b8; }
    .emp-tbl { width: 100%; border-collapse: collapse; font-size: 12px; }
    .emp-tbl th {
        background: #f1f5f9; padding: 6px 8px; text-align: left;
        border-bottom: 2px solid #e2e8f0; color: #64748b;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
        white-space: nowrap;
    }
    .emp-tbl td { padding: 6px 8px; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .emp-tbl tr:hover td { background: #f8fafc; }
    .emp-tbl tr.altered td { color: #b45309; }
    .emp-total td {
        background: #f8fafc; font-weight: 600; color: #1e293b;
        border-top: 2px solid #e2e8f0;
    }
    .grand-total td {
        background: #1e293b; color: #fff; font-weight: 700;
        font-size: 13px;
    }
    .ot-cell { color: #dc2626; font-weight: 600; }
    .summary-card {
        background: #fff; border-radius: 8px; padding: 12px 14px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08); ring: 1px solid #e2e8f0;
        border: 1px solid #e2e8f0;
    }
    .summary-card .sc-label { font-size: 11px; color: #64748b; font-weight: 500; text-transform: uppercase; letter-spacing: .04em; }
    .summary-card .sc-val   { font-size: 20px; font-weight: 700; color: #1e293b; margin-top: 2px; }
</style>

<script>
    function fmt(n, dec = 2) { return Number(n || 0).toFixed(dec); }
    function money(n) { return '$' + fmt(n); }
    function hrs(n)   { return fmt(n) + ' h'; }

    function loadReport() {
        const bd = document.getElementById('beginDate').value;
        const ed = document.getElementById('endDate').value;
        if (!bd || !ed) { alert('Select begin and end dates.'); return; }

        const status = document.getElementById('reportStatus');
        status.textContent = 'Loading…';
        status.classList.remove('hidden');

        fetch(`/TimeRecordsReport/GetTimeRecords?beginDate=${bd}&endDate=${ed}`)
            .then(r => r.json())
            .then(data => {
                status.classList.add('hidden');
                if (!data.length) {
                    status.textContent = 'No records found for that date range.';
                    status.classList.remove('hidden');
                    return;
                }
                renderReport(data, bd, ed);
                document.getElementById('reportWrap').classList.remove('hidden');
                document.getElementById('btnPrint').style.display = '';
            })
            .catch(err => {
                status.textContent = 'Error: ' + err.message;
            });
    }

    function renderReport(data, bd, ed) {
        // Group by employee
        const byEmp = {};
        data.forEach(r => {
            if (!byEmp[r.employeeName]) byEmp[r.employeeName] = [];
            byEmp[r.employeeName].push(r);
        });

        // Grand totals
        let gReg = 0, gOT = 0, gTotal = 0, gWages = 0;
        let gDecl = 0, gCC = 0, gPaid = 0, gShare = 0, gSales = 0;

        let html = '';
        let empIdx = 0;

        Object.keys(byEmp).sort().forEach(emp => {
            const rows = byEmp[emp];
            let eReg = 0, eOT = 0, eTotal = 0, eWages = 0;
            let eDecl = 0, eCC = 0, ePaid = 0, eShare = 0, eSales = 0;

            rows.forEach(r => {
                eReg   += +r.regHours;
                eOT    += +r.otHours;
                eTotal += +r.totalHours;
                eWages += +r.wages;
                eDecl  += +r.declaredTips;
                eCC    += +r.creditCardTips;
                ePaid  += +r.tipsPaidOut;
                eShare += +r.tipShare;
                eSales += +r.sales;
            });

            gReg += eReg; gOT += eOT; gTotal += eTotal; gWages += eWages;
            gDecl += eDecl; gCC += eCC; gPaid += ePaid; gShare += eShare; gSales += eSales;

            const dept = rows[0].departmentName;
            const pb = empIdx > 0 ? 'page-break' : '';
            empIdx++;

            html += `
            <div class="emp-section ${pb}">
              <div class="emp-hd">
                <div>${emp} <span>— ${dept}</span></div>
                <div><span>${rows.length} shift${rows.length !== 1 ? 's' : ''}</span></div>
              </div>
              <div class="overflow-x-auto rounded-b-xl bg-white shadow-sm ring-1 ring-slate-200">
              <table class="emp-tbl">
                <thead><tr>
                  <th>Date</th><th>Dept</th><th>In</th><th>Out</th>
                  <th>Brk Out</th><th>Brk In</th>
                  <th>Reg Hrs</th><th>OT Hrs</th><th>Total</th>
                  <th>Rate</th><th>Wages</th>
                  <th>Decl Tips</th><th>CC Tips</th><th>Tips Paid</th><th>Tip Share</th><th>Sales</th>
                  <th>Edited By</th>
                </tr></thead>
                <tbody>
                  ${rows.map(r => `
                  <tr class="${r.alteredBy ? 'altered' : ''}">
                    <td>${r.shiftDate}</td>
                    <td>${r.departmentName}</td>
                    <td>${r.timeIn}</td>
                    <td>${r.timeOut}</td>
                    <td>${r.breakOut}</td>
                    <td>${r.breakIn}</td>
                    <td>${fmt(r.regHours)}</td>
                    <td class="${+r.otHours > 0 ? 'ot-cell' : ''}">${+r.otHours > 0 ? fmt(r.otHours) : ''}</td>
                    <td>${fmt(r.totalHours)}</td>
                    <td>${money(r.rateOfPay)}</td>
                    <td>${money(r.wages)}</td>
                    <td>${+r.declaredTips   ? money(r.declaredTips)   : ''}</td>
                    <td>${+r.creditCardTips ? money(r.creditCardTips) : ''}</td>
                    <td>${+r.tipsPaidOut    ? money(r.tipsPaidOut)    : ''}</td>
                    <td>${+r.tipShare       ? money(r.tipShare)       : ''}</td>
                    <td>${+r.sales          ? money(r.sales)          : ''}</td>
                    <td style="font-size:11px;color:#b45309">${r.alteredBy || ''}</td>
                  </tr>`).join('')}
                </tbody>
                <tfoot>
                  <tr class="emp-total">
                    <td colspan="6" style="padding-left:8px">${emp} — Totals</td>
                    <td>${fmt(eReg)}</td>
                    <td class="${eOT > 0 ? 'ot-cell' : ''}">${eOT > 0 ? fmt(eOT) : ''}</td>
                    <td>${fmt(eTotal)}</td>
                    <td></td>
                    <td>${money(eWages)}</td>
                    <td>${money(eDecl)}</td>
                    <td>${money(eCC)}</td>
                    <td>${money(ePaid)}</td>
                    <td>${money(eShare)}</td>
                    <td>${money(eSales)}</td>
                    <td></td>
                  </tr>
                </tfoot>
              </table>
              </div>
            </div>`;
        });

        // Grand total row
        html += `
        <div class="overflow-x-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200 mt-2">
        <table class="emp-tbl">
          <tfoot>
            <tr class="grand-total">
              <td colspan="6" style="padding:10px 8px">Grand Total — ${bd} to ${ed}</td>
              <td>${fmt(gReg)}</td>
              <td class="${gOT > 0 ? 'ot-cell' : ''}" style="color:${gOT>0?'#fca5a5':'#fff'}">${gOT > 0 ? fmt(gOT) : ''}</td>
              <td>${fmt(gTotal)}</td>
              <td></td>
              <td>${money(gWages)}</td>
              <td>${money(gDecl)}</td>
              <td>${money(gCC)}</td>
              <td>${money(gPaid)}</td>
              <td>${money(gShare)}</td>
              <td>${money(gSales)}</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
        </div>`;

        document.getElementById('reportBody').innerHTML = html;

        // Summary cards
        const cards = [
            { label: 'Employees',  val: Object.keys(byEmp).length, prefix: '' },
            { label: 'Total Hours', val: fmt(gTotal), prefix: '' },
            { label: 'OT Hours',    val: fmt(gOT),    prefix: '' },
            { label: 'Wages',       val: money(gWages), prefix: '' },
            { label: 'CC Tips',     val: money(gCC),    prefix: '' },
            { label: 'Sales',       val: money(gSales), prefix: '' }
        ];
        document.getElementById('summaryCards').innerHTML =
            cards.map(c => `<div class="summary-card">
                <div class="sc-label">${c.label}</div>
                <div class="sc-val">${c.val}</div>
            </div>`).join('');
    }

    function printReport() { window.print(); }

    // Default to current week (Mon–Sun)
    (function setDefaultDates() {
        const today = new Date();
        const day = today.getDay();
        const mon = new Date(today);
        mon.setDate(today.getDate() - (day === 0 ? 6 : day - 1));
        const sun = new Date(mon);
        sun.setDate(mon.getDate() + 6);
        const fmt = d => d.toISOString().slice(0, 10);
        document.getElementById('beginDate').value = fmt(mon);
        document.getElementById('endDate').value   = fmt(sun);
    })();
</script>
