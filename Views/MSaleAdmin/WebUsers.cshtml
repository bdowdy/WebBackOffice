@{
    ViewData["Title"] = "Web Back Office Users";
}

<div class="space-y-6">

    <input type="hidden" id="userId" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <p class="mb-4 text-sm text-slate-500">
            These logins are for this web back office only. Passwords are stored encrypted.
            Leave the password blank when editing to keep the user's current password.
        </p>
        <div class="flex flex-wrap items-center gap-2">

            <input type="text"
                   id="userName"
                   autocomplete="off"
                   class="block w-full max-w-[200px] rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                   placeholder="Username" />

            <input type="password"
                   id="userPassword"
                   autocomplete="new-password"
                   class="block w-full max-w-[200px] rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                   placeholder="Password" />

            <label class="inline-flex items-center gap-2 px-2 text-sm text-slate-700">
                <input type="checkbox" id="userActive" checked
                       class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Active
            </label>

            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                    onclick="saveUser()">
                Save
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50"
                    onclick="clearForm()">
                Clear
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50"
                    onclick="deleteUser()">
                Delete
            </button>

        </div>
    </div>

    <div class="max-h-[500px] overflow-y-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200">

        <table id="usersTable" class="min-w-full divide-y divide-slate-200 text-sm">

            <thead class="sticky top-0 bg-slate-50">
                <tr>
                    <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Username</th>
                    <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                    <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Created</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-slate-100">
            </tbody>

        </table>

    </div>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {
        loadUsers();
    });

    function loadUsers() {

        fetch('/WebUsers/List')
            .then(r => r.json())
            .then(data => {

                let tbody = document.querySelector("#usersTable tbody");
                tbody.innerHTML = "";

                if (data.length === 0) {
                    tbody.innerHTML =
                        `<tr>
                            <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-400">
                                No web users yet. Users added here can sign in alongside the built-in accounts.
                            </td>
                         </tr>`;
                    return;
                }

                data.forEach(function (item) {

                    let tr = document.createElement("tr");
                    tr.className = "cursor-pointer hover:bg-slate-50";
                    tr.onclick = () => editUser(item);

                    let badge = item.isActive
                        ? `<span class="inline-flex rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-200">Active</span>`
                        : `<span class="inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500 ring-1 ring-inset ring-slate-300">Disabled</span>`;

                    tr.innerHTML =
                        `<td class="px-4 py-2.5 font-medium text-slate-700">${item.username}</td>
                         <td class="px-4 py-2.5">${badge}</td>
                         <td class="px-4 py-2.5 text-slate-500">${item.createdAt}</td>`;

                    tbody.appendChild(tr);
                });
            });
    }

    function editUser(item) {
        document.getElementById("userId").value = item.username;
        document.getElementById("userName").value = item.username;
        document.getElementById("userPassword").value = "";
        document.getElementById("userActive").checked = item.isActive;
    }

    function clearForm() {
        document.getElementById("userId").value = "";
        document.getElementById("userName").value = "";
        document.getElementById("userPassword").value = "";
        document.getElementById("userActive").checked = true;
        document.getElementById("userName").focus();
    }

    function saveUser() {

        let oldUsername = document.getElementById("userId").value;
        let username = document.getElementById("userName").value;
        let password = document.getElementById("userPassword").value;
        let isActive = document.getElementById("userActive").checked;

        if (username.trim() === "") {
            alert("Please enter a username.");
            return;
        }

        if (oldUsername === "" && password.trim() === "") {
            alert("Please enter a password for the new user.");
            return;
        }

        fetch('/WebUsers/Save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                oldUsername: oldUsername,
                username: username,
                password: password,
                isActive: isActive
            })
        })
        .then(r => r.text())
        .then(msg => {
            alert(msg);
            if (msg === "Saved Successfully") {
                clearForm();
                loadUsers();
            }
        });
    }

    function deleteUser() {

        let username = document.getElementById("userId").value;

        if (!username) {
            alert("Select a user first.");
            return;
        }

        if (!confirm("Delete user '" + username + "'? They will no longer be able to sign in."))
            return;

        fetch('/WebUsers/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: username })
        })
        .then(r => r.text())
        .then(msg => {
            alert(msg);
            clearForm();
            loadUsers();
        });
    }

</script>
