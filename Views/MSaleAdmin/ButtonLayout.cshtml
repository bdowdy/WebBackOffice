@{
    ViewData["Title"] = "Button Layout";
    ViewData["Subtitle"] = "Drag, resize, and assign menu items to POS buttons for each category.";
}

<div class="space-y-4">

    <div class="flex flex-wrap items-center gap-2 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
        <label class="text-sm font-medium text-slate-700">Category</label>
        <select id="categorySelect" onchange="loadLayout()" class="rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

        <button type="button" onclick="loadLayout()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Reload</button>
        <button type="button" onclick="addBlankButton()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Add Blank Button</button>
        <button type="button" onclick="assignSelectedItem()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Put Menu Item On Button</button>
        <button type="button" onclick="deleteSelectedButton()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50">Delete Selected</button>

        <div class="flex-1"></div>

        <button type="button" onclick="location.href='/'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Exit</button>
        <button type="button" onclick="saveLayout()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save Layout</button>
    </div>

    <div class="grid items-start gap-4 xl:grid-cols-[260px_minmax(0,1fr)_280px]">

        <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Menu Items</h3>
            <select id="itemList" size="30" class="mt-3 block h-[800px] w-full rounded-lg border-0 bg-white p-1 text-[15px] shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
        </div>

        <div class="overflow-x-auto rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Button Layout Area</h3>
            <div id="canvas" class="relative mt-3 h-[820px] w-[1250px] overflow-hidden rounded-lg border-2 border-[#444444] bg-[#1b1b1b] bg-[linear-gradient(rgba(255,255,255,.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.06)_1px,transparent_1px)] bg-[length:20px_20px]"></div>
            <div class="mt-3 flex items-center justify-between text-xs text-slate-500">
                <span id="statusButtons">0 buttons</span>
                <span id="statusSelected">No button selected</span>
            </div>
        </div>

        <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Selected Button</h3>

            <div class="mt-3 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Menu Item</label>
                    <input id="editMenuItem" onchange="applyEditor()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Font Size</label>
                    <input id="editFontSize" type="number" value="12" onchange="applyEditor()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Text Color</label>
                    <input id="editForeCol" type="color" value="#000000" onchange="applyEditor()" class="mt-1 block h-10 w-full cursor-pointer rounded-lg border-0 bg-white p-1 shadow-sm ring-1 ring-inset ring-slate-300" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Button Color</label>
                    <input id="editBackCol" type="color" value="#d9d9d9" onchange="applyEditor()" class="mt-1 block h-10 w-full cursor-pointer rounded-lg border-0 bg-white p-1 shadow-sm ring-1 ring-inset ring-slate-300" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Icon</label>
                    <input id="editIcon" onchange="applyEditor()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <button type="button" onclick="applyEditor()" class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Apply Changes</button>
            </div>
        </div>

    </div>
</div>

<script>
    let buttons = [];
    let selectedIndex = -1;

    let dragging = null;
    let resizing = null;
    let offsetX = 0;
    let offsetY = 0;

    // "menu-btn", "resize", and "selected" are kept as functional markers queried by this script;
    // the Tailwind utilities alongside them provide the visual styling.
    const MENU_BTN_CLASSES = "menu-btn absolute flex min-h-[35px] min-w-[60px] cursor-move select-none items-center justify-center overflow-hidden rounded-md border border-white p-1 text-center font-bold";
    const RESIZE_CLASSES = "resize absolute bottom-0 right-0 h-3.5 w-3.5 cursor-se-resize bg-[#ffff00]";
    const SELECTED_CLASSES = ["outline", "outline-[3px]", "outline-[#ffff00]"];

    document.addEventListener("DOMContentLoaded", function () {
        loadCategories();
        loadMenuItems();
    });

    function loadCategories() {
        fetch('/MSaleAdmin/GetButtonLayoutCategories')
            .then(r => r.json())
            .then(data => {
                const sel = document.getElementById("categorySelect");
                sel.innerHTML = "";
                sel.add(new Option("-- Select Category --", ""));

                data.forEach(x => sel.add(new Option(x, x)));

                if (data.length > 0) {
                    sel.value = data[0];
                    loadLayout();
                }
            })
            .catch(err => alert("Could not load categories: " + err.message));
    }

    function loadMenuItems() {
        fetch('/MSaleAdmin/GetButtonLayoutMenuItems')
            .then(r => r.json())
            .then(data => {
                const list = document.getElementById("itemList");
                list.innerHTML = "";

                data.forEach(x => list.add(new Option(x, x)));
            })
            .catch(err => alert("Could not load menu items: " + err.message));
    }

    function loadLayout() {
        const category = document.getElementById("categorySelect").value;
        if (!category) return;

        fetch('/MSaleAdmin/GetButtonLayout?category=' + encodeURIComponent(category))
            .then(r => r.json())
            .then(data => {
                buttons = data.buttons || data || [];

                selectedIndex = -1;
                drawButtons();
                clearEditor();
                updateStatus();
            })
            .catch(err => alert("Could not load layout: " + err.message));
    }

    function drawButtons() {
        const canvas = document.getElementById("canvas");
        canvas.innerHTML = "";

        buttons.forEach((b, index) => {
            const btn = document.createElement("div");
            btn.className = MENU_BTN_CLASSES;
            btn.dataset.index = index;

            if (index === selectedIndex) {
                btn.classList.add("selected", ...SELECTED_CLASSES);
            }

            btn.style.left = (b.left || 20) + "px";
            btn.style.top = (b.top || 20) + "px";
            btn.style.width = (b.width || 120) + "px";
            btn.style.height = (b.height || 55) + "px";
            btn.style.fontSize = (b.fontSize || 12) + "px";
            btn.style.color = vbColorToHex(b.foreCol || 0);
            btn.style.backgroundColor = vbColorToHex(b.backCol || 12632256);
            btn.innerText = b.menuItem || "";

            const resize = document.createElement("div");
            resize.className = RESIZE_CLASSES;

            resize.onmousedown = function (e) {
                e.stopPropagation();

                selectedIndex = index;
                resizing = btn;

                loadEditor();
                markSelectedButton();

                document.onmousemove = resizeMove;
                document.onmouseup = stopMouse;
            };

            btn.appendChild(resize);

            btn.onmousedown = function (e) {
                if (e.target.classList.contains("resize")) return;

                selectedIndex = index;
                dragging = btn;

                offsetX = e.clientX - btn.offsetLeft;
                offsetY = e.clientY - btn.offsetTop;

                loadEditor();
                markSelectedButton();

                document.onmousemove = dragMove;
                document.onmouseup = stopMouse;

                e.preventDefault();
            };

            canvas.appendChild(btn);
        });

        updateStatus();
    }

    function markSelectedButton() {
        document.querySelectorAll(".menu-btn").forEach(x => {
            x.classList.remove("selected", ...SELECTED_CLASSES);
        });

        if (selectedIndex >= 0) {
            const btn = document.querySelector('.menu-btn[data-index="' + selectedIndex + '"]');
            if (btn) btn.classList.add("selected", ...SELECTED_CLASSES);
        }

        updateStatus();
    }

    function dragMove(e) {
        if (!dragging || selectedIndex < 0) return;

        const canvas = document.getElementById("canvas");

        let x = e.clientX - offsetX;
        let y = e.clientY - offsetY;

        x = Math.max(0, Math.min(x, canvas.offsetWidth - dragging.offsetWidth));
        y = Math.max(0, Math.min(y, canvas.offsetHeight - dragging.offsetHeight));

        dragging.style.left = x + "px";
        dragging.style.top = y + "px";

        buttons[selectedIndex].left = Math.round(x);
        buttons[selectedIndex].top = Math.round(y);

        updateStatus();
    }

    function resizeMove(e) {
        if (!resizing || selectedIndex < 0) return;

        const rect = resizing.getBoundingClientRect();

        let w = e.clientX - rect.left;
        let h = e.clientY - rect.top;

        w = Math.max(60, w);
        h = Math.max(35, h);

        resizing.style.width = w + "px";
        resizing.style.height = h + "px";

        buttons[selectedIndex].width = Math.round(w);
        buttons[selectedIndex].height = Math.round(h);

        updateStatus();
    }

    function stopMouse() {
        dragging = null;
        resizing = null;
        document.onmousemove = null;
        document.onmouseup = null;
    }

    function addBlankButton() {
        const category = document.getElementById("categorySelect").value;

        if (!category) {
            alert("Select a category first.");
            return;
        }

        buttons.push({
            menuItem: "",
            category: category,
            foreCol: 0,
            backCol: 12632256,
            icon: "",
            width: 120,
            height: 55,
            fontSize: 12,
            left: 20,
            top: 20,
            buttonAssigned: buttons.length
        });

        selectedIndex = buttons.length - 1;
        drawButtons();
        loadEditor();
    }

    function assignSelectedItem() {
        const item = document.getElementById("itemList").value;

        if (!item) {
            alert("Select a menu item first.");
            return;
        }

        if (selectedIndex < 0) {
            addBlankButton();
        }

        if (selectedIndex < 0) return;

        buttons[selectedIndex].menuItem = item;
        document.getElementById("editMenuItem").value = item;

        drawButtons();
        updateStatus();
    }

    function deleteSelectedButton() {
        if (selectedIndex < 0) {
            alert("Select a button first.");
            return;
        }

        buttons.splice(selectedIndex, 1);
        selectedIndex = -1;

        drawButtons();
        clearEditor();
        updateStatus();
    }

    function loadEditor() {
        if (selectedIndex < 0) {
            clearEditor();
            return;
        }

        const b = buttons[selectedIndex];

        document.getElementById("editMenuItem").value = b.menuItem || "";
        document.getElementById("editFontSize").value = b.fontSize || 12;
        document.getElementById("editForeCol").value = vbColorToHex(b.foreCol || 0);
        document.getElementById("editBackCol").value = vbColorToHex(b.backCol || 12632256);
        document.getElementById("editIcon").value = b.icon || "";
    }

    function applyEditor() {
        if (selectedIndex < 0) return;

        const b = buttons[selectedIndex];

        b.menuItem = document.getElementById("editMenuItem").value;
        b.fontSize = parseInt(document.getElementById("editFontSize").value || 12);
        b.foreCol = hexToVbColor(document.getElementById("editForeCol").value).toString();
        b.backCol = hexToVbColor(document.getElementById("editBackCol").value).toString();
        b.icon = document.getElementById("editIcon").value;

        drawButtons();
    }

    function clearEditor() {
        document.getElementById("editMenuItem").value = "";
        document.getElementById("editFontSize").value = "12";
        document.getElementById("editForeCol").value = "#000000";
        document.getElementById("editBackCol").value = "#d9d9d9";
        document.getElementById("editIcon").value = "";
    }

    function saveLayout() {
        if (selectedIndex >= 0) {
            applyEditor();
        }

        const category = document.getElementById("categorySelect").value;

        if (!category) {
            alert("Select a category first.");
            return;
        }

        const cleanButtons = buttons.map((b, i) => ({
            menuItem: b.menuItem || "",
            category: category,
            foreCol: String(b.foreCol || "0"),
            backCol: String(b.backCol || "12632256"),
            icon: b.icon || "",
            width: parseInt(b.width || 120),
            height: parseInt(b.height || 55),
            fontSize: parseInt(b.fontSize || 12),
            left: parseInt(b.left || 20),
            top: parseInt(b.top || 20),
            buttonAssigned: i
        }));

        fetch('/MSaleAdmin/SaveButtonLayout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                category: category,
                buttons: cleanButtons
            })
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"))
        .catch(err => alert("Save failed: " + err.message));
    }

    function updateStatus() {
        document.getElementById("statusButtons").innerText =
            buttons.length + " buttons";

        if (selectedIndex < 0) {
            document.getElementById("statusSelected").innerText =
                "No button selected";
        } else {
            const b = buttons[selectedIndex];
            document.getElementById("statusSelected").innerText =
                "Selected: " + (b.menuItem || "Blank Button");
        }
    }

    function vbColorToHex(value) {
        value = Number(value || 0);

        let r = value & 255;
        let g = (value >> 8) & 255;
        let b = (value >> 16) & 255;

        return "#" +
            r.toString(16).padStart(2, "0") +
            g.toString(16).padStart(2, "0") +
            b.toString(16).padStart(2, "0");
    }

    function hexToVbColor(hex) {
        hex = hex.replace("#", "");

        let r = parseInt(hex.substring(0, 2), 16);
        let g = parseInt(hex.substring(2, 4), 16);
        let b = parseInt(hex.substring(4, 6), 16);

        return r + (g * 256) + (b * 65536);
    }
</script>
