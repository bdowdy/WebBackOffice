@{
    ViewData["Title"] = "Daily Specials";
}

<style>
    .daily-page {
        max-width: 760px;
        margin: 25px auto;
        background: #111;
        color: white;
        padding: 22px;
        border: 2px solid #00cc44;
        border-radius: 8px;
        font-family: Arial, sans-serif;
    }

    .daily-box {
        background: #404040;
        border: 1px solid #777;
        padding: 20px;
        margin-top: 15px;
    }

    h2 {
        text-align: center;
        color: #00ffff;
        margin-top: 0;
    }

    .feature-title {
        text-align: center;
        margin-bottom: 18px;
    }

        .feature-title input {
            text-align: center;
            font-weight: bold;
            color: #00ffff;
            background: black;
            border: none;
            font-size: 18px;
            padding: 6px;
            width: 280px;
        }

    .field-row {
        margin-bottom: 18px;
    }

    label {
        display: block;
        font-weight: bold;
        margin-bottom: 5px;
    }

    input.special {
        width: 100%;
        padding: 9px;
        text-align: center;
        font-size: 16px;
    }

    .counter {
        text-align: right;
        font-size: 12px;
        color: #ccc;
        height: 16px;
    }

    .bottom-row {
        display: flex;
        align-items: end;
        justify-content: space-between;
        margin-top: 22px;
        gap: 12px;
    }

    select {
        padding: 8px;
        font-weight: bold;
        width: 220px;
    }

    button {
        padding: 10px 18px;
        font-weight: bold;
        cursor: pointer;
        margin-left: 6px;
    }

    .button-box {
        background: #404040;
        border: 1px solid #00cc44;
        padding: 12px;
    }
</style>

<div class="daily-page">

    <h2>Daily Specials</h2>

    <div class="feature-title">
        <input id="featureCaption" maxlength="30" value="Featuring" />
    </div>

    <div class="daily-box">

        @for (int i = 1; i <= 4; i++)
        {
            <div class="field-row">
                <label>Daily Special #@i</label>
                <div class="counter" id="counter@(i)">50 characters left</div>
                <input id="special@(i)" class="special" maxlength="50" />
            </div>
        }

    </div>

    <div class="bottom-row">

        <div>
            <label>Select Day</label>
            <select id="daySelect" onchange="loadDailySpecial()">
                <option value="Default">Default</option>
                <option value="Sunday">Sunday</option>
                <option value="Monday">Monday</option>
                <option value="Tuesday">Tuesday</option>
                <option value="Wednesday">Wednesday</option>
                <option value="Thursday">Thursday</option>
                <option value="Friday">Friday</option>
                <option value="Saturday">Saturday</option>
            </select>
        </div>

        <div class="button-box">
            <button type="button" onclick="removeDailySpecial()">Remove</button>
            <button type="button" onclick="saveDailySpecial()">Save</button>
            <button type="button" onclick="location.href='/'">Exit</button>
        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        for (let i = 1; i <= 4; i++) {
            let input = document.getElementById("special" + i);
            input.addEventListener("input", function () {
                updateCounter(i);
            });
        }

        loadDailySpecial();
    });

    function updateCounter(i) {
        let input = document.getElementById("special" + i);
        let counter = document.getElementById("counter" + i);
        let left = 50 - input.value.length;
        counter.innerText = left + " characters left";
    }

    function clearFields() {
        for (let i = 1; i <= 4; i++) {
            document.getElementById("special" + i).value = "";
            updateCounter(i);
        }
    }

    function loadDailySpecial() {
        let day = document.getElementById("daySelect").value;

        fetch('/MSaleAdmin/GetDailySpecial?day=' + encodeURIComponent(day))
            .then(r => r.json())
            .then(data => {
                clearFields();

                if (data.error) {
                    alert(data.error);
                    return;
                }

                document.getElementById("featureCaption").value = data.featureCaption || "Featuring";
                document.getElementById("special1").value = data.special1 || "";
                document.getElementById("special2").value = data.special2 || "";
                document.getElementById("special3").value = data.special3 || "";
                document.getElementById("special4").value = data.special4 || "";

                for (let i = 1; i <= 4; i++) {
                    updateCounter(i);
                }
            })
            .catch(err => alert("Could not load daily special: " + err.message));
    }

    function saveDailySpecial() {
        let data = {
            day: document.getElementById("daySelect").value,
            featureCaption: document.getElementById("featureCaption").value,
            special1: document.getElementById("special1").value,
            special2: document.getElementById("special2").value,
            special3: document.getElementById("special3").value,
            special4: document.getElementById("special4").value
        };

        fetch('/MSaleAdmin/SaveDailySpecial', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"))
        .catch(err => alert("Could not save daily special: " + err.message));
    }

    function removeDailySpecial() {
        let day = document.getElementById("daySelect").value;

        if (!confirm("Remove daily specials for " + day + "?")) return;

        fetch('/MSaleAdmin/DeleteDailySpecial?day=' + encodeURIComponent(day), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            clearFields();
            alert(x.message || "Removed");
        })
        .catch(err => alert("Could not remove daily special: " + err.message));
    }
        function loadRemotePrinters() {
        fetch('/MSaleAdmin/GetSystemPrinters')
            .then(r => r.json())
            .then(data => {
                ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"]
                    .forEach(id => {
                        const ddl = document.getElementById(id);

                        ddl.innerHTML = "";
                        ddl.add(new Option("-- None --", ""));

                        data.forEach(name => {
                            ddl.add(new Option(name, name));
                        });
                    });
            })
            .catch(err => alert("Could not load system printers: " + err.message));
    }

</script>