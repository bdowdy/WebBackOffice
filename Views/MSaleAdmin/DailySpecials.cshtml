@{
    ViewData["Title"] = "Daily Specials";
}

<div class="max-w-xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <input id="featureCaption" maxlength="30" value="Featuring"
               class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-center text-lg font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />

        <div class="mt-6 space-y-5">
            @for (int i = 1; i <= 4; i++)
            {
                <div>
                    <div class="flex items-baseline justify-between gap-2">
                        <label class="block text-sm font-medium text-slate-700">Daily Special #@i</label>
                        <div class="text-xs text-slate-400" id="counter@(i)">50 characters left</div>
                    </div>
                    <input id="special@(i)" maxlength="50"
                           class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            }
        </div>

        <div class="mt-6 flex flex-wrap items-end justify-between gap-4 border-t border-slate-200 pt-5">

            <div class="w-full sm:w-56">
                <label class="block text-sm font-medium text-slate-700">Select Day</label>
                <select id="daySelect" onchange="loadDailySpecial()"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="Default">Default</option>
                    <option value="Sunday">Sunday</option>
                    <option value="Monday">Monday</option>
                    <option value="Tuesday">Tuesday</option>
                    <option value="Wednesday">Wednesday</option>
                    <option value="Thursday">Thursday</option>
                    <option value="Friday">Friday</option>
                    <option value="Saturday">Saturday</option>
                </select>
            </div>

            <div class="flex flex-wrap items-center gap-2">
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="removeDailySpecial()">Remove</button>
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveDailySpecial()">Save</button>
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
            </div>

        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        for (let i = 1; i <= 4; i++) {
            let input = document.getElementById("special" + i);
            input.addEventListener("input", function () {
                updateCounter(i);
            });
        }

        loadDailySpecial();
    });

    function updateCounter(i) {
        let input = document.getElementById("special" + i);
        let counter = document.getElementById("counter" + i);
        let left = 50 - input.value.length;
        counter.innerText = left + " characters left";
    }

    function clearFields() {
        for (let i = 1; i <= 4; i++) {
            document.getElementById("special" + i).value = "";
            updateCounter(i);
        }
    }

    function loadDailySpecial() {
        let day = document.getElementById("daySelect").value;

        fetch('/MSaleAdmin/GetDailySpecial?day=' + encodeURIComponent(day))
            .then(r => r.json())
            .then(data => {
                clearFields();

                if (data.error) {
                    alert(data.error);
                    return;
                }

                document.getElementById("featureCaption").value = data.featureCaption || "Featuring";
                document.getElementById("special1").value = data.special1 || "";
                document.getElementById("special2").value = data.special2 || "";
                document.getElementById("special3").value = data.special3 || "";
                document.getElementById("special4").value = data.special4 || "";

                for (let i = 1; i <= 4; i++) {
                    updateCounter(i);
                }
            })
            .catch(err => alert("Could not load daily special: " + err.message));
    }

    function saveDailySpecial() {
        let data = {
            day: document.getElementById("daySelect").value,
            featureCaption: document.getElementById("featureCaption").value,
            special1: document.getElementById("special1").value,
            special2: document.getElementById("special2").value,
            special3: document.getElementById("special3").value,
            special4: document.getElementById("special4").value
        };

        fetch('/MSaleAdmin/SaveDailySpecial', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"))
        .catch(err => alert("Could not save daily special: " + err.message));
    }

    function removeDailySpecial() {
        let day = document.getElementById("daySelect").value;

        if (!confirm("Remove daily specials for " + day + "?")) return;

        fetch('/MSaleAdmin/DeleteDailySpecial?day=' + encodeURIComponent(day), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            clearFields();
            alert(x.message || "Removed");
        })
        .catch(err => alert("Could not remove daily special: " + err.message));
    }
        function loadRemotePrinters() {
        fetch('/MSaleAdmin/GetSystemPrinters')
            .then(r => r.json())
            .then(data => {
                ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"]
                    .forEach(id => {
                        const ddl = document.getElementById(id);

                        ddl.innerHTML = "";
                        ddl.add(new Option("-- None --", ""));

                        data.forEach(name => {
                            ddl.add(new Option(name, name));
                        });
                    });
            })
            .catch(err => alert("Could not load system printers: " + err.message));
    }

</script>
