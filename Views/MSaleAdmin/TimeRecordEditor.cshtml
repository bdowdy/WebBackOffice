@{
    ViewData["Title"] = "Time Record Editor";
    ViewData["Subtitle"] = "Edit employee punches, breaks, tips, sales, and pay rate.";
}

<div class="space-y-6">

    <input type="hidden" id="recordId" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div>
                <label class="block text-sm font-medium text-slate-700">Employee</label>
                <input id="employeeName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" list="employeeList" />
                <datalist id="employeeList"></datalist>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Department</label>
                <input id="departmentName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Shift Date</label>
                <input id="shiftDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Punch Out Date</label>
                <input id="punchOutDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Time In</label>
                <input id="timeIn" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Break Out</label>
                <input id="breakOut" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Break In</label>
                <input id="breakIn" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Time Out</label>
                <input id="timeOut" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>
        </div>

        <div class="mt-4 grid gap-4 sm:grid-cols-3 lg:grid-cols-6">
            <div>
                <label class="block text-sm font-medium text-slate-700">Rate of Pay</label>
                <input id="rateOfPay" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tip Amount</label>
                <input id="tipAmount" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">CC Tips</label>
                <input id="creditCardTips" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tips Paid Out</label>
                <input id="tipsPaidOut" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tip Share</label>
                <input id="tipShare" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Sales</label>
                <input id="sales" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 pt-4">
            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveRecord()">Save</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteRecord()">Delete</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearEditor()">Clear</button>
        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div>
                <label class="block text-sm font-medium text-slate-700">Begin Date</label>
                <input id="beginDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">End Date</label>
                <input id="endDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Employee Filter</label>
                <input id="filterEmployee" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" list="employeeList" />
            </div>

            <div class="flex items-end">
                <button class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="loadRecords()">Load Records</button>
            </div>
        </div>
    </div>

    <div class="flex flex-wrap gap-3">
        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Records</b><span id="sumRecords" class="text-xl font-bold text-slate-900">0</span></div>
        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Total Hours</b><span id="sumHours" class="text-xl font-bold text-slate-900">0.00</span></div>
        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Sales</b><span id="sumSales" class="text-xl font-bold text-slate-900">0.00</span></div>
        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">CC Tips</b><span id="sumTips" class="text-xl font-bold text-slate-900">0.00</span></div>
    </div>

    <div class="max-h-[520px] overflow-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="sticky top-0 z-10 bg-slate-50">
                <tr>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Employee</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Dept</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Date</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">In</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Break Out</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Break In</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Out</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Hours</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Rate</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Tips</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">CC Tips</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Paid Out</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Sales</th>
                </tr>
            </thead>
            <tbody id="timeBody" class="divide-y divide-slate-100 text-slate-700"></tbody>
        </table>
    </div>

</div>

<script>
    let selectedRow = null;
    let currentData = [];

    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", () => {
        const today = new Date();
        const prior = new Date();
        prior.setDate(today.getDate() - 7);

        beginDate.value = prior.toISOString().substring(0,10);
        endDate.value = today.toISOString().substring(0,10);

        loadEmployees();
        loadRecords();
    });

    function n(v) {
        return Number(v || 0);
    }

    function money(v) {
        return n(v).toFixed(2);
    }

    function calcHours(row) {
        if (!row.shiftDate || !row.timeIn || !row.timeOut)
            return 0;

        const outDate = row.punchOutDate || row.shiftDate;

        let start = new Date(row.shiftDate + "T" + row.timeIn);
        let end = new Date(outDate + "T" + row.timeOut);

        if (end <= start)
            return 0;

        let hours = (end - start) / 3600000;

        if (row.breakOut && row.breakIn) {
            let bo = new Date(row.shiftDate + "T" + row.breakOut);
            let bi = new Date(row.shiftDate + "T" + row.breakIn);

            if (bi > bo)
                hours -= (bi - bo) / 3600000;
        }

        return Math.max(0, hours);
    }

    function loadEmployees() {
        fetch('/TimeRecordsEditor/GetTimeRecordEmployees')
            .then(r => r.json())
            .then(data => {
                employeeList.innerHTML = '';
                data.forEach(name => {
                    const opt = document.createElement('option');
                    opt.value = name;
                    employeeList.appendChild(opt);
                });
            });
    }

    function loadRecords() {
        const b = beginDate.value;
        const e = endDate.value;
        const emp = encodeURIComponent(filterEmployee.value || '');

        fetch(`/TimeRecordsEditor/GetTimeRecords?beginDate=${b}&endDate=${e}&employeeName=${emp}`)
            .then(r => r.json())
            .then(data => {
                currentData = data;
                renderTable();
            });
    }

    function renderTable() {
        timeBody.innerHTML = '';

        let totalHours = 0;
        let totalSales = 0;
        let totalTips = 0;

        currentData.forEach(row => {
            const hrs = calcHours(row);
            totalHours += hrs;
            totalSales += n(row.sales);
            totalTips += n(row.creditCardTips);

            const tr = document.createElement('tr');
            tr.className = 'cursor-pointer hover:bg-slate-50';

            tr.innerHTML = `
                <td class="whitespace-nowrap px-4 py-2.5">${row.employeeName || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.departmentName || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.shiftDate || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.timeIn || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.breakOut || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.breakIn || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${row.timeOut || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(hrs)}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(row.rateOfPay)}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(row.tipAmount)}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(row.creditCardTips)}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(row.tipsPaidOut)}</td>
                <td class="whitespace-nowrap px-4 py-2.5">${money(row.sales)}</td>
            `;

            tr.onclick = () => selectRecord(row, tr);
            timeBody.appendChild(tr);
        });

        sumRecords.textContent = currentData.length;
        sumHours.textContent = money(totalHours);
        sumSales.textContent = money(totalSales);
        sumTips.textContent = money(totalTips);
    }

    function selectRecord(row, tr) {
        if (selectedRow)
            selectedRow.classList.remove('selected', ...SEL);

        selectedRow = tr;
        tr.classList.add('selected', ...SEL);

        recordId.value = row.recordId || '';
        employeeName.value = row.employeeName || '';
        departmentName.value = row.departmentName || '';
        shiftDate.value = row.shiftDate || '';
        punchOutDate.value = row.punchOutDate || row.shiftDate || '';
        timeIn.value = row.timeIn || '';
        breakOut.value = row.breakOut || '';
        breakIn.value = row.breakIn || '';
        timeOut.value = row.timeOut || '';
        rateOfPay.value = row.rateOfPay || 0;
        tipAmount.value = row.tipAmount || 0;
        creditCardTips.value = row.creditCardTips || 0;
        tipsPaidOut.value = row.tipsPaidOut || 0;
        tipShare.value = row.tipShare || 0;
        sales.value = row.sales || 0;
    }

    function saveRecord() {
        const item = getEditorData();

        if (!item.employeeName.trim()) {
            alert("Employee name is required.");
            return;
        }

        if (!item.shiftDate) {
            alert("Shift date is required.");
            return;
        }

        fetch('/TimeRecordsEditor/SaveTimeRecord', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadRecords();
            clearEditor();
        });
    }

    function deleteRecord() {
        if (!recordId.value) {
            alert("Select a record to delete.");
            return;
        }

        if (!confirm("Delete this time record?"))
            return;

        fetch('/TimeRecordsEditor/DeleteTimeRecord', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ recordId: recordId.value })
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadRecords();
            clearEditor();
        });
    }

    function getEditorData() {
        return {
            recordId: recordId.value,
            employeeName: employeeName.value,
            departmentName: departmentName.value,
            shiftDate: shiftDate.value,
            punchOutDate: punchOutDate.value || shiftDate.value,
            timeIn: timeIn.value,
            breakOut: breakOut.value,
            breakIn: breakIn.value,
            timeOut: timeOut.value,
            rateOfPay: n(rateOfPay.value),
            tipAmount: n(tipAmount.value),
            creditCardTips: n(creditCardTips.value),
            tipsPaidOut: n(tipsPaidOut.value),
            tipShare: n(tipShare.value),
            sales: n(sales.value),
            shift: 0
        };
    }

    function clearEditor() {
        recordId.value = '';
        employeeName.value = '';
        departmentName.value = '';
        shiftDate.value = '';
        punchOutDate.value = '';
        timeIn.value = '';
        breakOut.value = '';
        breakIn.value = '';
        timeOut.value = '';
        rateOfPay.value = 0;
        tipAmount.value = 0;
        creditCardTips.value = 0;
        tipsPaidOut.value = 0;
        tipShare.value = 0;
        sales.value = 0;

        if (selectedRow) {
            selectedRow.classList.remove('selected', ...SEL);
            selectedRow = null;
        }
    }
</script>
