@{
    ViewData["Title"] = "Refund Reasons";
}

<div class="space-y-6">

    <input type="hidden" id="refundId" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="flex flex-wrap items-center gap-2">

            <input type="text"
                   id="refundName"
                   class="block w-full max-w-sm rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                   placeholder="Enter Refund Reason" />

            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                    onclick="saveRefundReason()">
                Save
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50"
                    onclick="clearForm()">
                Clear
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50"
                    onclick="deleteRefundReason()">
                Delete
            </button>

        </div>
    </div>

    <div class="max-h-[500px] overflow-y-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200">

        <table id="refundTable" class="min-w-full divide-y divide-slate-200 text-sm">

            <thead class="sticky top-0 bg-slate-50">
                <tr>
                    <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Refund Name</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-slate-100">
            </tbody>

        </table>

    </div>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {
        loadRefundReasons();
    });

    function loadRefundReasons() {

        fetch('/MSaleAdmin/GetRefundReasons')
            .then(r => r.json())
            .then(data => {

                let tbody = document.querySelector("#refundTable tbody");

                tbody.innerHTML = "";

                if (data.length === 0) {

                    tbody.innerHTML =
                        `<tr>
                            <td class="px-4 py-8 text-center text-sm text-slate-400">
                                No Refund Reasons Found
                            </td>
                         </tr>`;

                    return;
                }

                data.forEach(function (item) {

                    let tr = document.createElement("tr");

                    tr.className = "cursor-pointer hover:bg-slate-50";

                    tr.innerHTML =
                        `<td class="px-4 py-2.5 text-slate-700" onclick="editRefundReason('${item.refundName}')">
                            ${item.refundName}
                         </td>`;

                    tbody.appendChild(tr);

                });

            });

    }

    function editRefundReason(name) {

        document.getElementById("refundId").value = name;
        document.getElementById("refundName").value = name;

    }

    function clearForm() {

        document.getElementById("refundId").value = "";
        document.getElementById("refundName").value = "";

        document.getElementById("refundName").focus();

    }

    function saveRefundReason() {

        let oldName =
            document.getElementById("refundId").value;

        let refundName =
            document.getElementById("refundName").value;

        if (refundName.trim() === "") {

            alert("Please enter a Refund Name.");
            return;

        }

        fetch('/MSaleAdmin/SaveRefundReason', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                oldName: oldName,
                refundName: refundName
            })

        })
        .then(r => r.text())
        .then(msg => {

            alert(msg);

            clearForm();
            loadRefundReasons();

        });

    }

    function deleteRefundReason() {

        let refundName =
            document.getElementById("refundId").value;

        if (!refundName) {

            alert("Select a Refund Reason first.");
            return;

        }

        if (!confirm("Delete this Refund Reason?"))
            return;

        fetch('/MSaleAdmin/DeleteRefundReason', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                refundName: refundName
            })

        })
        .then(r => r.text())
        .then(msg => {

            alert(msg);

            clearForm();
            loadRefundReasons();

        });

    }

</script>
