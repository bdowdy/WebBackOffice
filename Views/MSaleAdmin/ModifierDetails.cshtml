@{
    ViewData["Title"] = "Modifier Details";
    ViewData["Subtitle"] = "Maintain item details, costs, taxes, and remote printers for each modifier.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-3 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
        <label for="modifierSelect" class="text-sm font-medium text-slate-700">Modifier Name</label>
        <select id="modifierSelect" onchange="loadItems()" class="w-72 rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadItems()">Reload</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="newItem()">New Item</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveItem()">Save</button>

        <div class="flex-1"></div>

        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/MSaleAdmin'">Dashboard</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[320px_1fr]">
        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Modifier Items</h3>
            <select id="itemList" size="30" onchange="loadEditor()" class="mt-3 block w-full rounded-lg border-0 bg-white p-1 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
            <div id="itemStatus" class="mt-3 text-sm font-medium text-slate-500"></div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Selected Modifier Item</h3>

            <input type="hidden" id="originalModifierName" />
            <input type="hidden" id="originalModifierCategory" />

            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Modifier Category</label>
                    <input id="modifierCategory" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Modifier Cost</label>
                    <input id="modifierCost" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Item Cost</label>
                    <input id="itemCost" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Price Level</label>
                    <input id="priceLevel" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Selection Quantity</label>
                    <input id="selectionQuantity" type="number" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">PLU</label>
                    <input id="plu" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Alias</label>
                    <input id="alias" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Comes With</label>
                    <input id="comesWith" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Alt Modifier</label>
                    <input id="altModifier" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <h3 class="mt-6 text-base font-semibold text-slate-900">Taxes</h3>

            <div class="mt-4 grid gap-4 sm:grid-cols-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Sales Tax</label>
                    <select id="salesTax" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Special Tax</label>
                    <select id="specialTax" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Liquor Tax</label>
                    <select id="liquorTax" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
            </div>

            <h3 class="mt-6 text-base font-semibold text-slate-900">Remote Printers</h3>

            <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 1</label>
                    <select id="remote1" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 2</label>
                    <select id="remote2" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 3</label>
                    <select id="remote3" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 4</label>
                    <select id="remote4" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 5</label>
                    <select id="remote5" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Remote Printer 6</label>
                    <select id="remote6" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
            </div>

            <button type="button" class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveItem()">
                Save Modifier Item
            </button>
        </div>
    </div>
</div>

<script>
    let items = [];
    let selectedIndex = -1;
    let isNewItem = false;

    document.addEventListener("DOMContentLoaded", function () {
        loadTaxLists();
        loadRemotePrinters();
        loadModifierNames();
    });

    function loadTaxLists() {
        ["salesTax", "specialTax", "liquorTax"].forEach(id => {
            const ddl = document.getElementById(id);
            ddl.innerHTML = "";

            for (let i = 0; i <= 5; i++) {
                ddl.add(new Option(i.toString(), i.toString()));
            }
        });
    }

    function loadRemotePrinters() {
        fetch('/ModifierDetails/GetSystemPrinters')
            .then(r => r.json())
            .then(data => {
                ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"].forEach(id => {
                    const ddl = document.getElementById(id);
                    ddl.innerHTML = "";
                    ddl.add(new Option("-- None --", ""));

                    data.forEach(name => {
                        ddl.add(new Option(name, name));
                    });
                });
            })
            .catch(err => alert("Could not load system printers: " + err.message));
    }

    function loadModifierNames() {
        fetch('/ModifierDetails/GetModifierNames')
            .then(r => r.json())
            .then(data => {
                const sel = document.getElementById("modifierSelect");
                sel.innerHTML = "";
                sel.add(new Option("-- Select Modifier --", ""));

                data.forEach(x => {
                    sel.add(new Option(x, x));
                });

                if (data.length > 0) {
                    sel.value = data[0];
                    loadItems();
                }
            })
            .catch(err => alert("Could not load modifier names: " + err.message));
    }

    function loadItems() {
        const modifierName = document.getElementById("modifierSelect").value;

        if (!modifierName) {
            items = [];
            selectedIndex = -1;
            isNewItem = false;
            drawItems();
            clearEditor();
            return;
        }

        fetch('/ModifierDetails/GetModifierDetailItems?modifierName=' + encodeURIComponent(modifierName))
            .then(r => r.json())
            .then(data => {
                items = data || [];
                selectedIndex = -1;
                isNewItem = false;
                drawItems();
            })
            .catch(err => alert("Could not load modifier items: " + err.message));
    }

    function drawItems() {
        const list = document.getElementById("itemList");
        const status = document.getElementById("itemStatus");

        list.innerHTML = "";

        items.forEach((x, i) => {
            list.add(new Option(x.modifierCategory || "", i.toString()));
        });

        status.innerText = items.length + " item(s) loaded";

        if (items.length > 0) {
            list.selectedIndex = 0;
            selectedIndex = 0;
            loadEditor();
        } else {
            selectedIndex = -1;
            clearEditor();
        }
    }

    function loadEditor() {
        const list = document.getElementById("itemList");

        if (list.selectedIndex < 0 || list.selectedIndex >= items.length) {
            selectedIndex = -1;
            clearEditor();
            return;
        }

        isNewItem = false;
        selectedIndex = list.selectedIndex;

        const x = items[selectedIndex];

        document.getElementById("originalModifierName").value = x.modifierName || "";
        document.getElementById("originalModifierCategory").value = x.modifierCategory || "";

        document.getElementById("modifierCategory").value = x.modifierCategory || "";
        document.getElementById("modifierCost").value = x.modifierCost ?? 0;
        document.getElementById("itemCost").value = x.itemCost ?? 0;
        document.getElementById("priceLevel").value = x.priceLevel || "";
        document.getElementById("selectionQuantity").value = x.selectionQuantity ?? 0;
        document.getElementById("plu").value = x.plu || "";
        document.getElementById("alias").value = x.alias || "";
        document.getElementById("comesWith").value = x.comesWith || "";
        document.getElementById("altModifier").value = x.altModifier || "";

        document.getElementById("salesTax").value = x.salesTax ?? 0;
        document.getElementById("specialTax").value = x.specialTax ?? 0;
        document.getElementById("liquorTax").value = x.liquorTax ?? 0;

        document.getElementById("remote1").value = x.remotePrinter1 || "";
        document.getElementById("remote2").value = x.remotePrinter2 || "";
        document.getElementById("remote3").value = x.remotePrinter3 || "";
        document.getElementById("remote4").value = x.remotePrinter4 || "";
        document.getElementById("remote5").value = x.remotePrinter5 || "";
        document.getElementById("remote6").value = x.remotePrinter6 || "";

        document.getElementById("itemStatus").innerText = "Editing existing item";
    }

    function newItem() {
        const modifierName = document.getElementById("modifierSelect").value;

        if (!modifierName) {
            alert("Select a modifier name first.");
            return;
        }

        isNewItem = true;
        selectedIndex = -1;

        document.getElementById("itemList").selectedIndex = -1;
        clearEditor();

        document.getElementById("itemStatus").innerText = "Adding new item";
        document.getElementById("modifierCategory").focus();
    }

    function clearEditor() {
        document.getElementById("originalModifierName").value = "";
        document.getElementById("originalModifierCategory").value = "";

        document.getElementById("modifierCategory").value = "";
        document.getElementById("modifierCost").value = "0";
        document.getElementById("itemCost").value = "0";
        document.getElementById("priceLevel").value = "";
        document.getElementById("selectionQuantity").value = "0";
        document.getElementById("plu").value = "";
        document.getElementById("alias").value = "";
        document.getElementById("comesWith").value = "";
        document.getElementById("altModifier").value = "";

        document.getElementById("salesTax").value = "0";
        document.getElementById("specialTax").value = "0";
        document.getElementById("liquorTax").value = "0";

        ["remote1", "remote2", "remote3", "remote4", "remote5", "remote6"].forEach(id => {
            document.getElementById(id).value = "";
        });
    }

    function saveItem() {
        const modifierName = document.getElementById("modifierSelect").value;
        const modifierCategory = document.getElementById("modifierCategory").value.trim();

        if (!modifierName) {
            alert("Select a modifier name first.");
            return;
        }

        if (!modifierCategory) {
            alert("Enter a modifier category.");
            return;
        }

        const model = {
            isNewItem: isNewItem,

            modifierName: modifierName,
            modifierCategory: modifierCategory,

            originalModifierName: document.getElementById("originalModifierName").value,
            originalModifierCategory: document.getElementById("originalModifierCategory").value,

            modifierCost: parseFloat(document.getElementById("modifierCost").value || 0),
            itemCost: parseFloat(document.getElementById("itemCost").value || 0),

            salesTax: parseInt(document.getElementById("salesTax").value || 0),
            specialTax: parseInt(document.getElementById("specialTax").value || 0),
            liquorTax: parseInt(document.getElementById("liquorTax").value || 0),

            remotePrinter1: document.getElementById("remote1").value,
            remotePrinter2: document.getElementById("remote2").value,
            remotePrinter3: document.getElementById("remote3").value,
            remotePrinter4: document.getElementById("remote4").value,
            remotePrinter5: document.getElementById("remote5").value,
            remotePrinter6: document.getElementById("remote6").value,

            priceLevel: document.getElementById("priceLevel").value,
            altModifier: document.getElementById("altModifier").value,
            selectionQuantity: parseInt(document.getElementById("selectionQuantity").value || 0),
            alias: document.getElementById("alias").value,
            comesWith: document.getElementById("comesWith").value,
            plu: document.getElementById("plu").value
        };

        fetch('/ModifierDetails/SaveModifierDetailItem', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(model)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");

            if (x.success === true) {
                isNewItem = false;
                loadItems();
            }
        })
        .catch(err => alert("Save failed: " + err.message));
    }
</script>
