@{
    ViewData["Title"] = "Time Clock Messages";
    ViewData["Subtitle"] = "Send employee messages for time clock display.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadEmployees()">Individual Message</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadDepartments()">Department Message</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="selectAllEmployees()">Select All Employees</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadUndelivered()">Undelivered Messages</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Delivery Date</label>
                    <input id="deliveryDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Message</label>
                    <textarea id="messageText" maxlength="255" class="mt-1 block min-h-[340px] w-full resize-y rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">None</textarea>
                </div>

                <div class="flex flex-wrap items-center gap-2 pt-2">
                    <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveMessages()">Save Message</button>
                    <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteMessages()">Delete Selected</button>
                    <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearMessage()">Clear</button>
                </div>

                <div id="messagePreview" class="min-h-[120px] whitespace-pre-wrap rounded-lg bg-slate-50 p-4 text-sm text-slate-700 ring-1 ring-slate-200"></div>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="mb-3 flex items-center justify-between">
                <h5 id="listTitle" class="text-base font-semibold text-slate-900">Employees</h5>
                <span id="recordCount" class="text-sm text-slate-500"></span>
            </div>

            <div id="nameList" class="max-h-[420px] divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
        </div>

    </div>

</div>

<script>
    let currentMode = "employee";

    document.addEventListener("DOMContentLoaded", function () {
        deliveryDate.value = new Date().toISOString().substring(0, 10);
        loadEmployees();
    });

    function checkedNames() {
        return [...document.querySelectorAll('.name-check:checked')].map(x => x.value);
    }

    function renderNames(names, title) {
        listTitle.textContent = title;
        recordCount.textContent = `${names.length} record${names.length === 1 ? '' : 's'}`;
        nameList.innerHTML = '';

        names.forEach(name => {
            const div = document.createElement('div');
            div.className = 'flex cursor-pointer items-center gap-3 px-4 py-2.5 text-sm hover:bg-slate-50';

            div.innerHTML = `
                <input type="checkbox" class="name-check h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" value="${name}">
                <span>${name}</span>
            `;

            div.ondblclick = function () {
                const cb = div.querySelector('input');
                cb.checked = true;

                if (currentMode === "undelivered") {
                    loadEmployeeMessages(name);
                }
            };

            nameList.appendChild(div);
        });
    }

    function loadEmployees() {
        currentMode = "employee";

        fetch('/TimeMessages/GetTimeMessageEmployees')
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderNames(result.data, "Employees");
            });
    }

    function loadDepartments() {
        currentMode = "department";

        fetch('/TimeMessages/GetTimeMessageDepartments')
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderNames(result.data, "Departments");
            });
    }

    function selectAllEmployees() {
        currentMode = "employee";

        fetch('/TimeMessages/GetTimeMessageEmployees')
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderNames(result.data, "All Employees");

                document.querySelectorAll('.name-check').forEach(x => x.checked = true);
            });
    }

    function loadUndelivered() {
        currentMode = "undelivered";

        fetch('/TimeMessages/GetUndeliveredMessageNames')
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderNames(result.data, "Undelivered Messages");
            });
    }

    function loadEmployeeMessages(name) {
        fetch('/TimeMessages/GetMessagesForEmployee?name=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                let text = '';

                result.data.forEach(x => {
                    text += `${x.date}\n${x.message}\nFrom ${x.messageFrom}\n\n`;
                });

                messagePreview.textContent = text || 'No messages found.';
            });
    }

    function saveMessages() {
        const names = checkedNames();

        if (names.length === 0) {
            alert("Select at least one name.");
            return;
        }

        const item = {
            deliveryDate: deliveryDate.value,
            message: messageText.value,
            messageFrom: "MSaleWebServer",
            names: names
        };

        fetch('/TimeMessages/SaveTimeMessages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");

            if (result.success) {
                messageText.value = "None";
            }
        });
    }

    function deleteMessages() {
        const names = checkedNames();

        if (names.length === 0) {
            alert("Select a name to delete.");
            return;
        }

        if (!confirm("Delete messages for selected name(s)?"))
            return;

        fetch('/TimeMessages/DeleteTimeMessages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ names: names })
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadUndelivered();
            messagePreview.textContent = "";
        });
    }

    function clearMessage() {
        if (confirm("Clear message box?")) {
            messageText.value = "None";
        }
    }
</script>
