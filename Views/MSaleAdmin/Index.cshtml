@{
    ViewData["Title"] = "Programming Dashboard";
    ViewData["Subtitle"] = "Add, edit, and manage POS setup records.";
}

<div class="mb-6">
    <div class="relative max-w-md">
        <svg class="pointer-events-none absolute left-3 top-2.5 h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <input id="dash-search" type="search" placeholder="Search settings…"
               class="w-full rounded-lg border-0 bg-white py-2 pl-9 pr-3 text-sm shadow-sm ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
    </div>
</div>

<div class="space-y-10">
    @foreach (var s in AdminNav.Sections)
    {
        <section id="@s.Id" data-section class="scroll-mt-24">
            <div class="mb-3 flex items-center gap-2.5">
                <span class="flex h-7 w-7 items-center justify-center rounded-md bg-@(s.Accent)-100 text-@(s.Accent)-600">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="@s.Icon" />
                    </svg>
                </span>
                <h2 class="font-display text-sm font-medium uppercase tracking-wider text-slate-600">@s.Name</h2>
                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500">@s.Links.Length</span>
            </div>
            <div class="divide-y divide-slate-100 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200">
                @foreach (var l in s.Links)
                {
                    <a href="@l.Href" data-row data-search="@l.Title.ToLower() @l.Sub.ToLower()"
                       class="group flex items-center gap-4 px-5 py-3.5 transition hover:bg-slate-50">
                        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-@(s.Accent)-50 text-@(s.Accent)-600 ring-1 ring-inset ring-@(s.Accent)-100">
                            <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="@s.Icon" />
                            </svg>
                        </span>
                        <span class="min-w-0 flex-1">
                            <span class="block text-sm font-medium text-slate-900">@l.Title</span>
                            <span class="block truncate text-sm text-slate-500">@l.Sub</span>
                        </span>
                        <svg class="h-4 w-4 shrink-0 text-slate-300 transition group-hover:translate-x-0.5 group-hover:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>
                }
            </div>
        </section>
    }
    <p id="dash-empty" class="hidden py-16 text-center text-sm text-slate-500">No settings match your search.</p>
</div>

<script>
    const search = document.getElementById('dash-search');
    const sections = [...document.querySelectorAll('[data-section]')];
    const empty = document.getElementById('dash-empty');
    search.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        let any = false;
        for (const section of sections) {
            let visible = 0;
            for (const row of section.querySelectorAll('[data-row]')) {
                const show = !q || row.dataset.search.includes(q);
                row.classList.toggle('hidden', !show);
                if (show) visible++;
            }
            section.classList.toggle('hidden', visible === 0);
            if (visible) any = true;
        }
        empty.classList.toggle('hidden', any);
    });
</script>
