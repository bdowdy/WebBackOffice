@{
    ViewData["Title"] = "Tax Setup";
    ViewData["Subtitle"] = "Configure sales tax, special tax, and tax break tables";
}

<div class="space-y-6">

    <!-- TAX BREAK TABLE -->
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2 border-b border-slate-200 pb-3.5">
            <h3 class="text-base font-semibold text-slate-900">Tax Break Table</h3>
            <span class="text-xs text-slate-500">Manage up to 5 tax break tables, 20 rows each</span>
        </div>

        <div class="mb-4 flex flex-wrap items-center gap-4 rounded-lg bg-slate-50 px-3.5 py-3">
            <div class="flex flex-wrap items-center gap-2">
                <span class="mr-1 text-xs font-semibold uppercase tracking-wide text-slate-500">Load</span>
                @for (int i = 1; i <= 5; i++)
                {
                    <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadTaxBreaks(@i)">Table @i</button>
                }
            </div>

            <div class="flex flex-wrap items-center gap-2">
                <span class="mr-1 text-xs font-semibold uppercase tracking-wide text-slate-500">Save</span>
                @for (int i = 1; i <= 5; i++)
                {
                    <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="saveTaxBreaks(@i)">Table @i</button>
                }
            </div>

            <div class="ml-auto flex flex-wrap items-center gap-2">
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteTaxBreakTable()">Delete Table</button>
            </div>
        </div>

        <div class="overflow-x-auto rounded-lg ring-1 ring-slate-200">
            <table id="taxBreakTable" class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="w-16 px-4 py-2.5 text-center text-xs font-semibold uppercase tracking-wide text-slate-500">Row</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">From Amount</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">To Amount</th>
                        <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Tax Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @for (int i = 1; i <= 20; i++)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="bg-slate-50/60 px-4 py-1.5 text-center text-xs font-semibold text-slate-400">@i</td>
                            <td class="px-2 py-1"><input type="number" step="0.01" class="break-start block w-full rounded-md border-0 bg-transparent px-2 py-1.5 text-right text-sm text-slate-700 ring-1 ring-inset ring-transparent placeholder:text-slate-400 hover:ring-slate-300 focus:bg-white focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="0.00" /></td>
                            <td class="px-2 py-1"><input type="number" step="0.01" class="break-end block w-full rounded-md border-0 bg-transparent px-2 py-1.5 text-right text-sm text-slate-700 ring-1 ring-inset ring-transparent placeholder:text-slate-400 hover:ring-slate-300 focus:bg-white focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="0.00" /></td>
                            <td class="px-2 py-1"><input type="number" step="0.01" class="break-tax block w-full rounded-md border-0 bg-transparent px-2 py-1.5 text-right text-sm text-slate-700 ring-1 ring-inset ring-transparent placeholder:text-slate-400 hover:ring-slate-300 focus:bg-white focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="0.00" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- SALES TAX SETUP -->
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2 border-b border-slate-200 pb-3.5">
            <h3 class="text-base font-semibold text-slate-900">Sales Tax Setup</h3>
            <span class="text-xs text-slate-500">Five configurable sales tax tables</span>
        </div>

        <div class="grid grid-cols-2 items-center gap-x-3.5 gap-y-2.5 md:grid-cols-[170px_1fr_180px]">
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Tax Table</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Tax Name</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Sales Tax %</div>

            @for (int i = 1; i <= 5; i++)
            {
                <div class="text-sm font-medium text-slate-600">Sales Tax Table @i</div>
                <input id="taxName@(i)" value="Sales Tax @i" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <input id="salesTax@(i)" type="number" step="0.001" value="0.000" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            }
        </div>
    </div>

    <!-- SPECIAL TAX SETUP -->
    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2 border-b border-slate-200 pb-3.5">
            <h3 class="text-base font-semibold text-slate-900">Special Tax Setup</h3>
            <span class="text-xs text-slate-500">Special rates, caps, and category exceptions</span>
        </div>

        <div class="grid grid-cols-2 items-center gap-x-3.5 gap-y-2.5 lg:grid-cols-[1fr_140px_140px_140px_1fr]">
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Special Tax Table</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">% Amount</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Min Tax $</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Max Tax $</div>
            <div class="border-b border-slate-200 pb-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">Tax Exceptions</div>

            @for (int i = 1; i <= 5; i++)
            {
                <input id="specialTaxName@(i)" value="Special Tax Table @i" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <input id="specialTax@(i)" type="number" step="0.001" value="0.000" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <input id="minTax@(i)" type="number" step="0.01" value="0.00" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <input id="maxTax@(i)" type="number" step="0.01" value="0.00" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <select id="exception@(i)" class="block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="None">None</option>
                    <option value="Food">Food</option>
                    <option value="Liquor">Liquor</option>
                    <option value="Beer">Beer</option>
                    <option value="Wine">Wine</option>
                    <option value="Other">Other</option>
                </select>
            }
        </div>

        <div class="mt-6 flex flex-wrap items-center justify-end gap-2 border-t border-slate-200 pt-5">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTaxSetup()">Save Tax Setup</button>
        </div>
    </div>
</div>

<div class="pointer-events-none fixed right-6 top-6 z-50 flex flex-col gap-2.5" id="toastStack"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadTaxSetup();
    });

    /* ---------- Helpers ---------- */
    function getValue(id) {
        return document.getElementById(id).value;
    }

    function setValue(id, value) {
        let el = document.getElementById(id);
        if (el) el.value = value ?? "";
    }

    function money(value) {
        return Number(value || 0).toFixed(2);
    }

    function percent(value) {
        return Number(value || 0).toFixed(3);
    }

    function toast(message, type) {
        let stack = document.getElementById("toastStack");
        let el = document.createElement("div");
        el.className = "pointer-events-auto min-w-[240px] rounded-lg border-l-4 bg-white px-4 py-3 text-sm text-slate-900 shadow-lg " +
            (type === "error" ? "border-rose-500" : "border-emerald-500");
        el.textContent = message;
        stack.appendChild(el);
        setTimeout(() => {
            el.style.transition = "opacity 0.25s ease, transform 0.25s ease";
            el.style.opacity = "0";
            el.style.transform = "translateX(20px)";
            setTimeout(() => el.remove(), 250);
        }, 2400);
    }

    /* ---------- Load main tax setup ---------- */
    function loadTaxSetup() {
        fetch('/MSaleAdmin/GetTaxSetup')
            .then(r => r.json())
            .then(data => {
                if (data.salesTaxes) {
                    data.salesTaxes.forEach(t => {
                        let n = t.taxTable;
                        setValue('taxName' + n, t.taxName);
                        setValue('salesTax' + n, percent(t.taxAmount));
                    });
                }
                if (data.specialTaxes) {
                    data.specialTaxes.forEach(t => {
                        let n = t.taxTable;
                        setValue('specialTaxName' + n, t.taxName);
                        setValue('specialTax' + n, percent(t.specialTax));
                        setValue('minTax' + n, money(t.minAmount));
                        setValue('maxTax' + n, money(t.maxAmount));
                        setValue('exception' + n, t.exception || 'None');
                    });
                }
            })
            .catch(err => {
                toast('Could not load tax setup.', 'error');
                console.log(err);
            });
    }

    /* ---------- Save sales tax + special tax ---------- */
    function saveTaxSetup() {
        let salesTaxes = [];
        let specialTaxes = [];

        for (let i = 1; i <= 5; i++) {
            salesTaxes.push({
                taxTable: i,
                taxName: getValue('taxName' + i),
                taxAmount: Number(getValue('salesTax' + i) || 0)
            });
            specialTaxes.push({
                taxTable: i,
                taxName: getValue('specialTaxName' + i),
                specialTax: Number(getValue('specialTax' + i) || 0),
                minTax: Number(getValue('minTax' + i) || 0),
                maxTax: Number(getValue('maxTax' + i) || 0),
                exception: getValue('exception' + i)
            });
        }

        fetch('/MSaleAdmin/SaveTaxSetup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ salesTaxes: salesTaxes, specialTaxes: specialTaxes })
        })
        .then(r => r.json())
        .then(x => {
            toast(x.message || 'Tax setup saved.', 'success');
        })
        .catch(err => {
            toast('Could not save tax setup.', 'error');
            console.log(err);
        });
    }

    /* ---------- Tax break table ---------- */
    function loadTaxBreaks(taxTable) {
        fetch('/MSaleAdmin/GetTaxBreaks?taxTable=' + taxTable)
            .then(r => r.json())
            .then(data => {
                clearTaxBreakRows();
                data.forEach((row, index) => {
                    let tr = document.querySelectorAll('#taxBreakTable tbody tr')[index];
                    if (!tr) return;
                    tr.querySelector('.break-start').value = money(row.startAmount);
                    tr.querySelector('.break-end').value = money(row.endAmount);
                    tr.querySelector('.break-tax').value = money(row.taxAmount);
                });
                toast('Loaded Tax Table ' + taxTable, 'success');
            })
            .catch(err => {
                toast('Could not load tax break table.', 'error');
                console.log(err);
            });
    }

    function saveTaxBreaks(taxTable) {
        let rows = [];
        document.querySelectorAll('#taxBreakTable tbody tr').forEach((tr, index) => {
            let startAmount = tr.querySelector('.break-start').value;
            let endAmount = tr.querySelector('.break-end').value;
            let taxAmount = tr.querySelector('.break-tax').value;

            if (startAmount !== "" || endAmount !== "" || taxAmount !== "") {
                rows.push({
                    taxTable: taxTable,
                    rowNumber: index + 1,
                    startAmount: Number(startAmount || 0),
                    endAmount: Number(endAmount || 0),
                    taxAmount: Number(taxAmount || 0)
                });
            }
        });

        fetch('/MSaleAdmin/SaveTaxBreaks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ taxTable: taxTable, rows: rows })
        })
        .then(r => r.json())
        .then(x => {
            toast(x.message || 'Tax break table saved.', 'success');
        })
        .catch(err => {
            toast('Could not save tax break table.', 'error');
            console.log(err);
        });
    }

    function deleteTaxBreakTable() {
        let taxTable = prompt('Enter tax table number to delete: 1 - 5');
        if (!taxTable) return;
        taxTable = Number(taxTable);
        if (taxTable < 1 || taxTable > 5) {
            toast('Invalid tax table number.', 'error');
            return;
        }
        if (!confirm('Delete Tax Break Table ' + taxTable + '?')) return;

        fetch('/MSaleAdmin/DeleteTaxBreaks?taxTable=' + taxTable, {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            clearTaxBreakRows();
            toast(x.message || 'Tax break table deleted.', 'success');
        })
        .catch(err => {
            toast('Could not delete tax break table.', 'error');
            console.log(err);
        });
    }

    function clearTaxBreakRows() {
        document.querySelectorAll('#taxBreakTable tbody input').forEach(i => i.value = "");
    }
</script>
