@{
    ViewData["Title"] = "Suggested Tips";
    ViewData["Subtitle"] = "Program the four suggested tip percentages shown by the POS.";
}

<div class="max-w-3xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Suggested Tip Configuration</h2>
        <p class="mt-1 text-sm text-slate-500">Enter the display text and percentage amount for each tip option.</p>

        <div class="mt-6 space-y-4">

            <div class="grid items-center gap-4 rounded-lg p-4 ring-1 ring-slate-200 sm:grid-cols-[5rem_1fr_10rem]">
                <div class="flex items-center justify-center rounded-lg bg-emerald-50 px-3 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">Tip 1</div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Text</label>
                    <input id="tipName0" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" value="15%" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Percent</label>
                    <input id="tipAmount0" type="number" step="0.01" value="15" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <div class="grid items-center gap-4 rounded-lg p-4 ring-1 ring-slate-200 sm:grid-cols-[5rem_1fr_10rem]">
                <div class="flex items-center justify-center rounded-lg bg-emerald-50 px-3 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">Tip 2</div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Text</label>
                    <input id="tipName1" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" value="18%" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Percent</label>
                    <input id="tipAmount1" type="number" step="0.01" value="18" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <div class="grid items-center gap-4 rounded-lg p-4 ring-1 ring-slate-200 sm:grid-cols-[5rem_1fr_10rem]">
                <div class="flex items-center justify-center rounded-lg bg-emerald-50 px-3 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">Tip 3</div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Text</label>
                    <input id="tipName2" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" value="20%" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Percent</label>
                    <input id="tipAmount2" type="number" step="0.01" value="20" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <div class="grid items-center gap-4 rounded-lg p-4 ring-1 ring-slate-200 sm:grid-cols-[5rem_1fr_10rem]">
                <div class="flex items-center justify-center rounded-lg bg-emerald-50 px-3 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-100">Tip 4</div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Text</label>
                    <input id="tipName3" class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" value="22%" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Percent</label>
                    <input id="tipAmount3" type="number" step="0.01" value="22" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

        </div>

        <div class="mt-6 flex flex-wrap items-center justify-end gap-2 pt-2">
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearTips()">Clear</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteTips()">Delete All</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTips()">Save Tips</button>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadTips();
    });

    function loadTips() {
        fetch('/MSaleAdmin/GetSuggestedTips')
            .then(r => r.json())
            .then(data => {
                for (let i = 0; i < 4; i++) {
                    if (data[i]) {
                        document.getElementById("tipName" + i).value =
                            data[i].name || data[i].Name || "";

                        document.getElementById("tipAmount" + i).value =
                            data[i].amount || data[i].Amount || "0";
                    }
                }
            });
    }

    function saveTips() {
        let tips = [];

        for (let i = 0; i < 4; i++) {
            let name = document.getElementById("tipName" + i).value;
            let amount = document.getElementById("tipAmount" + i).value;

            if (!name.trim()) {
                alert("Enter text for Tip " + (i + 1));
                return;
            }

            tips.push({
                name: name,
                amount: parseFloat(amount || 0)
            });
        }

        fetch('/MSaleAdmin/SaveSuggestedTips', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tips)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Suggested Tips Saved");
            loadTips();
        });
    }

    function deleteTips() {
        if (!confirm("Delete all suggested tips?")) return;

        fetch('/MSaleAdmin/DeleteSuggestedTips', {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Suggested Tips Deleted");
            clearTips();
        });
    }

    function clearTips() {
        for (let i = 0; i < 4; i++) {
            document.getElementById("tipName" + i).value = "";
            document.getElementById("tipAmount" + i).value = "0";
        }
    }
</script>
