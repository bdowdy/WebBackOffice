@{
    ViewData["Title"] = "Suggested Tips";
}

<style>
    body {
        background: #f4f6f9;
    }

    .page {
        max-width: 950px;
        margin: 35px auto;
        background: white;
        padding: 28px;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(0,0,0,.12);
    }

    .header {
        background: #2c3e50;
        color: white;
        padding: 24px;
        border-radius: 14px;
        margin-bottom: 24px;
    }

        .header h2 {
            margin: 0;
            font-size: 32px;
        }

    .section {
        border: 1px solid #e1e5ea;
        background: #fafafa;
        border-radius: 12px;
        padding: 20px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 16px;
    }

    .tip-row {
        display: grid;
        grid-template-columns: 80px 1fr 160px;
        gap: 16px;
        align-items: center;
        margin-bottom: 14px;
        background: white;
        border: 1px solid #dce1e6;
        border-radius: 10px;
        padding: 14px;
    }

    .tip-number {
        background: #3498db;
        color: white;
        font-weight: 700;
        text-align: center;
        padding: 10px;
        border-radius: 8px;
    }

    label {
        font-weight: 700;
        color: #34495e;
        margin-bottom: 6px;
        display: block;
    }

    input {
        width: 100%;
        height: 42px;
        border: 1px solid #cfd6dd;
        border-radius: 8px;
        padding: 0 12px;
        box-sizing: border-box;
        font-size: 15px;
    }

        input:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 5px rgba(52,152,219,.35);
        }

    .required {
        background: #fff8cc;
    }

    .button-bar {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 22px;
    }

    button {
        border: none;
        border-radius: 8px;
        padding: 11px 22px;
        font-weight: 700;
        color: white;
        cursor: pointer;
    }

    .btn-save {
        background: #27ae60;
    }

    .btn-delete {
        background: #e74c3c;
    }

    .btn-clear {
        background: #7f8c8d;
    }

    .hint {
        color: #7f8c8d;
        font-size: 14px;
        margin-bottom: 16px;
    }
</style>

<div class="page">

    <div class="header">
        <h2>Suggested Tips</h2>
        <div>Program the four suggested tip percentages shown by the POS.</div>
    </div>

    <div class="section">
        <div class="section-title">Suggested Tip Configuration</div>
        <div class="hint">Enter the display text and percentage amount for each tip option.</div>

        <div class="tip-row">
            <div class="tip-number">Tip 1</div>
            <div>
                <label>Text</label>
                <input id="tipName0" class="required" value="15%" />
            </div>
            <div>
                <label>Percent</label>
                <input id="tipAmount0" type="number" step="0.01" value="15" />
            </div>
        </div>

        <div class="tip-row">
            <div class="tip-number">Tip 2</div>
            <div>
                <label>Text</label>
                <input id="tipName1" class="required" value="18%" />
            </div>
            <div>
                <label>Percent</label>
                <input id="tipAmount1" type="number" step="0.01" value="18" />
            </div>
        </div>

        <div class="tip-row">
            <div class="tip-number">Tip 3</div>
            <div>
                <label>Text</label>
                <input id="tipName2" class="required" value="20%" />
            </div>
            <div>
                <label>Percent</label>
                <input id="tipAmount2" type="number" step="0.01" value="20" />
            </div>
        </div>

        <div class="tip-row">
            <div class="tip-number">Tip 4</div>
            <div>
                <label>Text</label>
                <input id="tipName3" class="required" value="22%" />
            </div>
            <div>
                <label>Percent</label>
                <input id="tipAmount3" type="number" step="0.01" value="22" />
            </div>
        </div>

        <div class="button-bar">
            <button class="btn-clear" onclick="clearTips()">Clear</button>
            <button class="btn-delete" onclick="deleteTips()">Delete All</button>
            <button class="btn-save" onclick="saveTips()">Save Tips</button>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadTips();
    });

    function loadTips() {
        fetch('/MSaleAdmin/GetSuggestedTips')
            .then(r => r.json())
            .then(data => {
                for (let i = 0; i < 4; i++) {
                    if (data[i]) {
                        document.getElementById("tipName" + i).value =
                            data[i].name || data[i].Name || "";

                        document.getElementById("tipAmount" + i).value =
                            data[i].amount || data[i].Amount || "0";
                    }
                }
            });
    }

    function saveTips() {
        let tips = [];

        for (let i = 0; i < 4; i++) {
            let name = document.getElementById("tipName" + i).value;
            let amount = document.getElementById("tipAmount" + i).value;

            if (!name.trim()) {
                alert("Enter text for Tip " + (i + 1));
                return;
            }

            tips.push({
                name: name,
                amount: parseFloat(amount || 0)
            });
        }

        fetch('/MSaleAdmin/SaveSuggestedTips', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tips)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Suggested Tips Saved");
            loadTips();
        });
    }

    function deleteTips() {
        if (!confirm("Delete all suggested tips?")) return;

        fetch('/MSaleAdmin/DeleteSuggestedTips', {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Suggested Tips Deleted");
            clearTips();
        });
    }

    function clearTips() {
        for (let i = 0; i < 4; i++) {
            document.getElementById("tipName" + i).value = "";
            document.getElementById("tipAmount" + i).value = "0";
        }
    }
</script>