@{
    ViewData["Title"] = "Meal Periods";
    ViewData["Subtitle"] = "Create meal periods and assign them to categories.";
}

<div class="grid gap-6 lg:grid-cols-2">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h2 class="text-base font-semibold text-slate-900">Create / Edit Meal Period</h2>

        <div class="mt-4 space-y-4">

            <div>
                <label class="block text-sm font-medium text-slate-700">Existing Meal Periods</label>

                <select id="mealPeriodCombo"
                        onchange="mealPeriodChanged()"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Meal Period</option>
                </select>

                <p class="mt-1 text-sm text-slate-500">Select an existing meal period to edit.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Meal Period Name</label>

                <input type="text"
                       id="periodName"
                       placeholder="Breakfast, Lunch, Dinner"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Timed Event</label>

                <select id="periodTime"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Timed Event</option>
                </select>
            </div>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-6">

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50"
                    onclick="document.getElementById('periodName').value='';document.getElementById('periodTime').value='';document.getElementById('mealPeriodCombo').value='';">
                Clear
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50"
                    onclick="deleteMealPeriod()">
                Remove Meal Period
            </button>

            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                    onclick="saveMealPeriod()">
                Add / Save Meal Period
            </button>

        </div>

    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h2 class="text-base font-semibold text-slate-900">Assign Meal Period To Category</h2>

        <div class="mt-4 space-y-4">

            <div>
                <label class="block text-sm font-medium text-slate-700">Category</label>

                <select id="categoryName"
                        onchange="loadCategoryMealPeriod()"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Category</option>
                </select>

                <p class="mt-1 text-sm text-slate-500">Select a category to assign a meal period.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Meal Period</label>

                <select id="mealPeriodAssign"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Meal Period</option>
                </select>
            </div>

        </div>

        <div class="mt-6 border-t border-slate-200 pt-4">
            <div class="flex flex-wrap items-center justify-end gap-2">

                <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                        onclick="saveCategoryMealPeriod()">
                    Save Category Assignment
                </button>

            </div>
        </div>

    </div>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        loadTimedEvents();
        loadMealPeriods();
        loadCategories();

    });

    function loadMealPeriods() {

        fetch('/MSaleAdmin/GetMealPeriods')
            .then(r => r.json())
            .then(data => {

                let combo =
                    document.getElementById("mealPeriodCombo");

                let assign =
                    document.getElementById("mealPeriodAssign");

                combo.innerHTML =
                    '<option value="">Select Meal Period</option>';

                assign.innerHTML =
                    '<option value="">Select Meal Period</option>';

                data.forEach(function (item) {

                    let periodName =
                        item.periodName || item.PeriodName;

                    let periodTime =
                        item.periodTime || item.PeriodTime;

                    let opt1 =
                        document.createElement("option");

                    opt1.value = periodName;
                    opt1.text = periodName;
                    opt1.dataset.periodTime = periodTime;

                    combo.appendChild(opt1);

                    let opt2 =
                        document.createElement("option");

                    opt2.value = periodName;
                    opt2.text = periodName;

                    assign.appendChild(opt2);
                });
            });
    }

    function loadTimedEvents() {

        fetch('/MSaleAdmin/GetTimedEvents')
            .then(r => r.json())
            .then(data => {

                let combo =
                    document.getElementById("periodTime");

                combo.innerHTML =
                    '<option value="">Select Timed Event</option>';

                data.forEach(function (name) {

                    let opt =
                        document.createElement("option");

                    opt.value = name;
                    opt.text = name;

                    combo.appendChild(opt);
                });
            });
    }

    function mealPeriodChanged() {

        let combo =
            document.getElementById("mealPeriodCombo");

        let selected =
            combo.options[combo.selectedIndex];

        if (!selected || !selected.value) {

            document.getElementById("periodName").value = "";
            document.getElementById("periodTime").value = "";

            return;
        }

        document.getElementById("periodName").value =
            selected.value;

        document.getElementById("periodTime").value =
            selected.dataset.periodTime || "";
    }

    function loadCategories() {

        fetch('/MSaleAdmin/GetCategories')
            .then(r => r.json())
            .then(data => {

                let combo =
                    document.getElementById("categoryName");

                combo.innerHTML =
                    '<option value="">Select Category</option>';

                data.forEach(function (name) {

                    let opt =
                        document.createElement("option");

                    opt.value = name;
                    opt.text = name;

                    combo.appendChild(opt);
                });
            });
    }

    function saveMealPeriod() {

        let periodName =
            document.getElementById("periodName").value;

        let periodTime =
            document.getElementById("periodTime").value;

        if (!periodName) {

            alert("Enter Meal Period Name");
            return;
        }

        fetch('/MSaleAdmin/SaveMealPeriod', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({

                periodName: periodName,
                periodTime: periodTime

            })

        })
        .then(r => r.json())
        .then(x => {

            alert("Meal Period Saved");

            loadMealPeriods();

            document.getElementById("mealPeriodCombo").value =
                periodName;
        });
    }

    function deleteMealPeriod() {

        let periodName =
            document.getElementById("periodName").value;

        if (!periodName) {

            alert("Select or enter Meal Period Name");
            return;
        }

        fetch('/MSaleAdmin/DeleteMealPeriod?periodName='
            + encodeURIComponent(periodName), {

            method: 'POST'

        })
        .then(r => r.json())
        .then(x => {

            alert("Meal Period Deleted");

            document.getElementById("periodName").value = "";
            document.getElementById("periodTime").value = "";

            loadMealPeriods();
        });
    }

    function loadCategoryMealPeriod() {

        let categoryName =
            document.getElementById("categoryName").value;

        if (!categoryName)
            return;

        fetch('/MSaleAdmin/GetCategoryMealPeriod?categoryName='
            + encodeURIComponent(categoryName))

            .then(r => r.json())

            .then(x => {

                document.getElementById("mealPeriodAssign").value =
                    x.mealPeriod || "";

            });
    }

    function saveCategoryMealPeriod() {

        let categoryName =
            document.getElementById("categoryName").value;

        let mealPeriod =
            document.getElementById("mealPeriodAssign").value;

        if (!categoryName) {

            alert("Select Category");
            return;
        }

        if (!mealPeriod) {

            alert("Select Meal Period");
            return;
        }

        fetch('/MSaleAdmin/SaveCategoryMealPeriod', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({

                categoryName: categoryName,
                mealPeriod: mealPeriod

            })

        })
        .then(r => r.json())
        .then(x => {

            alert("Category Assignment Saved");

        });
    }

</script>
