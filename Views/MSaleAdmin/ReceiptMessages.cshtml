@{
    ViewData["Title"] = "Receipt Messages";
    ViewData["Subtitle"] = "Set the messages printed on receipts and credit card slips.";
}

<div class="space-y-6">

    <div class="max-w-xs">
        <label for="day" class="block text-sm font-medium text-slate-700">Day</label>
        <select id="day" onchange="loadBothMessages()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
            <option value="Default">Default</option>
            <option value="Monday">Monday</option>
            <option value="Tuesday">Tuesday</option>
            <option value="Wednesday">Wednesday</option>
            <option value="Thursday">Thursday</option>
            <option value="Friday">Friday</option>
            <option value="Saturday">Saturday</option>
            <option value="Sunday">Sunday</option>
        </select>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Regular Receipt Message</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="ticketLine1" class="block text-sm font-medium text-slate-700">Line 1</label>
                    <input id="ticketLine1" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ticketLine2" class="block text-sm font-medium text-slate-700">Line 2</label>
                    <input id="ticketLine2" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ticketLine3" class="block text-sm font-medium text-slate-700">Line 3</label>
                    <input id="ticketLine3" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ticketLine4" class="block text-sm font-medium text-slate-700">Line 4</label>
                    <input id="ticketLine4" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-2">
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTicketInfo()">Save Receipt</button>
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteTicketInfo()">Delete</button>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Credit Card Slip Message</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="ccLine1" class="block text-sm font-medium text-slate-700">Line 1</label>
                    <input id="ccLine1" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ccLine2" class="block text-sm font-medium text-slate-700">Line 2</label>
                    <input id="ccLine2" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ccLine3" class="block text-sm font-medium text-slate-700">Line 3</label>
                    <input id="ccLine3" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
                <div>
                    <label for="ccLine4" class="block text-sm font-medium text-slate-700">Line 4</label>
                    <input id="ccLine4" maxlength="80" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-2">
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveCreditCardMessage()">Save CC Slip</button>
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteCreditCardMessage()">Delete</button>
            </div>
        </div>

    </div>

    <div class="flex flex-wrap items-center gap-2">
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", loadBothMessages);

    function currentDay() {
        return document.getElementById("day").value;
    }

    function loadBothMessages() {
        loadTicketInfo();
        loadCreditCardMessage();
    }

    function loadTicketInfo() {
        fetch('/MSaleAdmin/GetTicketInfo?day=' + encodeURIComponent(currentDay()))
            .then(r => r.json())
            .then(d => {
                document.getElementById("ticketLine1").value = d.line1 || "";
                document.getElementById("ticketLine2").value = d.line2 || "";
                document.getElementById("ticketLine3").value = d.line3 || "";
                document.getElementById("ticketLine4").value = d.line4 || "";
            });
    }

    function loadCreditCardMessage() {
        fetch('/MSaleAdmin/GetCreditCardMessage?day=' + encodeURIComponent(currentDay()))
            .then(r => r.json())
            .then(d => {
                document.getElementById("ccLine1").value = d.line1 || "";
                document.getElementById("ccLine2").value = d.line2 || "";
                document.getElementById("ccLine3").value = d.line3 || "";
                document.getElementById("ccLine4").value = d.line4 || "";
            });
    }

    function saveTicketInfo() {
        let data = {
            day: currentDay(),
            line1: document.getElementById("ticketLine1").value,
            line2: document.getElementById("ticketLine2").value,
            line3: document.getElementById("ticketLine3").value,
            line4: document.getElementById("ticketLine4").value
        };

        fetch('/MSaleAdmin/SaveTicketInfo', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"));
    }

    function saveCreditCardMessage() {
        let data = {
            day: currentDay(),
            line1: document.getElementById("ccLine1").value,
            line2: document.getElementById("ccLine2").value,
            line3: document.getElementById("ccLine3").value,
            line4: document.getElementById("ccLine4").value
        };

        fetch('/MSaleAdmin/SaveCreditCardMessage', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"));
    }

    function deleteTicketInfo() {
        fetch('/MSaleAdmin/DeleteTicketInfo?day=' + encodeURIComponent(currentDay()), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            loadTicketInfo();
        });
    }

    function deleteCreditCardMessage() {
        fetch('/MSaleAdmin/DeleteCreditCardMessage?day=' + encodeURIComponent(currentDay()), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            loadCreditCardMessage();
        });
    }
</script>
