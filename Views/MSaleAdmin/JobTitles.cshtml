@{
    ViewData["Title"] = "Job Titles";
    ViewData["Subtitle"] = "Manage tipped positions, tip pool percent, 7shifts job codes, and cash drawer access.";
}

<div class="space-y-6">

    <input type="hidden" id="originalJobTitle" />

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Job Title Setup</h2>

        <div class="mt-4 grid gap-4 md:grid-cols-[2fr_1fr_1fr]">

            <div>
                <label class="block text-sm font-medium text-slate-700">Job Title</label>
                <input id="jobTitle"
                       placeholder="Example: Server, Bartender, Cashier"
                       class="mt-1 block w-full rounded-lg border-0 bg-amber-50 px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <div class="mt-1 text-xs text-slate-500">This is the job title shown in the POS.</div>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">7shifts Job Code</label>
                <input id="jobCodeNumber"
                       placeholder="Job code"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <div class="mt-1 text-xs text-slate-500">Used for 7shifts mapping.</div>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tip Pool %</label>
                <input id="tipPoolPercent"
                       type="number"
                       step="0.01"
                       value="0.00"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <div class="mt-1 text-xs text-slate-500">Enter 0.00 if not used.</div>
            </div>

        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input id="tippedPosition"
                       type="checkbox"
                       class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Tipped Position - start audit / tip tracking
            </label>

            <label class="flex cursor-pointer items-center gap-2.5 rounded-lg bg-white px-4 py-3 text-sm font-medium text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-50">
                <input id="drawer"
                       type="checkbox"
                       class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Opens Cash Drawer
            </label>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-4">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearJobTitle()">Clear</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteJobTitle()">Delete</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveJobTitle()">Save Job Title</button>
        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Existing Job Titles</h2>

        <div class="mt-4 overflow-x-auto rounded-lg ring-1 ring-slate-200">
            <div class="min-w-[640px]">
                <div class="grid grid-cols-[1.4fr_100px_130px_150px_100px] items-center gap-2.5 border-b border-slate-200 bg-slate-50 px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-slate-500">
                    <div>Job Title</div>
                    <div class="text-center">Tipped</div>
                    <div class="text-right">Tip Pool %</div>
                    <div>7shifts Code</div>
                    <div class="text-center">Drawer</div>
                </div>

                <div id="jobList" class="max-h-[430px] divide-y divide-slate-100 overflow-y-auto bg-white"></div>
            </div>
        </div>
    </div>

</div>

<script>
    let selectedJobRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadJobTitles();
    });

    function loadJobTitles() {
        fetch('/MSaleAdmin/GetJobTitles')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById('jobList');
                list.innerHTML = '';

                data.forEach(function (x) {
                    let div = document.createElement('div');
                    div.className = 'grid cursor-pointer grid-cols-[1.4fr_100px_130px_150px_100px] items-center gap-2.5 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50';

                    div.innerHTML =
                        '<div>' + escapeHtml(x.jobTitle || '') + '</div>' +
                        '<div class="text-center">' + (x.tippedPosition ? 'Yes' : 'No') + '</div>' +
                        '<div class="text-right">' + Number(x.tipPoolPercent || 0).toFixed(2) + '</div>' +
                        '<div>' + escapeHtml(x.jobCodeNumber || '') + '</div>' +
                        '<div class="text-center">' + (x.drawer ? 'Yes' : 'No') + '</div>';

                    div.onclick = function () {
                        if (selectedJobRow)
                            selectedJobRow.classList.remove('selected', ...SEL);

                        selectedJobRow = div;
                        selectedJobRow.classList.add('selected', ...SEL);

                        document.getElementById('jobTitle').value = x.jobTitle || '';
                        document.getElementById('originalJobTitle').value = x.jobTitle || '';
                        document.getElementById('tippedPosition').checked = x.tippedPosition === true;
                        document.getElementById('tipPoolPercent').value = Number(x.tipPoolPercent || 0).toFixed(2);
                        document.getElementById('jobCodeNumber').value = x.jobCodeNumber || '';
                        document.getElementById('drawer').checked = x.drawer === true;
                    };

                    list.appendChild(div);
                });
            });
    }

    function saveJobTitle() {
        let item = {
            jobTitle: document.getElementById('jobTitle').value,
            originalJobTitle: document.getElementById('originalJobTitle').value,
            tippedPosition: document.getElementById('tippedPosition').checked,
            tipPoolPercent: parseFloat(document.getElementById('tipPoolPercent').value || 0),
            jobCodeNumber: document.getElementById('jobCodeNumber').value,
            drawer: document.getElementById('drawer').checked
        };

        if (!item.jobTitle.trim()) {
            alert("Enter a job title.");
            return;
        }

        fetch('/MSaleAdmin/SaveJobTitle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadJobTitles();
            clearJobTitle();
        });
    }

    function deleteJobTitle() {
        let item = {
            jobTitle:
                document.getElementById('originalJobTitle').value ||
                document.getElementById('jobTitle').value
        };

        if (!item.jobTitle.trim()) {
            alert("Select a job title to delete.");
            return;
        }

        if (!confirm("Delete job title " + item.jobTitle + "?"))
            return;

        fetch('/MSaleAdmin/DeleteJobTitle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadJobTitles();
            clearJobTitle();
        });
    }

    function clearJobTitle() {
        document.getElementById('jobTitle').value = '';
        document.getElementById('originalJobTitle').value = '';
        document.getElementById('tippedPosition').checked = false;
        document.getElementById('tipPoolPercent').value = '0.00';
        document.getElementById('jobCodeNumber').value = '';
        document.getElementById('drawer').checked = false;

        if (selectedJobRow) {
            selectedJobRow.classList.remove('selected', ...SEL);
            selectedJobRow = null;
        }

        document.getElementById('jobTitle').focus();
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }
</script>
