@{
    ViewData["Title"] = "Check Review";
    ViewData["Subtitle"] = "Review closed checks, menu items, voids, payments, tips, and totals.";
}

<div class="space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid gap-4 md:grid-cols-12">
            <div class="md:col-span-3">
                <label class="block text-sm font-medium text-slate-700">Business Date</label>
                <input id="businessDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div class="md:col-span-3">
                <label class="block text-sm font-medium text-slate-700">Search Type</label>
                <select id="searchType" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">All Checks</option>
                    <option value="check">Check Number</option>
                    <option value="server">Server Name</option>
                </select>
            </div>

            <div class="md:col-span-4">
                <label class="block text-sm font-medium text-slate-700">Search Value</label>
                <input id="searchValue" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="Optional" />
            </div>

            <div class="flex items-end md:col-span-2">
                <button class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="loadChecks()">Load</button>
            </div>
        </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[430px_minmax(0,1fr)]">

        <div>
            <div class="mb-3 text-base font-semibold text-slate-900">Closed Checks</div>
            <div id="checkList" class="max-h-[680px] divide-y divide-slate-100 overflow-y-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200"></div>
        </div>

        <div>
            <div id="reviewArea" class="space-y-6">
                <div class="rounded-xl bg-white p-6 text-sm text-slate-500 shadow-sm ring-1 ring-slate-200">
                    Select a check to review.
                </div>
            </div>
        </div>

    </div>

</div>

<script>
    let selectedCheckRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        businessDate.value = new Date().toISOString().substring(0, 10);
        loadChecks();
    });

    function money(v) {
        return Number(v || 0).toFixed(2);
    }

    function loadChecks() {
        const date = businessDate.value;
        const type = searchType.value;
        const value = encodeURIComponent(searchValue.value || '');

        fetch(`/CheckReview/GetClosedChecks?businessDate=${date}&searchType=${type}&searchValue=${value}`)
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderCheckList(result.data);
            });
    }

    function renderCheckList(data) {
        checkList.innerHTML = '';

        if (!data || data.length === 0) {
            checkList.innerHTML = `<div class="px-4 py-3 text-sm text-slate-500">No checks found.</div>`;
            return;
        }

        data.forEach(row => {
            const div = document.createElement('div');
            div.className = 'cursor-pointer px-4 py-3 text-sm text-slate-700 hover:bg-slate-50';

            div.innerHTML = `
                <div class="text-base font-bold text-slate-900">Check #${row.checkNumber}</div>
                <div>${row.serverName || ''}</div>
                <div class="text-xs text-slate-500">
                    ${row.openTime || ''} - ${row.closeTime || ''}
                    &nbsp; | &nbsp; Total: $${money(row.checkTotal)}
                </div>
            `;

            div.onclick = function () {
                if (selectedCheckRow)
                    selectedCheckRow.classList.remove('selected', ...SEL);

                selectedCheckRow = div;
                div.classList.add('selected', ...SEL);

                loadCheckReview(row.checkNumber, row.orderDate, row.closeOutDay);
            };

            checkList.appendChild(div);
        });
    }

    function loadCheckReview(checkNumber, orderDate, closeOutDay) {
        fetch(`/CheckReview/GetCheckReview?checkNumber=${checkNumber}&businessDate=${orderDate}&closeOutDay=${closeOutDay}`)
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                renderReview(result.data);
            });
    }

    function renderReview(data) {
        const h = data.header;
        const totals = data.totals;

        let detailRows = '';
        data.details.forEach(x => {
            detailRows += `
                <tr class="${x.voided ? 'bg-rose-50 text-rose-700 line-through' : ''}">
                    <td class="px-4 py-2.5">${x.seatNumber}</td>
                    <td class="px-4 py-2.5">${x.menuItem || ''}</td>
                    <td class="px-4 py-2.5 text-right">${money(x.amount)}</td>
                    <td class="px-4 py-2.5">${x.voided ? 'VOID' : ''}</td>
                    <td class="px-4 py-2.5">${x.voidReason || ''}</td>
                    <td class="px-4 py-2.5">${x.voidedBy || ''}</td>
                </tr>`;
        });

        let paymentRows = '';
        data.payments.forEach(x => {
            paymentRows += `
                <tr>
                    <td class="px-4 py-2.5">${x.paymentType || ''}</td>
                    <td class="px-4 py-2.5 text-right">${money(x.paymentAmount)}</td>
                    <td class="px-4 py-2.5 text-right">${money(x.tipAmount)}</td>
                </tr>`;
        });

        reviewArea.innerHTML = `
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
                <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Check</b><span class="text-xl font-bold text-slate-900">#${h.checkNumber}</span></div>
                <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Total</b><span class="text-xl font-bold text-slate-900">$${money(h.checkTotal)}</span></div>
                <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Items</b><span class="text-xl font-bold text-slate-900">$${money(totals.itemTotal)}</span></div>
                <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Payments</b><span class="text-xl font-bold text-slate-900">$${money(totals.paymentTotal)}</span></div>
                <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200"><b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Tips</b><span class="text-xl font-bold text-slate-900">$${money(totals.tipTotal)}</span></div>
            </div>

            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="mb-3 text-base font-semibold text-slate-900">Check Header</div>
                <div class="space-y-1 text-sm text-slate-700">
                    <div><b class="font-semibold text-slate-900">Server:</b> ${h.serverName || ''}</div>
                    <div><b class="font-semibold text-slate-900">Cashier:</b> ${h.cashierName || ''}</div>
                    <div><b class="font-semibold text-slate-900">Table:</b> ${h.tableNumber || ''}</div>
                    <div><b class="font-semibold text-slate-900">Order Type:</b> ${h.orderType || ''}</div>
                    <div><b class="font-semibold text-slate-900">Opened:</b> ${h.orderDate || ''} ${h.openTime || ''}</div>
                    <div><b class="font-semibold text-slate-900">Closed:</b> ${h.closeTime || ''}</div>
                    <div><b class="font-semibold text-slate-900">Member:</b> ${h.memberName || ''}</div>
                </div>
            </div>

            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="mb-3 text-base font-semibold text-slate-900">Check Detail</div>
                <div class="overflow-x-auto rounded-lg ring-1 ring-slate-200">
                    <table class="min-w-full divide-y divide-slate-200 text-sm text-slate-700">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Seat</th>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Menu Item</th>
                                <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Amount</th>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Void Reason</th>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Voided By</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">${detailRows}</tbody>
                    </table>
                </div>
            </div>

            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <div class="mb-3 text-base font-semibold text-slate-900">Payments</div>
                <div class="overflow-x-auto rounded-lg ring-1 ring-slate-200">
                    <table class="min-w-full divide-y divide-slate-200 text-sm text-slate-700">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Payment Type</th>
                                <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Amount</th>
                                <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Tip</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">${paymentRows}</tbody>
                    </table>
                </div>
            </div>
        `;
    }
</script>
