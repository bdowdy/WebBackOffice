@{
    ViewData["Title"] = "Master Departments";
    ViewData["Subtitle"] = "Manage master department names used for reporting.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <h2 class="text-base font-semibold text-slate-900">Master Departments</h2>
        <div class="flex-1"></div>
        <span id="statusLine" class="text-sm text-slate-500"></span>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/MSaleAdmin'">Dashboard</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[360px_1fr]">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Add Master Department</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="newName" class="block text-sm font-medium text-slate-700">Master Department Name</label>
                    <input id="newName" onkeydown="if(event.key==='Enter'){event.preventDefault();addMasterDept();}" placeholder="e.g. Food, Liquor, Retail" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <button type="button" class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="addMasterDept()">
                    Add Master Department
                </button>

                <p class="text-sm text-slate-500">Master department names group report categories for reporting. Names must be unique.</p>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="flex items-center justify-between">
                <h3 class="text-base font-semibold text-slate-900">Existing Master Departments</h3>
                <span id="countBadge" class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">0</span>
            </div>

            <ul id="deptList" class="mt-4 divide-y divide-slate-100"></ul>

            <p id="emptyHint" class="mt-4 rounded-lg bg-slate-50 px-3 py-6 text-center text-sm text-slate-500">No master departments yet. Add one on the left.</p>
        </div>

    </div>
</div>

<script>
    let depts = [];

    document.addEventListener("DOMContentLoaded", loadDepts);

    function setStatus(msg) {
        document.getElementById("statusLine").textContent = msg || "";
    }

    function loadDepts() {
        fetch('/MSaleAdmin/GetMasterDepartments')
            .then(r => r.json())
            .then(data => {
                depts = data || [];
                render();
            })
            .catch(err => alert("Could not load master departments: " + err.message));
    }

    function render() {
        const ul = document.getElementById("deptList");
        ul.innerHTML = "";

        document.getElementById("countBadge").textContent = depts.length;
        document.getElementById("emptyHint").style.display = depts.length ? "none" : "block";

        depts.forEach(name => {
            const li = document.createElement("li");
            li.className = "py-2 text-sm text-slate-800";
            li.textContent = name;
            ul.appendChild(li);
        });
    }

    function addMasterDept() {
        const input = document.getElementById("newName");
        const name = input.value.trim();

        if (!name) {
            alert("Enter a master department name.");
            input.focus();
            return;
        }

        // client-side duplicate guard (the add endpoint has no uniqueness check)
        const exists = depts.some(d => (d || "").toLowerCase() === name.toLowerCase());
        if (exists) {
            alert("\"" + name + "\" already exists.");
            input.focus();
            return;
        }

        setStatus("Saving...");

        fetch('/MSaleAdmin/AddMasterDepartment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name })
        })
        .then(r => r.json())
        .then(x => {
            setStatus("Added");
            input.value = "";
            input.focus();
            loadDepts();
        })
        .catch(err => { setStatus(""); alert("Add failed: " + err.message); });
    }
</script>
