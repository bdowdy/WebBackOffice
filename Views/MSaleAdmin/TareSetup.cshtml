@{
    ViewData["Title"] = "Tare Setup";
    ViewData["Subtitle"] = "Create, edit, and remove tare weights";
}

<div class="max-w-3xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid gap-6 md:grid-cols-[280px_1fr]">

            <!-- Left: existing tares -->
            <div>
                <label for="tareListBox" class="block text-sm font-medium text-slate-700">Existing Tares</label>
                <select id="tareListBox" size="10" onchange="loadSelectedTare()" class="mt-1 block h-80 w-full rounded-lg border-0 bg-white p-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                <div id="tareCount" class="mt-2 text-center text-xs text-slate-400">0 tares</div>
            </div>

            <!-- Right: editor -->
            <div>
                <div class="mb-4">
                    <label for="tareName" class="block text-sm font-medium text-slate-700">Tare Name</label>
                    <input id="tareName" placeholder="e.g. Small Container" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div class="mb-4">
                    <label for="tareWt" class="block text-sm font-medium text-slate-700">Tare Weight</label>
                    <div class="relative mt-1">
                        <input id="tareWt" type="number" step="0.01" value="0.00" class="block w-full rounded-lg border-0 bg-white py-2 pl-3 pr-10 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-sm text-slate-400">lb</span>
                    </div>
                </div>

                <div class="mt-6 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-5">
                    <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearForm()">Clear</button>
                    <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteTare()">Remove</button>
                    <button class="inline-flex flex-1 items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTare()">Save</button>
                </div>

                <div id="msg" class="mt-4 min-h-[20px] rounded-lg text-sm"></div>
            </div>

        </div>
    </div>

</div>

<script>
    let tares = [];

    document.addEventListener("DOMContentLoaded", function () {
        loadTares();
    });

    function showMsg(text, type) {
        let el = document.getElementById("msg");
        el.innerText = text || "";
        const styles = {
            info: " bg-slate-100 px-3.5 py-2.5 text-slate-600 ring-1 ring-inset ring-slate-200",
            error: " bg-rose-50 px-3.5 py-2.5 text-rose-700 ring-1 ring-inset ring-rose-200",
            success: " bg-emerald-50 px-3.5 py-2.5 text-emerald-800 ring-1 ring-inset ring-emerald-200"
        };
        el.className = "mt-4 min-h-[20px] rounded-lg text-sm" + (text ? (styles[type] || styles.info) : "");
    }

    function updateCount() {
        let el = document.getElementById("tareCount");
        el.innerText = tares.length + (tares.length === 1 ? " tare" : " tares");
    }

    function clearForm() {
        document.getElementById("tareListBox").value = "";
        document.getElementById("tareName").value = "";
        document.getElementById("tareWt").value = "0.00";
        showMsg("");
    }

    async function loadTares() {
        try {
            let r = await fetch('/MSaleAdmin/GetTares');
            tares = await r.json();

            let list = document.getElementById("tareListBox");
            list.innerHTML = "";

            tares.forEach(x => {
                let opt = document.createElement("option");
                opt.value = x.tareName;
                opt.text = x.tareName;
                list.appendChild(opt);
            });

            updateCount();
        } catch (err) {
            showMsg("Could not load tares.", "error");
            console.log(err);
        }
    }

    function loadSelectedTare() {
        let name = document.getElementById("tareListBox").value;
        let item = tares.find(x => x.tareName === name);

        if (!item) return;

        document.getElementById("tareName").value = item.tareName;
        document.getElementById("tareWt").value = Number(item.tareWt).toFixed(2);
        showMsg("Existing tare loaded.", "info");
    }

    async function saveTare() {
        let name = document.getElementById("tareName").value.trim();
        let wt = document.getElementById("tareWt").value;

        if (name === "") {
            showMsg("Tare name is required.", "error");
            return;
        }

        let body = {
            tareName: name,
            tareWt: parseFloat(wt || 0)
        };

        try {
            let r = await fetch('/MSaleAdmin/SaveTare', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            let result = await r.json();
            showMsg(result.message, "success");

            await loadTares();

            document.getElementById("tareListBox").value = name;
            document.getElementById("tareName").value = name;
        } catch (err) {
            showMsg("Could not save tare.", "error");
            console.log(err);
        }
    }

    async function deleteTare() {
        let name = document.getElementById("tareName").value.trim();

        if (name === "") {
            showMsg("Nothing to delete.", "error");
            return;
        }

        if (!confirm('Remove tare "' + name + '"?')) return;

        let body = {
            tareName: name,
            tareWt: 0
        };

        try {
            let r = await fetch('/MSaleAdmin/DeleteTare', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            let result = await r.json();
            showMsg(result.message, "success");

            await loadTares();
            clearForm();
        } catch (err) {
            showMsg("Could not delete tare.", "error");
            console.log(err);
        }
    }
</script>
