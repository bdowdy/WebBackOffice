@{
    ViewData["Title"] = "Timed Pricing";
    ViewData["Subtitle"] = "Visual weekly timeline of timed price events.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="newEvent()">New</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveEvents()">Save</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadEvents()">Reload</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteSelected()">Delete Selected</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[320px_1fr]">

        <div class="panel rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Selected Event</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Event Name</label>
                    <input id="eventName" list="eventNameList" onchange="selectEventByName()" placeholder="Type a new name or pick an existing one" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                    <datalist id="eventNameList"></datalist>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Start Time</label>
                    <input id="startTime" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">End Time</label>
                    <input id="endTime" type="time" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Start Date</label>
                    <input id="startDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">End Date</label>
                    <input id="endDate" type="date" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Price Off</label>
                    <input id="priceOff" type="number" step="0.01" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Days Active</label>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="monday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Monday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="tuesday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Tuesday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="wednesday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Wednesday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="thursday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Thursday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="friday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Friday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="saturday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Saturday</label>
                        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" id="sunday" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" /> Sunday</label>
                    </div>
                </div>

                <div class="pt-2">
                    <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="applyEditor()">Apply To Timeline</button>
                </div>
            </div>
        </div>

        <div class="panel rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Timeline</h3>
            <div class="mt-4 overflow-x-auto rounded-lg bg-slate-900 ring-1 ring-slate-700">
                <div id="timeline" class="relative min-h-[520px] pt-9"></div>
            </div>
        </div>

    </div>

</div>

<script>
    let events = [];
    let selectedIndex = -1;

    const SEL = ['outline', 'outline-2', 'outline-offset-2', 'outline-amber-400'];

    const days = [
        { key: "monday", label: "Monday" },
        { key: "tuesday", label: "Tuesday" },
        { key: "wednesday", label: "Wednesday" },
        { key: "thursday", label: "Thursday" },
        { key: "friday", label: "Friday" },
        { key: "saturday", label: "Saturday" },
        { key: "sunday", label: "Sunday" }
    ];

    const leftPad = 85;
    const hourWidth = 45;
    const timelineWidth = leftPad + (24 * hourWidth);

    document.addEventListener("DOMContentLoaded", function () {
        loadEventNames();
        loadEvents();
    });

    function loadEventNames() {
        fetch('/MSaleAdmin/GetTimedEvents')
            .then(r => r.json())
            .then(data => {
                const ddl = document.getElementById("eventNameList");
                ddl.innerHTML = "";

                data.forEach(name => {
                    const opt = document.createElement("option");
                    opt.value = name;
                    ddl.appendChild(opt);
                });
            })
            .catch(err => alert("Could not load event names: " + err.message));
    }

    function loadEvents() {
        fetch('/MSaleAdmin/GetTimedPricing')
            .then(r => r.json())
            .then(result => {
                if (Array.isArray(result)) {
                    events = result;
                } else if (result.success === true && Array.isArray(result.data)) {
                    events = result.data;
                } else {
                    events = [];
                }

                selectedIndex = -1;
                clearEditor();
                drawTimeline();
            })
            .catch(err => {
                events = [];
                selectedIndex = -1;
                clearEditor();
                drawTimeline();
                alert("Could not load timed pricing: " + err.message);
            });
    }

    function drawTimeline() {
        const tl = document.getElementById("timeline");
        tl.innerHTML = "";
        tl.style.width = timelineWidth + "px";

        for (let h = 0; h <= 24; h++) {
            const x = leftPad + h * hourWidth;

            const line = document.createElement("div");
            line.className = "absolute inset-y-0 w-px bg-slate-600";
            line.style.left = x + "px";
            tl.appendChild(line);

            if (h < 24) {
                const lbl = document.createElement("div");
                lbl.className = "absolute top-1 -translate-x-1/2 text-[11px] text-slate-300";
                lbl.style.left = x + "px";
                lbl.innerText = formatHour(h);
                tl.appendChild(lbl);
            }
        }

        days.forEach(d => {
            const row = document.createElement("div");
            row.className = "relative h-[62px] border-t border-slate-700 text-white";

            const name = document.createElement("div");
            name.className = "absolute left-2 top-5 w-[75px] text-sm font-semibold text-slate-200";
            name.innerText = d.label;
            row.appendChild(name);

            events.forEach((ev, index) => {
                if (!ev[d.key]) return;

                let start = timeToMinutes(ev.startTime);
                let end = timeToMinutes(ev.endTime);

                if (end <= start) end = start + 30;

                const block = document.createElement("div");
                block.className = "absolute top-3 h-[38px] cursor-pointer overflow-hidden rounded border border-white/80 bg-sky-600 p-1 text-xs text-white hover:bg-sky-500";

                if (index === selectedIndex) {
                    block.classList.add("selected", ...SEL);
                }

                block.style.left = (leftPad + (start / 60) * hourWidth) + "px";
                block.style.width = Math.max(35, ((end - start) / 60) * hourWidth) + "px";

                block.innerText = ev.eventName + " $" + ev.priceOff;

                block.onclick = function () {
                    selectedIndex = index;
                    loadEditor(index);
                    drawTimeline();
                };

                row.appendChild(block);
            });

            tl.appendChild(row);
        });
    }

    function newEvent() {
        events.push({
            eventName: "",
            startTime: "09:00",
            endTime: "17:00",
            monday: true,
            tuesday: true,
            wednesday: true,
            thursday: true,
            friday: true,
            saturday: false,
            sunday: false,
            startDate: null,
            endDate: null,
            priceOff: 0
        });

        selectedIndex = events.length - 1;
        loadEditor(selectedIndex);
        drawTimeline();
    }

    function selectEventByName() {
        const name = document.getElementById("eventName").value;
        if (!name) return;

        // recall an existing event by name; if the name is new/unsaved, leave it for entry
        const idx = events.findIndex(e => (e.eventName || "") === name);
        if (idx < 0) return;

        selectedIndex = idx;
        loadEditor(idx);
        drawTimeline();
    }

    function loadEditor(index) {
        const ev = events[index];

        document.getElementById("eventName").value = ev.eventName || "";
        document.getElementById("startTime").value = formatTime(ev.startTime);
        document.getElementById("endTime").value = formatTime(ev.endTime);
        document.getElementById("startDate").value = formatDate(ev.startDate);
        document.getElementById("endDate").value = formatDate(ev.endDate);
        document.getElementById("priceOff").value = ev.priceOff || 0;

        days.forEach(d => {
            document.getElementById(d.key).checked = !!ev[d.key];
        });
    }

    function applyEditor() {
        if (selectedIndex < 0) {
            events.push({});
            selectedIndex = events.length - 1;
        }

        const ev = events[selectedIndex];

        ev.eventName = document.getElementById("eventName").value;
        ev.startTime = document.getElementById("startTime").value;
        ev.endTime = document.getElementById("endTime").value;
        ev.startDate = document.getElementById("startDate").value || null;
        ev.endDate = document.getElementById("endDate").value || null;
        ev.priceOff = parseFloat(document.getElementById("priceOff").value || 0);

        days.forEach(d => {
            ev[d.key] = document.getElementById(d.key).checked;
        });

        drawTimeline();
    }

    function deleteSelected() {
        if (selectedIndex < 0) return;
        if (!confirm("Delete selected timed price event?")) return;

        events.splice(selectedIndex, 1);
        selectedIndex = -1;
        clearEditor();
        drawTimeline();
    }

    function saveEvents() {
        if (selectedIndex >= 0) {
            applyEditor();
        }

        fetch('/MSaleAdmin/SaveTimedPricing', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(events)
        })
            .then(r => r.json())
            .then(x => {
                alert(x.message || "Saved");
                loadEventNames();
                loadEvents();
            })
            .catch(err => alert("Save failed: " + err.message));
    }

    function clearEditor() {
        document.querySelectorAll(".panel input").forEach(x => {
            if (x.type === "checkbox") x.checked = false;
            else x.value = "";
        });

        document.getElementById("eventName").value = "";
    }

    function timeToMinutes(v) {
        v = formatTime(v);
        if (!v) return 0;

        const p = v.split(":");
        return parseInt(p[0]) * 60 + parseInt(p[1]);
    }

    function formatTime(v) {
        if (!v) return "";
        return v.toString().substring(0, 5);
    }

    function formatDate(v) {
        if (!v) return "";
        return v.toString().substring(0, 10);
    }

    function formatHour(h) {
        if (h === 0) return "12a";
        if (h < 12) return h + "a";
        if (h === 12) return "12p";
        return (h - 12) + "p";
    }
</script>
