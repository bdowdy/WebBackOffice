@{
    ViewData["Title"] = "Order Buttons";
    ViewData["Subtitle"] = "Assign POS functions first. Add colors later if needed.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" type="button" onclick="loadButtons()">Reload</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" type="button" onclick="saveButtons()">Save</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" type="button" onclick="clearSelectedButton()">Clear Selected</button>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" type="button" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[320px_1fr]">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

            <h2 class="text-base font-semibold text-slate-900">POS Functions</h2>

            <p class="mt-1 text-sm text-slate-500">
                Select a function, then click a button position.
            </p>

            <select id="functionList" size="25" class="mt-3 block h-[460px] w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            <h2 class="mt-6 text-base font-semibold text-slate-900">Button Colors</h2>

            <p class="mt-1 text-sm text-slate-500">
                Select a button first, then change colors if needed.
            </p>

            <div class="mt-3 grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Background</label>
                    <select id="backColorSelect" onchange="applySelectedColors()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700">Text</label>
                    <select id="foreColorSelect" onchange="applySelectedColors()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>
            </div>

        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

            <h2 class="text-base font-semibold text-slate-900">Button Positions</h2>

            <p class="mt-1 text-sm text-slate-500">
                Click a button to assign the selected function. Double-click to clear.
            </p>

            <div id="buttonCanvas" class="mt-4 grid min-h-[560px] grid-cols-4 gap-3 rounded-xl bg-slate-900 p-4 ring-1 ring-slate-800"></div>

        </div>

    </div>

</div>

<script>
    let buttons = [];
    let selectedButtonElement = null;

    const DEFAULT_BACK_COLOR = 12632256; // Light Gray
    const DEFAULT_FORE_COLOR = 0;        // Black

    const SELECTED_BTN_CLASSES = ["outline", "outline-4", "outline-yellow-400"];

    const functionList = [
        "Access Phone Order",
        "Phone Order",
        "Message To Manager",
        "Item Refund",
        "Refund",
        "Member Reward",
        "Check Id",
        "New Phone Order",
        "Open Drinks",
        "Attach Coupon",
        "Review Order",
        "Attach Credit Card",
        "Guest Services",
        "Frequent Diner",
        "Show Recipe",
        "Catering Proposal",
        "Server Drinks",
        "Release Holds",
        "Keyboard",
        "Customer Name",
        "Attach Discount",
        "Table Tent",
        "Change Destination",
        "Tray Review",
        "Time Clock",
        "Paid Outs",
        "Fire Order",
        "Gift Card Balance",
        "Resend to Kitchen",
        "Item To Go",
        "Discount Card",
        "Show Menu List",
        "Hide Sent Items",
        "Show Sent Items",
        "PLU Look Up",
        "Verify Account",
        "Edit Account No",
        "Meal Periods",
        "Print By Seat",
        "Open Drawer",
        "Intercard",
        "Reprint Receipt",
        "Hold Item",
        "Hold Check",
        "Managers Menu",
        "Apply Tip",
        "Blind Audit",
        "Gratuity",
        "Waste",
        "Redeem Loyalty",
        "Loyalty Status",
        "EBT Total",
        "Verify Balance",
        "Reprint Last Receipt",
        "Taxable",
        "Start Tab",
        "Tip Edit",
        "Scan Check",
        "Price Adjust",
        "Alternate Remote",
        "Select Receipt",
        "Item Transfer",
        "Delete Item",
        "Print/Start Tab",
        "Service Charge",
        "Send/Stay",
        "Skim Drawer",
        "Tip List",
        "Print CC Slip",
        "Pay Up Front",
        "Recall Suspended",
        "Text Order Ready",
        "Stop PhoneOrder Message",
        "EBT Sale",
        "Qty Available",
        "Change Menu",
        "Single Labels",
        "Multi Labels",
        "Grab N Go",
        "Table View",
        "Kiosk Is On",
        "Edit Seats"
    ];

    const colorList = [
        { name: "Light Gray", value: 12632256 },
        { name: "Black", value: 0 },
        { name: "White", value: 16777215 },
        { name: "Red", value: 255 },
        { name: "Green", value: 65280 },
        { name: "Blue", value: 16711680 },
        { name: "Yellow", value: 65535 },
        { name: "Cyan", value: 16776960 },
        { name: "Magenta", value: 16711935 },
        { name: "Gray", value: 8421504 },
        { name: "Dark Gray", value: 4210752 },
        { name: "Orange", value: 33023 },
        { name: "Brown", value: 128 },
        { name: "Dark Green", value: 32768 },
        { name: "Navy", value: 8388608 }
    ];

    document.addEventListener("DOMContentLoaded", function () {
        loadFunctionList();
        loadColorLists();
        loadButtons();
    });

    function loadFunctionList() {
        let list = document.getElementById("functionList");
        list.innerHTML = "";

        functionList.forEach(name => {
            let opt = document.createElement("option");
            opt.value = name;
            opt.text = name;
            list.appendChild(opt);
        });
    }

    function loadColorLists() {
        let back = document.getElementById("backColorSelect");
        let fore = document.getElementById("foreColorSelect");

        back.innerHTML = "";
        fore.innerHTML = "";

        colorList.forEach(c => {
            back.add(new Option(c.name, c.value));
            fore.add(new Option(c.name, c.value));
        });

        back.value = DEFAULT_BACK_COLOR;
        fore.value = DEFAULT_FORE_COLOR;
    }

    function loadButtons() {
        fetch('/MSaleAdmin/GetOrderButtons')
            .then(r => r.json())
            .then(data => {
                buttons = data || [];

                if (buttons.length === 0) {
                    for (let i = 1; i <= 20; i++) {
                        buttons.push({
                            idxNo: i,
                            captionName: "",
                            spareLeft: DEFAULT_BACK_COLOR,
                            spareTop: DEFAULT_FORE_COLOR
                        });
                    }
                }

                buttons.forEach(b => {
                    if (!b.spareLeft || Number(b.spareLeft) === 0) {
                        b.spareLeft = DEFAULT_BACK_COLOR;
                    }

                    if (b.spareTop === null || b.spareTop === undefined || b.spareTop === "") {
                        b.spareTop = DEFAULT_FORE_COLOR;
                    }
                });

                drawButtons();
            })
            .catch(err => alert("Could not load buttons: " + err.message));
    }

    function drawButtons() {
        let canvas = document.getElementById("buttonCanvas");
        canvas.innerHTML = "";

        buttons
            .sort((a, b) => Number(a.idxNo || 0) - Number(b.idxNo || 0))
            .forEach(row => {

                let wrap = document.createElement("div");
                wrap.className = "text-center";

                let label = document.createElement("div");
                label.className = "mb-1 text-xs font-medium text-slate-300";
                label.innerText = "Position " + row.idxNo;

                let btn = document.createElement("div");
                btn.className = "order-btn flex h-[72px] w-full cursor-pointer select-none items-center justify-center whitespace-normal rounded-lg border-2 border-slate-400 p-1.5 text-center text-[13px] font-bold transition hover:border-sky-400";
                btn.dataset.idx = row.idxNo;

                btn.innerText = row.captionName || "";

                btn.style.backgroundColor =
                    vbColorToHex(row.spareLeft || DEFAULT_BACK_COLOR);

                btn.style.color =
                    vbColorToHex(row.spareTop ?? DEFAULT_FORE_COLOR);

                btn.onclick = function () {
                    selectButton(btn);
                    assignSelectedFunction(btn);
                };

                btn.ondblclick = function () {
                    selectButton(btn);
                    clearSelectedButton();
                };

                wrap.appendChild(label);
                wrap.appendChild(btn);
                canvas.appendChild(wrap);
            });
    }

    function selectButton(btn) {
        document.querySelectorAll(".order-btn")
            .forEach(b => b.classList.remove("selected-btn", ...SELECTED_BTN_CLASSES));

        selectedButtonElement = btn;
        btn.classList.add("selected-btn", ...SELECTED_BTN_CLASSES);

        let row = getButtonRow(btn);

        if (row) {
            document.getElementById("backColorSelect").value =
                row.spareLeft || DEFAULT_BACK_COLOR;

            document.getElementById("foreColorSelect").value =
                row.spareTop ?? DEFAULT_FORE_COLOR;
        }
    }

    function assignSelectedFunction(btn) {
        let selectedFunction =
            document.getElementById("functionList").value;

        if (!selectedFunction) return;

        let row = getButtonRow(btn);
        if (!row) return;

        row.captionName = selectedFunction;

        if (!row.spareLeft || Number(row.spareLeft) === 0) {
            row.spareLeft = DEFAULT_BACK_COLOR;
        }

        if (row.spareTop === null || row.spareTop === undefined || row.spareTop === "") {
            row.spareTop = DEFAULT_FORE_COLOR;
        }

        btn.innerText = selectedFunction;
        btn.style.backgroundColor = vbColorToHex(row.spareLeft);
        btn.style.color = vbColorToHex(row.spareTop);
    }

    function clearSelectedButton() {
        if (!selectedButtonElement) return;

        let row = getButtonRow(selectedButtonElement);
        if (!row) return;

        row.captionName = "";
        row.spareLeft = DEFAULT_BACK_COLOR;
        row.spareTop = DEFAULT_FORE_COLOR;

        selectedButtonElement.innerText = "";
        selectedButtonElement.style.backgroundColor = vbColorToHex(DEFAULT_BACK_COLOR);
        selectedButtonElement.style.color = vbColorToHex(DEFAULT_FORE_COLOR);

        document.getElementById("backColorSelect").value = DEFAULT_BACK_COLOR;
        document.getElementById("foreColorSelect").value = DEFAULT_FORE_COLOR;
    }

    function applySelectedColors() {
        if (!selectedButtonElement) return;

        let row = getButtonRow(selectedButtonElement);
        if (!row) return;

        row.spareLeft =
            parseInt(document.getElementById("backColorSelect").value || DEFAULT_BACK_COLOR);

        row.spareTop =
            parseInt(document.getElementById("foreColorSelect").value ?? DEFAULT_FORE_COLOR);

        selectedButtonElement.style.backgroundColor =
            vbColorToHex(row.spareLeft);

        selectedButtonElement.style.color =
            vbColorToHex(row.spareTop);
    }

    function getButtonRow(btn) {
        let idx = parseInt(btn.dataset.idx);
        return buttons.find(x => Number(x.idxNo) === idx);
    }

    function saveButtons() {
        fetch('/MSaleAdmin/SaveOrderButtons', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(buttons)
        })
        .then(r => r.json())
        .then(x => alert(x.message || "Saved"))
        .catch(err => alert("Save failed: " + err.message));
    }

    function vbColorToHex(value) {
        value = Number(value || 0);

        let r = value & 255;
        let g = (value >> 8) & 255;
        let b = (value >> 16) & 255;

        return "#" +
            r.toString(16).padStart(2, "0") +
            g.toString(16).padStart(2, "0") +
            b.toString(16).padStart(2, "0");
    }
</script>
