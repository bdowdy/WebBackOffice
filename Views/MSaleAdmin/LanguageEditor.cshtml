@{
    ViewData["Title"] = "Language Editor";
    ViewData["Subtitle"] = "Maintain POS text translations. Enter the English phrase and its translation; changes save to the shared translation database.";
}

<div class="space-y-6">

    <div class="grid gap-6 lg:grid-cols-3">

        <!-- Translation list -->
        <div class="lg:col-span-2 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="flex items-center justify-between gap-3">
                <h3 class="text-base font-semibold text-slate-900">Translation List</h3>
                <span id="count" class="text-xs text-slate-500"></span>
            </div>

            <div class="mt-4 relative max-w-sm">
                <input id="search" type="text" placeholder="Search phrases"
                       class="block w-full rounded-lg border-0 bg-white px-3 py-2 pl-9 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <svg class="pointer-events-none absolute left-2.5 top-2.5 h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
                </svg>
            </div>

            <div class="mt-4 overflow-hidden rounded-lg ring-1 ring-slate-200">
                <div class="grid grid-cols-[1fr_1fr_auto] gap-0 bg-slate-50 px-4 py-2 text-xs font-medium text-slate-500">
                    <span>English</span><span>Translation</span><span class="w-8"></span>
                </div>
                <div id="grid" class="max-h-[420px] divide-y divide-slate-100 overflow-y-auto"></div>
            </div>
        </div>

        <!-- Editor -->
        <div class="space-y-6">
            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <h3 class="text-base font-semibold text-slate-900">Edit Entry</h3>
                <div class="mt-4 space-y-4">
                    <div>
                        <label for="english" class="block text-sm font-medium text-slate-700">English</label>
                        <input id="english" maxlength="255" placeholder="Enter English phrase"
                               class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                    </div>
                    <div>
                        <label for="translated" class="block text-sm font-medium text-slate-700">Translation</label>
                        <input id="translated" maxlength="255" placeholder="Enter translation"
                               class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                    </div>
                </div>
                <div class="mt-5 flex flex-wrap items-center gap-2">
                    <button type="button" onclick="applyEntry()"
                            class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Add / Update</button>
                    <button type="button" onclick="clearFields()"
                            class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-600 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Clear</button>
                </div>
                <p id="toast" class="mt-3 min-h-[1.25rem] text-sm text-emerald-600"></p>
            </div>

            <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <label class="flex items-start gap-3">
                    <input id="logpos" type="checkbox"
                           class="mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                    <span class="text-sm text-slate-700">
                        <span class="font-medium">Log POS system text</span><br />
                        <span class="text-slate-500">Build translation database (turns on POS language translation).</span>
                    </span>
                </label>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const API = "/api/language";
    let state = [];
    let selected = null;

    const $ = id => document.getElementById(id);
    const gridEl = $("grid"), searchEl = $("search"), englishEl = $("english"),
          translatedEl = $("translated"), toastEl = $("toast"), countEl = $("count"), logposEl = $("logpos");

    const esc = s => String(s ?? "").replace(/[&<>"]/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

    function flash(msg, isErr) {
        toastEl.textContent = msg;
        toastEl.className = "mt-3 min-h-[1.25rem] text-sm " + (isErr ? "text-rose-600" : "text-emerald-600");
        if (!isErr) setTimeout(() => { toastEl.textContent = ""; }, 2500);
    }

    function render() {
        const q = searchEl.value.trim().toLowerCase();
        gridEl.innerHTML = "";
        let shown = 0;
        state.forEach(row => {
            if (q && row.english.toLowerCase().indexOf(q) === -1 && (row.returnText || "").toLowerCase().indexOf(q) === -1) return;
            shown++;
            const sel = row.english === selected;
            const miss = !row.returnText;
            const div = document.createElement("div");
            div.className = "grid grid-cols-[1fr_1fr_auto] items-center gap-0 px-4 py-2 text-sm cursor-pointer " + (sel ? "bg-emerald-50" : "hover:bg-slate-50");
            div.innerHTML =
                '<span class="truncate pr-2">' + esc(row.english) + '</span>' +
                '<span class="truncate pr-2 ' + (miss ? "text-slate-400" : "text-slate-700") + '">' + (miss ? "—" : esc(row.returnText)) + '</span>' +
                '<button type="button" title="Delete" class="js-del w-8 text-slate-400 hover:text-rose-600">×</button>';
            div.addEventListener("click", e => {
                if (e.target.classList.contains("js-del")) { e.stopPropagation(); removeRow(row.english); return; }
                selected = row.english; englishEl.value = row.english; translatedEl.value = row.returnText || ""; render();
            });
            gridEl.appendChild(div);
        });
        countEl.textContent = state.length + " phrases" + (q ? " · " + shown + " shown" : "");
    }

    async function checkOk(r) {
        if (!r.ok) {
            let body = "";
            try { body = await r.text(); } catch { }
            throw new Error(body && body.length < 500 ? body : ("HTTP " + r.status));
        }
        return r;
    }

    function load() {
        fetch(API).then(checkOk).then(r => r.json())
            .then(rows => {
                state = rows.map(x => ({ english: x.english, returnText: x.returnText || "" }))
                            .sort((a, b) => a.english.localeCompare(b.english));
                render();
            })
            .catch(err => flash("Couldn't load translations. " + err.message, true));
    }

    function applyEntry() {
        const eng = englishEl.value.trim(), txt = translatedEl.value.trim();
        if (!eng) { flash("Enter an English phrase.", true); englishEl.focus(); return; }
        fetch(API, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ english: eng, returnText: txt }) })
            .then(checkOk)
            .then(() => {
                const existing = state.find(x => x.english.toLowerCase() === eng.toLowerCase());
                if (existing) { existing.english = eng; existing.returnText = txt; }
                else { state.push({ english: eng, returnText: txt }); state.sort((a, b) => a.english.localeCompare(b.english)); }
                selected = eng; englishEl.value = ""; translatedEl.value = ""; render();
                flash(existing ? 'Updated "' + eng + '"' : 'Added "' + eng + '"');
            })
            .catch(err => flash("Save failed. " + err.message, true));
    }

    function removeRow(eng) {
        if (!confirm('Delete "' + eng + '"?')) return;
        fetch(API + "?english=" + encodeURIComponent(eng), { method: "DELETE" })
            .then(checkOk)
            .then(() => {
                state = state.filter(x => x.english !== eng);
                if (selected === eng) { selected = null; englishEl.value = ""; translatedEl.value = ""; }
                render(); flash('Deleted "' + eng + '"');
            })
            .catch(err => flash("Delete failed. " + err.message, true));
    }

    function clearFields() { englishEl.value = ""; translatedEl.value = ""; selected = null; render(); }

    searchEl.addEventListener("input", render);

    logposEl.addEventListener("change", () => {
        fetch(API + "/setting/language-on", { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ value: logposEl.checked }) })
            .then(checkOk)
            .then(() => flash("Setting saved"))
            .catch(err => { logposEl.checked = !logposEl.checked; flash("Couldn't save setting. " + err.message, true); });
    });

    fetch(API + "/setting/language-on").then(r => r.json()).then(d => { logposEl.checked = !!d.value; }).catch(() => {});
    load();
</script>
}
