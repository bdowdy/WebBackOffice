@{
    ViewData["Title"] = "Category Setup";
    ViewData["Subtitle"] = "Add, edit, or delete menu categories.";
}

<div class="grid gap-6 lg:grid-cols-[330px_1fr]">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Existing Categories</h2>
        <p class="mt-1 text-sm text-slate-500">Click a category to edit it.</p>

        <button type="button" onclick="newCategory()" class="mt-3 mb-3 inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">
            Add New Category
        </button>

        <div id="categoryList" class="max-h-[620px] divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Category Details</h2>

        <input type="hidden" id="originalCategoryName" />

        <div class="mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">

            <div>
                <label class="block text-sm font-medium text-slate-700">Category Name <span class="text-rose-500">*</span></label>
                <input id="categoryName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Sort Level</label>
                <input id="sortLevel" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Button Level</label>
                <input id="buttonLevel" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Meal Period</label>
                <select id="mealPeriod" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Meal Period</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Mandatory</label>
                <select id="mandatory" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="No">No</option>
                    <option value="Yes">Yes</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Disable Mods</label>
                <select id="disableMods" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="No">No</option>
                    <option value="Yes">Yes</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Tip Exempt</label>
                <select id="tipExempt" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="No">No</option>
                    <option value="Yes">Yes</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Prompt</label>
                <input id="prompt" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">BitMap</label>
                <input id="bitMap" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Alias</label>
                <input id="alias" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

        </div>

        <div class="mt-6 flex flex-wrap items-center justify-end gap-2">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="newCategory()">Clear</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteCategory()">Delete</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveCategory()">Save Category</button>
        </div>

    </div>

</div>

<script>
    const ACTIVE_CLASSES = ["bg-emerald-50", "text-emerald-900", "font-medium"];

    document.addEventListener("DOMContentLoaded", function () {
        loadCategoryNames();
        loadMealPeriods();
    });

    function loadCategoryNames() {
        fetch('/MSaleAdmin/GetCategoryNames')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("categoryList");
                list.innerHTML = "";

                data.forEach(function (name) {
                    let div = document.createElement("div");
                    div.className = "category-item cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50";
                    div.innerText = name;

                    div.onclick = function () {
                        document.querySelectorAll(".category-item")
                            .forEach(x => x.classList.remove("active", ...ACTIVE_CLASSES));

                        div.classList.add("active", ...ACTIVE_CLASSES);
                        loadCategoryByName(name);
                    };

                    list.appendChild(div);
                });
            });
    }

    function loadMealPeriods() {
        fetch('/MSaleAdmin/GetMealPeriodNames')
            .then(r => r.json())
            .then(data => {
                let combo = document.getElementById("mealPeriod");

                combo.innerHTML =
                    '<option value="">Select Meal Period</option>';

                data.forEach(function (name) {
                    let opt = document.createElement("option");
                    opt.value = name;
                    opt.text = name;
                    combo.appendChild(opt);
                });
            });
    }

    function loadCategoryByName(categoryName) {
        if (!categoryName) return;

        fetch('/MSaleAdmin/GetCategory?categoryName='
            + encodeURIComponent(categoryName))
            .then(r => r.json())
            .then(x => {
                document.getElementById("originalCategoryName").value =
                    x.categoryName || "";

                document.getElementById("categoryName").value =
                    x.categoryName || "";

                document.getElementById("sortLevel").value =
                    x.sortLevel || "";

                document.getElementById("buttonLevel").value =
                    x.buttonLevel || "";

                document.getElementById("mandatory").value =
                    x.mandatory || "No";

                document.getElementById("disableMods").value =
                    x.disableMods || "No";

                document.getElementById("tipExempt").value =
                    x.tipExempt || "No";

                document.getElementById("prompt").value =
                    x.prompt || "";

                document.getElementById("mealPeriod").value =
                    x.mealPeriod || "";

                document.getElementById("bitMap").value =
                    x.bitMap || "";

                document.getElementById("alias").value =
                    x.alias || "";
            });
    }

    function newCategory() {
        document.getElementById("originalCategoryName").value = "";
        document.getElementById("categoryName").value = "";
        document.getElementById("sortLevel").value = "";
        document.getElementById("buttonLevel").value = "";

        document.getElementById("mandatory").value = "No";
        document.getElementById("disableMods").value = "No";
        document.getElementById("tipExempt").value = "No";

        document.getElementById("prompt").value = "";
        document.getElementById("mealPeriod").value = "";
        document.getElementById("bitMap").value = "";
        document.getElementById("alias").value = "";

        document.querySelectorAll(".category-item")
            .forEach(x => x.classList.remove("active", ...ACTIVE_CLASSES));

        document.getElementById("categoryName").focus();
    }

    function saveCategory() {
        let model = {
            originalCategoryName:
                document.getElementById("originalCategoryName").value,

            categoryName:
                document.getElementById("categoryName").value,

            sortLevel:
                document.getElementById("sortLevel").value,

            buttonLevel:
                document.getElementById("buttonLevel").value,

            mandatory:
                document.getElementById("mandatory").value,

            disableMods:
                document.getElementById("disableMods").value,

            tipExempt:
                document.getElementById("tipExempt").value,

            prompt:
                document.getElementById("prompt").value,

            mealPeriod:
                document.getElementById("mealPeriod").value,

            bitMap:
                document.getElementById("bitMap").value,

            alias:
                document.getElementById("alias").value
        };

        if (!model.categoryName) {
            alert("Enter Category Name");
            return;
        }

        fetch('/MSaleAdmin/SaveCategory', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(model)
        })
        .then(r => r.json())
        .then(x => {
            alert("Category Saved");
            loadCategoryNames();
        });
    }

    function deleteCategory() {
        let categoryName =
            document.getElementById("categoryName").value;

        if (!categoryName) {
            alert("Select Category");
            return;
        }

        if (!confirm("Delete this category?"))
            return;

        fetch('/MSaleAdmin/DeleteCategory?categoryName='
            + encodeURIComponent(categoryName), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert("Category Deleted");
            newCategory();
            loadCategoryNames();
        });
    }
</script>
