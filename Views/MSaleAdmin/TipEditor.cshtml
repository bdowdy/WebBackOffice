@{
    ViewData["Title"] = "Tip Editor";
    ViewData["Subtitle"] = "Edit cash tips, credit card tips, paid out tips, tip share, and gratuity.";
}

<div class="space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="grid gap-4 lg:grid-cols-2">
            <div>
                <label class="block text-sm font-medium text-slate-700">Employee</label>
                <select id="employeeName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
            </div>

            <div class="flex items-end">
                <div class="flex flex-wrap items-center gap-2">
                    <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="loadTips()">Load Tips</button>
                    <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveTips()">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <div class="flex flex-wrap gap-3">
        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Records</b>
            <span id="sumRecords" class="text-xl font-bold text-slate-900">0</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Cash Tips</b>
            <span id="sumCash" class="text-xl font-bold text-slate-900">0.00</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">CC Tips</b>
            <span id="sumCC" class="text-xl font-bold text-slate-900">0.00</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Tips Paid Out</b>
            <span id="sumPaidOut" class="text-xl font-bold text-slate-900">0.00</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Tip Share</b>
            <span id="sumShare" class="text-xl font-bold text-slate-900">0.00</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Net Tips</b>
            <span id="sumNet" class="text-xl font-bold text-slate-900">0.00</span>
        </div>

        <div class="min-w-[140px] rounded-xl bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
            <b class="block text-xs font-semibold uppercase tracking-wide text-slate-500">Gratuity</b>
            <span id="sumGrat" class="text-xl font-bold text-slate-900">0.00</span>
        </div>
    </div>

    <div class="max-h-[520px] overflow-auto rounded-xl bg-white shadow-sm ring-1 ring-slate-200">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="sticky top-0 z-10 bg-slate-50">
                <tr>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Job Name</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Shift Date</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Time On</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Time Out</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Cash Tips</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Non Cash Tips</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Tips Paid Out</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Tip Share</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Total Tips</th>
                    <th class="whitespace-nowrap px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Gratuity</th>
                </tr>
            </thead>
            <tbody id="tipBody" class="divide-y divide-slate-100"></tbody>
        </table>
    </div>

</div>

<script>
    let tipRows = [];

    document.addEventListener("DOMContentLoaded", function () {
        loadEmployees();
    });

    function n(v) {
        return Number(v || 0);
    }

    function money(v) {
        return n(v).toFixed(2);
    }

    function loadEmployees() {
        fetch('/TipEditor/GetTipEmployees')
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                const ddl = document.getElementById('employeeName');
                ddl.innerHTML = '<option value="">Select Employee</option>';

                result.data.forEach(name => {
                    const opt = document.createElement('option');
                    opt.value = name;
                    opt.textContent = name;
                    ddl.appendChild(opt);
                });
            });
    }

    function loadTips() {
        const emp = document.getElementById('employeeName').value;

        if (!emp) {
            alert("Select an employee.");
            return;
        }

        fetch('/TipEditor/GetTipEditRecords?employeeName=' + encodeURIComponent(emp))
            .then(r => r.json())
            .then(result => {
                if (!result.success) {
                    alert(result.message);
                    return;
                }

                tipRows = result.data;
                renderTips();
            });
    }

    function renderTips() {
        const body = document.getElementById('tipBody');
        body.innerHTML = '';

        tipRows.forEach((row, index) => {
            const totalTips = n(row.cashTips) + n(row.creditCardTips) + n(row.tipShare);

            const tr = document.createElement('tr');
            tr.className = 'hover:bg-slate-50';

            tr.innerHTML = `
                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-700">${row.departmentName || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-700">${row.shiftDate || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-700">${row.timeIn || ''}</td>
                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-700">${row.timeOut || ''}</td>

                <td class="whitespace-nowrap px-4 py-2.5"><input class="block w-24 rounded-md border-0 bg-white px-2 py-1 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" type="number" step="0.01" value="${money(row.cashTips)}" onchange="changeValue(${index}, 'cashTips', this.value)" /></td>

                <td class="whitespace-nowrap px-4 py-2.5"><input class="block w-24 rounded-md border-0 bg-white px-2 py-1 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" type="number" step="0.01" value="${money(row.creditCardTips)}" onchange="changeValue(${index}, 'creditCardTips', this.value)" /></td>

                <td class="whitespace-nowrap px-4 py-2.5"><input class="block w-24 rounded-md border-0 bg-white px-2 py-1 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" type="number" step="0.01" value="${money(row.tipsPaidOut)}" onchange="changeValue(${index}, 'tipsPaidOut', this.value)" /></td>

                <td class="whitespace-nowrap px-4 py-2.5"><input class="block w-24 rounded-md border-0 bg-white px-2 py-1 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" type="number" step="0.01" value="${money(row.tipShare)}" onchange="changeValue(${index}, 'tipShare', this.value)" /></td>

                <td class="whitespace-nowrap px-4 py-2.5 font-medium text-slate-700" id="totalTips_${index}">${money(totalTips)}</td>

                <td class="whitespace-nowrap px-4 py-2.5"><input class="block w-24 rounded-md border-0 bg-white px-2 py-1 text-right text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500" type="number" step="0.01" value="${money(row.gratuity)}" onchange="changeValue(${index}, 'gratuity', this.value)" /></td>
            `;

            body.appendChild(tr);
        });

        updateTotals();
    }

    function changeValue(index, field, value) {
        tipRows[index][field] = n(value);

        const totalTips = n(tipRows[index].cashTips) +
                          n(tipRows[index].creditCardTips) +
                          n(tipRows[index].tipShare);

        document.getElementById('totalTips_' + index).textContent = money(totalTips);

        updateTotals();
    }

    function updateTotals() {
        let cash = 0;
        let cc = 0;
        let paid = 0;
        let share = 0;
        let net = 0;
        let grat = 0;

        tipRows.forEach(row => {
            cash += n(row.cashTips);
            cc += n(row.creditCardTips);
            paid += n(row.tipsPaidOut);
            share += n(row.tipShare);
            grat += n(row.gratuity);

            net += (n(row.cashTips) + n(row.creditCardTips) + n(row.tipShare)) - n(row.tipsPaidOut);
        });

        document.getElementById('sumRecords').textContent = tipRows.length;
        document.getElementById('sumCash').textContent = money(cash);
        document.getElementById('sumCC').textContent = money(cc);
        document.getElementById('sumPaidOut').textContent = money(paid);
        document.getElementById('sumShare').textContent = money(share);
        document.getElementById('sumNet').textContent = money(net);
        document.getElementById('sumGrat').textContent = money(grat);
    }

    function saveTips() {
        if (tipRows.length === 0) {
            alert("No records to save.");
            return;
        }

        if (!confirm("Save tip changes?"))
            return;

        fetch('/TipEditor/SaveTipEditRecords', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(tipRows)
        })
        .then(r => r.json())
        .then(result => {
            if (!result.success) {
                alert(result.message);
                return;
            }

            alert(result.message || "Saved");
            loadTips();
        });
    }
</script>
