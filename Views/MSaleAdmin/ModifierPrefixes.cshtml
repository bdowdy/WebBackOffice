@{
    ViewData["Title"] = "Modifier Prefixes";
    ViewData["Subtitle"] = "Add, edit, delete, and set upcharges for modifier prefixes.";
}

<input type="hidden" id="originalPrefixName" />

<div class="grid gap-6 lg:grid-cols-2">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h3 class="text-base font-semibold text-slate-900">Prefix Setup</h3>

        <div class="mt-4 grid gap-4 sm:grid-cols-3">

            <div class="sm:col-span-2">
                <label for="prefixName" class="block text-sm font-medium text-slate-700">Prefix Name</label>
                <input id="prefixName"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500"
                       placeholder="Example: Extra, No, Light" />
                <div class="mt-1 text-xs text-slate-500">This is the prefix shown before a modifier.</div>
            </div>

            <div>
                <label for="upcharge" class="block text-sm font-medium text-slate-700">Upcharge</label>
                <input id="upcharge"
                       type="number"
                       step="0.01"
                       value="0.00"
                       class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                <div class="mt-1 text-xs text-slate-500">Leave 0.00 for no extra charge.</div>
            </div>

        </div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-4">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearPrefix()">Clear</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deletePrefix()">Delete</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="savePrefix()">Save Prefix</button>
        </div>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h3 class="text-base font-semibold text-slate-900">Existing Modifier Prefixes</h3>

        <div class="mt-4 overflow-hidden rounded-lg ring-1 ring-slate-200">
            <div class="grid grid-cols-[1fr_8rem] gap-3 bg-slate-50 px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-slate-500">
                <div>Prefix Name</div>
                <div class="text-right">Upcharge</div>
            </div>

            <div id="prefixList" class="max-h-96 divide-y divide-slate-100 overflow-y-auto bg-white"></div>
        </div>
    </div>

</div>

<script>
    let selectedPrefixRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadPrefixes();
    });

    function loadPrefixes() {
        fetch('/MSaleAdmin/GetModifierPrefixes')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById('prefixList');
                list.innerHTML = '';

                data.forEach(function (x) {
                    let div = document.createElement('div');
                    div.className = 'grid cursor-pointer grid-cols-[1fr_8rem] gap-3 px-4 py-2.5 text-sm text-slate-700 hover:bg-slate-50';

                    let nameDiv = document.createElement('div');
                    nameDiv.textContent = x.prefixName;

                    let chargeDiv = document.createElement('div');
                    chargeDiv.className = 'text-right tabular-nums';
                    chargeDiv.textContent = Number(x.upcharge || 0).toFixed(2);

                    div.appendChild(nameDiv);
                    div.appendChild(chargeDiv);

                    div.onclick = function () {
                        if (selectedPrefixRow) {
                            selectedPrefixRow.classList.remove('selected', ...SEL);
                        }

                        selectedPrefixRow = div;
                        selectedPrefixRow.classList.add('selected', ...SEL);

                        document.getElementById('prefixName').value = x.prefixName;
                        document.getElementById('originalPrefixName').value = x.prefixName;
                        document.getElementById('upcharge').value =
                            Number(x.upcharge || 0).toFixed(2);
                    };

                    list.appendChild(div);
                });
            });
    }

    function savePrefix() {
        let item = {
            prefixName: document.getElementById('prefixName').value,
            originalPrefixName: document.getElementById('originalPrefixName').value,
            upcharge: parseFloat(document.getElementById('upcharge').value || 0)
        };

        if (!item.prefixName.trim()) {
            alert("Enter a prefix name.");
            return;
        }

        fetch('/MSaleAdmin/SaveModifierPrefix', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadPrefixes();
            clearPrefix();
        });
    }

    function deletePrefix() {
        let item = {
            prefixName:
                document.getElementById('originalPrefixName').value ||
                document.getElementById('prefixName').value
        };

        if (!item.prefixName.trim()) {
            alert("Select a prefix to delete.");
            return;
        }

        if (!confirm("Delete prefix " + item.prefixName + "?"))
            return;

        fetch('/MSaleAdmin/DeleteModifierPrefix', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadPrefixes();
            clearPrefix();
        });
    }

    function clearPrefix() {
        document.getElementById('prefixName').value = '';
        document.getElementById('originalPrefixName').value = '';
        document.getElementById('upcharge').value = '0.00';

        if (selectedPrefixRow) {
            selectedPrefixRow.classList.remove('selected', ...SEL);
            selectedPrefixRow = null;
        }

        document.getElementById('prefixName').focus();
    }
</script>
