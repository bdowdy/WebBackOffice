@{
    ViewData["Title"] = "Access Level Setup";
}

<div class="max-w-xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div class="space-y-4">

            <div>
                <label class="block text-sm font-medium text-slate-700">Access Name</label>
                <select id="accessName" onchange="loadAccessLevel()"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Access Name</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Access Level</label>
                <select id="accessLevel"
                        class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    @for (int i = 0; i <= 10; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <div class="flex flex-wrap items-center gap-2 pt-2">
                <button type="button" onclick="saveAccessLevel()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save</button>
                <button type="button" onclick="removeAccessLevel()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50">Remove Name</button>
                <button type="button" onclick="location.href='/'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Exit</button>
            </div>

        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadAccessNames();
    });

        function loadAccessNames() {
        fetch('/MSaleAdmin/GetAccessLevelNames')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("accessName");

                list.innerHTML = '<option value="">Select Access Name</option>';

                data.forEach(x => {
                    let opt = document.createElement("option");
                    opt.text = x.accessName;
                    list.appendChild(opt);
                });
            })
            .catch(err => alert("Could not load access names: " + err.message));
    }

    function loadAccessLevel() {
        let name = document.getElementById("accessName").value;
        if (!name) return;

        fetch('/MSaleAdmin/GetAccessLevel?accessName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(data => {
                if (data && data.accessLevel) {
                    document.getElementById("accessLevel").value = data.accessLevel;
                }
            })
            .catch(err => alert("Could not load access level: " + err.message));
    }

    function saveAccessLevel() {
        let data = {
            accessName: document.getElementById("accessName").value,
            accessLevel: parseInt(document.getElementById("accessLevel").value || 1)
        };

        if (!data.accessName) {
            alert("Enter an access name.");
            return;
        }

        fetch('/MSaleAdmin/SaveAccessLevel', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            document.getElementById("accessName").value = "";
            document.getElementById("accessLevel").value = "1";
            loadAccessNames();
        })
        .catch(err => alert("Save failed: " + err.message));
    }

    function removeAccessLevel() {
        let name = document.getElementById("accessName").value;
        if (!name) return;

        if (!confirm("Delete " + name + "?")) return;

        fetch('/MSaleAdmin/DeleteAccessLevel?accessName=' + encodeURIComponent(name), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            document.getElementById("accessName").value = "";
            document.getElementById("accessLevel").value = "1";
            loadAccessNames();
        })
        .catch(err => alert("Delete failed: " + err.message));
    }
</script>
