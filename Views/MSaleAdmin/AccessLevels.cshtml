@{
    ViewData["Title"] = "Access Level Setup";
}

<style>
    .access-page {
        width: 475px;
        margin: 40px auto;
        background: #808080;
        padding: 20px 24px;
        font-family: Arial, sans-serif;
        border: 2px solid #555;
    }

    .title {
        color: white;
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 12px;
    }

    .box {
        background: #e0e0e0;
        padding: 24px;
        border: 1px solid black;
    }

    .row {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 10px;
        align-items: center;
        margin-bottom: 12px;
    }

    label {
        text-align: right;
        font-size: 16px;
    }

    input, select {
        padding: 7px;
        font-size: 16px;
    }

    .buttons {
        text-align: center;
        margin-top: 18px;
    }

    button {
        padding: 8px 14px;
        margin: 4px;
        font-weight: bold;
        cursor: pointer;
    }
</style>

<div class="access-page">

    <div class="title">Access Level Setup</div>

    <div class="box">

        <div class="row">
            <label>Access Name</label>
            <select id="accessName" onchange="loadAccessLevel()">
                <option value="">Select Access Name</option>
            </select>
        </div>

        <div class="row">
            <label>Access Level</label>
            <select id="accessLevel">
                @for (int i = 0; i <= 10; i++)
                {
                    <option value="@i">@i</option>
                }
            </select>
        </div>

        <div class="buttons">
            <button type="button" onclick="saveAccessLevel()">Save</button>
            <button type="button" onclick="removeAccessLevel()">Remove Name</button>
            <button type="button" onclick="location.href='/'">Exit</button>
        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadAccessNames();
    });

        function loadAccessNames() {
        fetch('/MSaleAdmin/GetAccessLevelNames')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("accessName");

                list.innerHTML = '<option value="">Select Access Name</option>';

                data.forEach(x => {
                    let opt = document.createElement("option");                    
                    opt.text = x.accessName;
                    list.appendChild(opt);
                });
            })
            .catch(err => alert("Could not load access names: " + err.message));
    }

    function loadAccessLevel() {
        let name = document.getElementById("accessName").value;
        if (!name) return;

        fetch('/MSaleAdmin/GetAccessLevel?accessName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(data => {
                if (data && data.accessLevel) {
                    document.getElementById("accessLevel").value = data.accessLevel;
                }
            })
            .catch(err => alert("Could not load access level: " + err.message));
    }

    function saveAccessLevel() {
        let data = {
            accessName: document.getElementById("accessName").value,
            accessLevel: parseInt(document.getElementById("accessLevel").value || 1)
        };

        if (!data.accessName) {
            alert("Enter an access name.");
            return;
        }

        fetch('/MSaleAdmin/SaveAccessLevel', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            document.getElementById("accessName").value = "";
            document.getElementById("accessLevel").value = "1";
            loadAccessNames();
        })
        .catch(err => alert("Save failed: " + err.message));
    }

    function removeAccessLevel() {
        let name = document.getElementById("accessName").value;
        if (!name) return;

        if (!confirm("Delete " + name + "?")) return;

        fetch('/MSaleAdmin/DeleteAccessLevel?accessName=' + encodeURIComponent(name), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            document.getElementById("accessName").value = "";
            document.getElementById("accessLevel").value = "1";
            loadAccessNames();
        })
        .catch(err => alert("Delete failed: " + err.message));
    }
</script>