@{
    ViewData["Title"] = "Subcategory Setup";
    ViewData["Subtitle"] = "Assign subcategories to categories and optional timed events.";
}

<div class="max-w-xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <div class="space-y-4">

            <div>
                <label class="block text-sm font-medium text-slate-700">Sub Category Name</label>
                <select id="subName" onchange="loadSubCategory()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Subcategory</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700">Category Assigned</label>
                <select id="categoryName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                    <option value="">Select Category</option>
                </select>
            </div>

            <p class="text-xs text-slate-500">
                Subcategory Name cannot be identical to a Menu Item Name
            </p>

            <div>
                <label class="block text-sm font-medium text-slate-700">New Subcategory</label>
                <input id="newSubName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
            </div>

            <button type="button" onclick="changeSubName()" class="inline-flex w-full items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Change Subcategory Name</button>

        </div>

    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <h3 class="text-base font-semibold text-slate-900">Optional Section</h3>
        <p class="mt-1 text-sm text-slate-500">
            Assign Subcategory to a Timed Event to restrict the use of the subcategory.
        </p>

        <div class="mt-4 space-y-4">
            @for (int i = 1; i <= 5; i++)
            {
                <div>
                    <label class="block text-sm font-medium text-slate-700">Timed Event @i</label>
                    <select id="timedEvent@(i)" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
                        <option value="None">None</option>
                    </select>
                </div>
            }
        </div>

    </div>

    <div class="flex flex-wrap items-center gap-2 pt-2">
        <button type="button" onclick="removeSubCategory()" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50">Remove</button>
        <button type="button" onclick="saveSubCategory()" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500">Save</button>
        <button type="button" onclick="location.href='/'" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50">Exit</button>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadLists();
    });

    function loadLists() {
        fetch('/MSaleAdmin/GetSubCategoryLists')
            .then(r => r.json())
            .then(data => {
                let sub = document.getElementById("subName");
                let cat = document.getElementById("categoryName");

                sub.innerHTML = '<option value="">Select Subcategory</option>';
                cat.innerHTML = '<option value="">Select Category</option>';

                data.subCategories.forEach(x => {
                    sub.add(new Option(x, x));
                });

                data.categories.forEach(x => {
                    cat.add(new Option(x, x));
                });

                for (let i = 1; i <= 5; i++) {
                    let ev = document.getElementById("timedEvent" + i);
                    ev.innerHTML = '<option value="None">None</option>';

                    data.timedEvents.forEach(x => {
                        ev.add(new Option(x, x));
                    });
                }
            })
            .catch(err => alert("Could not load lists: " + err.message));
    }

    function loadSubCategory() {
        let name = document.getElementById("subName").value;
        if (!name) return;

        fetch('/MSaleAdmin/GetSubCategory?subName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(data => {
                document.getElementById("categoryName").value = data.categoryName || "";
                document.getElementById("timedEvent1").value = data.timedEvent1 || "None";
                document.getElementById("timedEvent2").value = data.timedEvent2 || "None";
                document.getElementById("timedEvent3").value = data.timedEvent3 || "None";
                document.getElementById("timedEvent4").value = data.timedEvent4 || "None";
                document.getElementById("timedEvent5").value = data.timedEvent5 || "None";
            })
            .catch(err => alert("Could not load subcategory: " + err.message));
    }

    function saveSubCategory() {
        let subName = document.getElementById("subName").value;

        if (!subName) {
            subName = prompt("Enter new subcategory name");
            if (!subName) return;
        }

        let data = {
            subName: subName,
            categoryName: document.getElementById("categoryName").value,
            timedEvent1: document.getElementById("timedEvent1").value || "None",
            timedEvent2: document.getElementById("timedEvent2").value || "None",
            timedEvent3: document.getElementById("timedEvent3").value || "None",
            timedEvent4: document.getElementById("timedEvent4").value || "None",
            timedEvent5: document.getElementById("timedEvent5").value || "None"
        };

        if (!data.categoryName) {
            alert("Please assign a category name.");
            return;
        }

        fetch('/MSaleAdmin/SaveSubCategory', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadLists();
        })
        .catch(err => alert("Save failed: " + err.message));
    }

    function removeSubCategory() {
        let subName = document.getElementById("subName").value;
        if (!subName) return;

        if (!confirm("Remove " + subName + "?")) return;

        fetch('/MSaleAdmin/DeleteSubCategory?subName=' + encodeURIComponent(subName), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Removed");
            clearFields();
            loadLists();
        })
        .catch(err => alert("Remove failed: " + err.message));
    }

    function changeSubName() {
        let oldName = document.getElementById("subName").value;
        let newName = document.getElementById("newSubName").value;

        if (!oldName || !newName) return;

        fetch('/MSaleAdmin/RenameSubCategory', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ oldName: oldName, newName: newName })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Updated");
            clearFields();
            loadLists();
        })
        .catch(err => alert("Rename failed: " + err.message));
    }

    function clearFields() {
        document.getElementById("subName").value = "";
        document.getElementById("categoryName").value = "";
        document.getElementById("newSubName").value = "";

        for (let i = 1; i <= 5; i++) {
            document.getElementById("timedEvent" + i).value = "None";
        }
    }
</script>
