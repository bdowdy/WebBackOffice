@{
    ViewData["Title"] = "Modifier Maintenance";
    ViewData["Subtitle"] = "Create modifiers and manage their item lists.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="newModifier()">New Modifier</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveModifier()">Save Modifier</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteModifier()">Delete Modifier</button>

        <div class="flex-1"></div>

        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/MSaleAdmin'">Dashboard</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[320px_1fr_320px]">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Modifier Names</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="modifierSelect" class="block text-sm font-medium text-slate-700">Select Modifier</label>
                    <select id="modifierSelect" onchange="loadModifierItems()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>

                <div>
                    <label for="modifierName" class="block text-sm font-medium text-slate-700">Modifier Name</label>
                    <input id="modifierName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <button type="button" class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveModifier()">
                    Save Modifier Name
                </button>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Modifier Items</h3>

            <select id="itemList" size="25" onchange="loadItemEditor()" class="mt-3 block w-full rounded-lg border-0 bg-white p-1 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>

            <div class="mt-3 flex flex-wrap gap-2">
                <button type="button" class="inline-flex flex-1 items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="addItem()">Add Item</button>
                <button type="button" class="inline-flex flex-1 items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="removeItem()">Remove Item</button>
                <button type="button" class="inline-flex flex-1 items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveItems()">Save Items</button>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Selected Item</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="itemName" class="block text-sm font-medium text-slate-700">Item Name</label>
                    <input id="itemName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <div>
                    <label for="itemSort" class="block text-sm font-medium text-slate-700">Sort Order</label>
                    <input id="itemSort" type="number" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" />
                </div>

                <button type="button" class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="applyItemEditor()">
                    Apply Item
                </button>
            </div>
        </div>

    </div>
</div>

<script>
    let modifierItems = [];
    let selectedItemIndex = -1;

    document.addEventListener("DOMContentLoaded", function () {
        loadModifiers();
    });

    function loadModifiers() {
        fetch('/ModifierMaintenance/GetModifierNames')
            .then(r => r.json())
            .then(data => {
                const sel = document.getElementById("modifierSelect");
                sel.innerHTML = "";
                sel.add(new Option("-- Select Modifier --", ""));

                data.forEach(x => {
                    sel.add(new Option(x, x));
                });

                if (data.length > 0) {
                    sel.value = data[0];
                    document.getElementById("modifierName").value = data[0];
                    loadModifierItems();
                }
            })
            .catch(err => alert("Could not load modifiers: " + err.message));
    }

    function loadModifierItems() {
        const modName = document.getElementById("modifierSelect").value;
        document.getElementById("modifierName").value = modName;

        if (!modName) {
            modifierItems = [];
            selectedItemIndex = -1;
            drawItems();
            clearItemEditor();
            return;
        }

        fetch('/ModifierMaintenance/GetModifierItems?modifierName=' + encodeURIComponent(modName))
            .then(r => r.json())
            .then(data => {
                modifierItems = data || [];
                selectedItemIndex = -1;
                drawItems();
                clearItemEditor();
            })
            .catch(err => alert("Could not load modifier items: " + err.message));
    }

    function drawItems() {
        const list = document.getElementById("itemList");
        list.innerHTML = "";

        modifierItems.forEach((x, i) => {
            const text = (x.modifierCategory || "");
            list.add(new Option(text, i));
        });
    }

    function newModifier() {
        document.getElementById("modifierSelect").value = "";
        document.getElementById("modifierName").value = "";

        modifierItems = [];
        selectedItemIndex = -1;

        drawItems();
        clearItemEditor();
    }

    function saveModifier() {
        const name = document.getElementById("modifierName").value.trim();

        if (!name) {
            alert("Enter a modifier name.");
            return;
        }

        fetch('/ModifierMaintenance/SaveModifierName', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ modifierName: name })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadModifiers();
        })
        .catch(err => alert("Save failed: " + err.message));
    }

    function deleteModifier() {
        const name = document.getElementById("modifierSelect").value;

        if (!name) {
            alert("Select a modifier first.");
            return;
        }

        if (!confirm("Delete modifier and its items?")) {
            return;
        }

        fetch('/ModifierMaintenance/DeleteModifierName', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ modifierName: name })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            newModifier();
            loadModifiers();
        })
        .catch(err => alert("Delete failed: " + err.message));
    }

    function addItem() {
        modifierItems.push({
            modifierCategory: "New Item",
            pos: modifierItems.length
        });

        selectedItemIndex = modifierItems.length - 1;

        drawItems();

        document.getElementById("itemList").value = selectedItemIndex;
        loadItemEditor();
    }

    function removeItem() {
        const list = document.getElementById("itemList");
        const idx = parseInt(list.value);

        if (isNaN(idx)) {
            alert("Select an item first.");
            return;
        }

        modifierItems.splice(idx, 1);

        modifierItems.forEach((x, i) => {
            x.pos = i;
        });

        selectedItemIndex = -1;

        drawItems();
        clearItemEditor();
    }

    function loadItemEditor() {
        const idx = parseInt(document.getElementById("itemList").value);

        if (isNaN(idx)) {
            return;
        }

        selectedItemIndex = idx;

        const item = modifierItems[idx];

        document.getElementById("itemName").value = item.modifierCategory || "";
        document.getElementById("itemSort").value = item.pos ?? idx;
    }

    function applyItemEditor() {
        if (selectedItemIndex < 0) {
            return;
        }

        const name = document.getElementById("itemName").value.trim();
        const sort = parseInt(document.getElementById("itemSort").value || selectedItemIndex);

        modifierItems[selectedItemIndex].modifierCategory = name;
        modifierItems[selectedItemIndex].pos = sort;

        modifierItems.sort((a, b) => {
            return (a.pos ?? 0) - (b.pos ?? 0);
        });

        drawItems();
        clearItemEditor();
        selectedItemIndex = -1;
    }

    function clearItemEditor() {
        document.getElementById("itemName").value = "";
        document.getElementById("itemSort").value = "";
    }

    function saveItems() {
        const modName = document.getElementById("modifierName").value.trim();

        if (!modName) {
            alert("Enter a modifier name first.");
            return;
        }

        if (selectedItemIndex >= 0) {
            applyItemEditor();
        }

        modifierItems.forEach((x, i) => {
            x.pos = i;
        });

        fetch('/ModifierMaintenance/SaveModifierItems', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                modifierName: modName,
                items: modifierItems
            })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadModifiers();
        })
        .catch(err => alert("Save failed: " + err.message));
    }
</script>
