@{
    ViewData["Title"] = "Modifier Maintenance";
    ViewData["Subtitle"] = "Create modifiers and manage their item lists.";
}

<div class="space-y-6">

    <div class="flex flex-wrap items-center gap-2">
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="newModifier()">New Modifier</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveAll()">Save</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteModifier()">Delete Modifier</button>

        <div class="flex-1"></div>

        <span id="statusLine" class="text-sm text-slate-500"></span>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/MSaleAdmin'">Dashboard</button>
        <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="location.href='/'">Exit</button>
    </div>

    <div class="grid gap-6 lg:grid-cols-[340px_1fr]">

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-base font-semibold text-slate-900">Modifier</h3>

            <div class="mt-4 space-y-4">
                <div>
                    <label for="modifierSelect" class="block text-sm font-medium text-slate-700">Select Modifier</label>
                    <select id="modifierSelect" onchange="onModifierChange()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-500"></select>
                </div>

                <div>
                    <label for="modifierName" class="block text-sm font-medium text-slate-700">Modifier Name</label>
                    <input id="modifierName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="e.g. Cheese Choices" />
                    <p class="mt-1 text-sm text-slate-500">Pick a modifier to edit, or type a new name to create one.</p>
                </div>
            </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="flex items-center justify-between">
                <h3 class="text-base font-semibold text-slate-900">Items</h3>
                <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-emerald-700 shadow-sm ring-1 ring-inset ring-emerald-200 transition hover:bg-emerald-50" onclick="addItem()">+ Add Item</button>
            </div>

            <p class="mt-1 text-sm text-slate-500">Type item names in order. Drag with the arrows to reorder; changes are saved with the Save button.</p>

            <div id="itemsContainer" class="mt-4 space-y-2"></div>

            <p id="emptyHint" class="mt-4 rounded-lg bg-slate-50 px-3 py-6 text-center text-sm text-slate-500">No items yet. Click "Add Item" to create one.</p>
        </div>

    </div>
</div>

<script>
    // Single source of truth: array of item names (order = sort order).
    let items = [];
    let dirty = false;

    document.addEventListener("DOMContentLoaded", loadModifiers);

    function setStatus(msg) {
        document.getElementById("statusLine").textContent = msg || "";
    }

    function markDirty() {
        dirty = true;
        setStatus("Unsaved changes");
    }

    function loadModifiers() {
        fetch('/ModifierMaintenance/GetModifierNames')
            .then(r => r.json())
            .then(data => {
                const sel = document.getElementById("modifierSelect");
                const current = document.getElementById("modifierName").value;
                sel.innerHTML = "";
                sel.add(new Option("-- Select Modifier --", ""));
                data.forEach(x => sel.add(new Option(x, x)));

                if (current && data.includes(current)) {
                    sel.value = current;
                } else if (data.length > 0) {
                    sel.value = data[0];
                    document.getElementById("modifierName").value = data[0];
                    loadItems(data[0]);
                }
            })
            .catch(err => alert("Could not load modifiers: " + err.message));
    }

    function onModifierChange() {
        const name = document.getElementById("modifierSelect").value;
        document.getElementById("modifierName").value = name;
        if (name) {
            loadItems(name);
        } else {
            items = [];
            renderItems();
        }
    }

    function loadItems(name) {
        fetch('/ModifierMaintenance/GetModifierItems?modifierName=' + encodeURIComponent(name))
            .then(r => r.json())
            .then(data => {
                items = (data || []).map(x => x.modifierCategory || "");
                dirty = false;
                setStatus("");
                renderItems();
            })
            .catch(err => alert("Could not load modifier items: " + err.message));
    }

    function newModifier() {
        document.getElementById("modifierSelect").value = "";
        document.getElementById("modifierName").value = "";
        items = [];
        dirty = false;
        setStatus("New modifier");
        renderItems();
        document.getElementById("modifierName").focus();
    }

    function addItem() {
        items.push("");
        markDirty();
        renderItems();
        const inputs = document.querySelectorAll("#itemsContainer input");
        if (inputs.length) inputs[inputs.length - 1].focus();
    }

    function moveItem(i, dir) {
        const j = i + dir;
        if (j < 0 || j >= items.length) return;
        const tmp = items[i];
        items[i] = items[j];
        items[j] = tmp;
        markDirty();
        renderItems();
        const inputs = document.querySelectorAll("#itemsContainer input");
        if (inputs[j]) inputs[j].focus();
    }

    function removeItem(i) {
        items.splice(i, 1);
        markDirty();
        renderItems();
    }

    function renderItems() {
        const c = document.getElementById("itemsContainer");
        c.innerHTML = "";

        document.getElementById("emptyHint").style.display =
            items.length ? "none" : "block";

        items.forEach((name, i) => {
            const row = document.createElement("div");
            row.className = "flex items-center gap-2";

            const orderBtns = document.createElement("div");
            orderBtns.className = "flex flex-col";
            orderBtns.appendChild(arrowBtn("▲", i === 0, () => moveItem(i, -1)));
            orderBtns.appendChild(arrowBtn("▼", i === items.length - 1, () => moveItem(i, 1)));
            row.appendChild(orderBtns);

            const num = document.createElement("span");
            num.className = "w-6 text-right text-xs text-slate-400";
            num.textContent = (i + 1);
            row.appendChild(num);

            const input = document.createElement("input");
            input.value = name;
            input.placeholder = "Item name";
            input.className = "flex-1 rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500";
            input.oninput = () => { items[i] = input.value; markDirty(); };
            input.onkeydown = (e) => { if (e.key === "Enter") { e.preventDefault(); addItem(); } };
            row.appendChild(input);

            const rm = document.createElement("button");
            rm.type = "button";
            rm.title = "Remove item";
            rm.className = "inline-flex h-9 w-9 items-center justify-center rounded-lg text-rose-600 ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50";
            rm.textContent = "✕";
            rm.onclick = () => removeItem(i);
            row.appendChild(rm);

            c.appendChild(row);
        });
    }

    function arrowBtn(glyph, disabled, handler) {
        const b = document.createElement("button");
        b.type = "button";
        b.textContent = glyph;
        b.disabled = disabled;
        b.className = "flex h-4 w-6 items-center justify-center text-[10px] leading-none text-slate-500 hover:text-slate-800 disabled:opacity-25";
        if (!disabled) b.onclick = handler;
        return b;
    }

    function saveAll() {
        const name = document.getElementById("modifierName").value.trim();
        if (!name) {
            alert("Enter a modifier name.");
            document.getElementById("modifierName").focus();
            return;
        }

        // Build payload in list order, dropping blank rows, renumbering pos.
        const payload = items
            .map(x => (x || "").trim())
            .filter(x => x !== "")
            .map((x, idx) => ({ modifierCategory: x, pos: idx }));

        setStatus("Saving...");

        fetch('/ModifierMaintenance/SaveModifierItems', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ modifierName: name, items: payload })
        })
        .then(r => r.json())
        .then(x => {
            dirty = false;
            setStatus("Saved");
            // refresh the dropdown and keep this modifier selected
            loadModifiers();
            loadItems(name);
        })
        .catch(err => { setStatus(""); alert("Save failed: " + err.message); });
    }

    function deleteModifier() {
        const name = document.getElementById("modifierSelect").value
            || document.getElementById("modifierName").value.trim();
        if (!name) {
            alert("Select a modifier first.");
            return;
        }
        if (!confirm('Delete modifier "' + name + '" and all its items?')) return;

        fetch('/ModifierMaintenance/DeleteModifierName', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ modifierName: name })
        })
        .then(r => r.json())
        .then(x => {
            newModifier();
            setStatus("Deleted");
            loadModifiers();
        })
        .catch(err => alert("Delete failed: " + err.message));
    }

    window.addEventListener("beforeunload", function (e) {
        if (dirty) { e.preventDefault(); e.returnValue = ""; }
    });
</script>
