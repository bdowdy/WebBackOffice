@{
    ViewData["Title"] = "Discount / Coupon Reasons";
    ViewData["Subtitle"] = "Add, edit, or delete coupon and discount reasons.";
}

<div class="max-w-xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">

        <input type="hidden" id="originalName" />

        <label for="reasonName" class="block text-sm font-medium text-slate-700">Reason Name</label>
        <input id="reasonName" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500" placeholder="Enter reason name" />

        <div class="flex flex-wrap items-center gap-2 pt-4">
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveReason()">Save</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteReason()">Delete</button>
            <button type="button" class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearReason()">Clear</button>
        </div>

    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-base font-semibold text-slate-900">Existing Reasons</h2>
        <div id="reasonList" class="mt-3 max-h-80 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>
    </div>

</div>

<script>
    let selectedRow = null;
    const SEL = ['bg-emerald-50', 'text-emerald-900', 'font-medium'];

    document.addEventListener("DOMContentLoaded", function () {
        loadReasons();
    });

    function loadReasons() {
        fetch('/MSaleAdmin/GetCouponReasons')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById('reasonList');
                list.innerHTML = '';

                data.forEach(function (x) {
                    let div = document.createElement('div');
                    div.className = 'cursor-pointer px-4 py-2.5 text-sm hover:bg-slate-50';
                    div.textContent = x.name;

                    div.onclick = function () {
                        if (selectedRow) selectedRow.classList.remove('selected', ...SEL);
                        selectedRow = div;
                        selectedRow.classList.add('selected', ...SEL);

                        document.getElementById('reasonName').value = x.name;
                        document.getElementById('originalName').value = x.name;
                    };

                    list.appendChild(div);
                });
            });
    }

    function saveReason() {
        let item = {
            name: document.getElementById('reasonName').value,
            originalName: document.getElementById('originalName').value
        };

        if (!item.name.trim()) {
            alert("Enter a reason name.");
            return;
        }

        fetch('/MSaleAdmin/SaveCouponReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Saved");
            loadReasons();
            clearReason();
        });
    }

    function deleteReason() {
        let item = {
            name: document.getElementById('originalName').value || document.getElementById('reasonName').value
        };

        if (!item.name.trim()) {
            alert("Select a reason to delete.");
            return;
        }

        if (!confirm("Delete reason " + item.name + "?")) return;

        fetch('/MSaleAdmin/DeleteCouponReason', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item)
        })
        .then(r => r.json())
        .then(result => {
            alert(result.message || "Deleted");
            loadReasons();
            clearReason();
        });
    }

    function clearReason() {
        document.getElementById('reasonName').value = '';
        document.getElementById('originalName').value = '';

        if (selectedRow) {
            selectedRow.classList.remove('selected', ...SEL);
            selectedRow = null;
        }
    }
</script>
