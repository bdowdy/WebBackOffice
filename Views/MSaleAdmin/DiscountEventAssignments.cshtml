@{
    ViewData["Title"] = "Discount Event Assignments";
}

<style>
    body {
        background: #f4f6f9;
    }

    .page {
        max-width: 900px;
        margin: 35px auto;
        background: white;
        padding: 28px;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(0,0,0,.12);
    }

    .header {
        background: #2c3e50;
        color: white;
        padding: 24px;
        border-radius: 14px;
        margin-bottom: 24px;
    }

    .section {
        border: 1px solid #e1e5ea;
        background: #fafafa;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 22px;
    }

    label {
        font-weight: 700;
        color: #34495e;
        margin-bottom: 6px;
        display: block;
    }

    select, input {
        width: 100%;
        height: 42px;
        border: 1px solid #cfd6dd;
        border-radius: 8px;
        padding: 0 12px;
        box-sizing: border-box;
        font-size: 15px;
    }

    .discount-list {
        max-height: 420px;
        overflow-y: auto;
        background: white;
        border: 1px solid #dce1e6;
        border-radius: 10px;
        padding: 10px;
    }

    .discount-item {
        display: block;
        padding: 10px;
        border-bottom: 1px solid #eee;
        cursor: pointer;
        font-weight: 600;
    }

        .discount-item:hover {
            background: #eef6ff;
        }

        .discount-item input {
            width: auto;
            height: auto;
            margin-right: 8px;
        }

    .button-bar {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    button {
        border: none;
        border-radius: 8px;
        padding: 11px 22px;
        font-weight: 700;
        color: white;
        cursor: pointer;
    }

    .btn-save {
        background: #27ae60;
    }

    .btn-delete {
        background: #e74c3c;
    }

    .btn-clear {
        background: #7f8c8d;
    }
</style>

<div class="page">

    <div class="header">
        <h2>Discount Event Assignments</h2>
        <div>Select an event and check the discounts assigned to that event.</div>
    </div>

    <div class="section">
        <label>Event Name</label>

        <select id="eventName" onchange="loadSelectedEvent()">
            <option value="">Select Event</option>
        </select>
    </div>

    <div class="section">
        <label>Discounts</label>

        <div id="discountList" class="discount-list"></div>

        <div class="button-bar">
            <button class="btn-clear" onclick="clearPickList()">Clear</button>
            <button class="btn-delete" onclick="deleteEvent()">Delete</button>
            <button class="btn-save" onclick="saveEvent()">Save</button>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadEvents();
        loadDiscounts();
    });

    function loadEvents() {
        fetch('/MSaleAdmin/GetDiscountAssignmentEvents')
            .then(r => r.json())
            .then(data => {
                let combo = document.getElementById("eventName");

                combo.innerHTML =
                    '<option value="">Select Event</option>';

                data.forEach(function (name) {
                    let opt = document.createElement("option");
                    opt.value = name;
                    opt.text = name;
                    combo.appendChild(opt);
                });
            });
    }

    function loadDiscounts() {
        fetch('/MSaleAdmin/GetDiscountAssignmentDiscounts')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("discountList");
                list.innerHTML = "";

                data.forEach(function (name, index) {
                    let label = document.createElement("label");
                    label.className = "discount-item";

                    label.innerHTML =
                        `<input type="checkbox"
                                class="discount-check"
                                data-pos="${index}"
                                value="${escapeAttr(name)}" />
                         ${escapeHtml(name)}`;

                    list.appendChild(label);
                });
            });
    }

    function loadSelectedEvent() {
        clearPickList();

        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) return;

        fetch('/MSaleAdmin/GetDiscountAssignmentSelected?eventName='
            + encodeURIComponent(eventName))
            .then(r => r.json())
            .then(data => {
                document.querySelectorAll(".discount-check")
                    .forEach(function (box) {
                        if (data.includes(box.value)) {
                            box.checked = true;
                        }
                    });
            });
    }

    function clearPickList() {
        document.querySelectorAll(".discount-check")
            .forEach(x => x.checked = false);
    }

    function saveEvent() {
        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) {
            alert("Select an event first.");
            return;
        }

        let selected = [];

        document.querySelectorAll(".discount-check")
            .forEach(function (box) {
                if (box.checked) {
                    selected.push({
                        pos: parseInt(box.dataset.pos),
                        discountName: box.value
                    });
                }
            });

        fetch('/MSaleAdmin/SaveDiscountAssignmentEvent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                eventName: eventName,
                discounts: selected
            })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadEvents();
        });
    }

    function deleteEvent() {
        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) {
            alert("Select an event first.");
            return;
        }

        if (!confirm("Delete this event assignment?"))
            return;

        fetch('/MSaleAdmin/DeleteDiscountAssignmentEvent?eventName='
            + encodeURIComponent(eventName), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            document.getElementById("eventName").value = "";
            clearPickList();
            loadEvents();
        });
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function escapeAttr(value) {
        return escapeHtml(value);
    }
</script>