@{
    ViewData["Title"] = "Discount Event Assignments";
    ViewData["Subtitle"] = "Select an event and check the discounts assigned to that event.";
}

<div class="max-w-2xl space-y-6">

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <label class="block text-sm font-medium text-slate-700">Event Name</label>

        <select id="eventName" onchange="loadSelectedEvent()" class="mt-1 block w-full rounded-lg border-0 bg-white px-3 py-2 text-sm shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-500">
            <option value="">Select Event</option>
        </select>
    </div>

    <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <label class="block text-sm font-medium text-slate-700">Discounts</label>

        <div id="discountList" class="mt-1 max-h-96 divide-y divide-slate-100 overflow-y-auto rounded-lg bg-white ring-1 ring-slate-200"></div>

        <div class="flex flex-wrap items-center justify-end gap-2 pt-4">
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition hover:bg-slate-50" onclick="clearPickList()">Clear</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200 transition hover:bg-rose-50" onclick="deleteEvent()">Delete</button>
            <button class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500" onclick="saveEvent()">Save</button>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadEvents();
        loadDiscounts();
    });

    function loadEvents() {
        fetch('/MSaleAdmin/GetDiscountAssignmentEvents')
            .then(r => r.json())
            .then(data => {
                let combo = document.getElementById("eventName");

                combo.innerHTML =
                    '<option value="">Select Event</option>';

                data.forEach(function (name) {
                    let opt = document.createElement("option");
                    opt.value = name;
                    opt.text = name;
                    combo.appendChild(opt);
                });
            });
    }

    function loadDiscounts() {
        fetch('/MSaleAdmin/GetDiscountAssignmentDiscounts')
            .then(r => r.json())
            .then(data => {
                let list = document.getElementById("discountList");
                list.innerHTML = "";

                data.forEach(function (name, index) {
                    let label = document.createElement("label");
                    label.className = "flex cursor-pointer select-none items-center gap-3 px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50";

                    label.innerHTML =
                        `<input type="checkbox"
                                class="discount-check h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                                data-pos="${index}"
                                value="${escapeAttr(name)}" />
                         ${escapeHtml(name)}`;

                    list.appendChild(label);
                });
            });
    }

    function loadSelectedEvent() {
        clearPickList();

        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) return;

        fetch('/MSaleAdmin/GetDiscountAssignmentSelected?eventName='
            + encodeURIComponent(eventName))
            .then(r => r.json())
            .then(data => {
                document.querySelectorAll(".discount-check")
                    .forEach(function (box) {
                        if (data.includes(box.value)) {
                            box.checked = true;
                        }
                    });
            });
    }

    function clearPickList() {
        document.querySelectorAll(".discount-check")
            .forEach(x => x.checked = false);
    }

    function saveEvent() {
        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) {
            alert("Select an event first.");
            return;
        }

        let selected = [];

        document.querySelectorAll(".discount-check")
            .forEach(function (box) {
                if (box.checked) {
                    selected.push({
                        pos: parseInt(box.dataset.pos),
                        discountName: box.value
                    });
                }
            });

        fetch('/MSaleAdmin/SaveDiscountAssignmentEvent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                eventName: eventName,
                discounts: selected
            })
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Saved");
            loadEvents();
        });
    }

    function deleteEvent() {
        let eventName =
            document.getElementById("eventName").value;

        if (!eventName) {
            alert("Select an event first.");
            return;
        }

        if (!confirm("Delete this event assignment?"))
            return;

        fetch('/MSaleAdmin/DeleteDiscountAssignmentEvent?eventName='
            + encodeURIComponent(eventName), {
            method: 'POST'
        })
        .then(r => r.json())
        .then(x => {
            alert(x.message || "Deleted");
            document.getElementById("eventName").value = "";
            clearPickList();
            loadEvents();
        });
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function escapeAttr(value) {
        return escapeHtml(value);
    }
</script>
